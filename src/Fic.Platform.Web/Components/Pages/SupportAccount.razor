@page "/support/account"

<PageTitle>Account Support</PageTitle>

<section class="panel company-support">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star account support</p>
            <h2>Account and access help</h2>
            <p class="lede">
                Support for log-in, password recovery, and account ownership questions. This keeps the company support
                layer separate from the merchant-owned workspace.
            </p>
        </div>
    </div>

    <div class="company-support__links company-support__links--stack">
        <a class="button button--primary" href="/account/login">Go to Log In</a>
        <a class="button button--ghost" href="/account/forgot-password">Reset password</a>
        <a class="button button--ghost" href="/support/billing">Billing support</a>
    </div>

    <CompanySocialRail Compact="true" />
</section>

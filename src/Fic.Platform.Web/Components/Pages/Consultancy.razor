@page "/consultancy"

<PageTitle>Training &amp; Consultancy</PageTitle>

<section class="panel company-support company-support--wide">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star Customer Solutions</p>
            <h2>Training &amp; Consultancy</h2>
            <p class="lede">
                Strategic support for loyalty, membership, and customer strategy. FIC is the product surface; North
                Star is the thinking, training, and commercial guidance behind it.
            </p>
        </div>
    </div>

    <div class="company-support__pillars">
        <article class="company-support__pillar">
            <h3>Insight</h3>
            <p>Understand customer behaviour, segmentation, and the commercial shape of loyalty.</p>
        </article>

        <article class="company-support__pillar">
            <h3>Value</h3>
            <p>Design propositions that customers genuinely want to come back for.</p>
        </article>

        <article class="company-support__pillar">
            <h3>Experience</h3>
            <p>Shape the join, earn, and reward journey so the programme feels coherent in-store and in Wallet.</p>
        </article>

        <article class="company-support__pillar">
            <h3>Loyalty</h3>
            <p>Turn programme mechanics into repeat behaviour and longer-term customer relationships.</p>
        </article>
    </div>

    <div class="company-support__actions">
        <a class="button button--primary" href="/portal/signup">Start with FIC</a>
        <button class="button button--ghost" type="button" disabled>Book strategy session</button>
    </div>

    <CompanySocialRail Compact="true" />
</section>

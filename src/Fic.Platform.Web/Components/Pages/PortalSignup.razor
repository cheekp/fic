@page "/portal/signup"
@using System.ComponentModel.DataAnnotations
@using System.Text
@inject DemoPlatformState PlatformState
@inject NavigationManager Navigation

<PageTitle>Set Up Your Shop</PageTitle>

<section class="panel signup-panel signup-panel--entry">
    <div class="panel__header">
        <div>
            <p class="eyebrow">Step 1 of 2</p>
            <h2>Create your shop account</h2>
            <p class="lede">Enter the shop details. Billing is next, then your workspace opens.</p>
        </div>
    </div>

    <EditForm Model="_form" OnValidSubmit="HandleSubmitAsync" FormName="create-shop" class="form-stack">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="form-grid">
            <label class="field">
                <span>Coffee shop name</span>
                <InputText @bind-Value="_form.DisplayName" class="input" />
            </label>

            <label class="field">
                <span>Owner email</span>
                <InputText @bind-Value="_form.ContactEmail" class="input" />
            </label>

            <label class="field">
                <span>Town or city</span>
                <InputText @bind-Value="_form.TownOrCity" class="input" />
            </label>

            <label class="field">
                <span>Postcode</span>
                <InputText @bind-Value="_form.Postcode" class="input" />
            </label>

        </div>

        <div class="form-actions">
            <button class="button button--primary" type="submit" disabled="@_isSubmitting">Continue to Billing</button>
            <a class="button button--ghost" href="/">Back to start</a>
        </div>
    </EditForm>
</section>

@code {
    private readonly SignupFormModel _form = new();
    private bool _isSubmitting;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var workspace = await PlatformState.CreateMerchantAsync(
                _form.DisplayName,
                _form.TownOrCity,
                _form.Postcode,
                _form.ContactEmail,
                null,
                BuildFallbackLogo(_form.DisplayName, DefaultPrimaryColor, DefaultAccentColor),
                DefaultPrimaryColor,
                DefaultAccentColor,
                Navigation.BaseUri);

            Navigation.NavigateTo($"/portal/signup/billing/{workspace.Merchant.MerchantId}");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private static string GetInitials(string name)
    {
        var initials = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length == 0 ? "F" : new string(initials);
    }

    private static string BuildFallbackLogo(string displayName, string primaryColor, string accentColor)
    {
        var initials = GetInitials(displayName);
        var svg =
            $"""
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" role="img" aria-label="{displayName}">
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="{NormalizeColor(primaryColor)}" />
                  <stop offset="100%" stop-color="{NormalizeColor(accentColor)}" />
                </linearGradient>
              </defs>
              <rect width="160" height="160" rx="34" fill="url(#g)" />
              <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-size="58" font-family="Trebuchet MS, sans-serif" fill="#fff8e3">{initials}</text>
            </svg>
            """;

        return $"data:image/svg+xml;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(svg))}";
    }

    private const string DefaultPrimaryColor = "#1f3731";
    private const string DefaultAccentColor = "#f4c15d";

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private sealed class SignupFormModel
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = "Jo's Coffee";

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = "owner@joscoffee.test";

        [Required, StringLength(60)]
        public string TownOrCity { get; set; } = "Bristol";

        [Required, StringLength(12)]
        public string Postcode { get; set; } = "BS1 4DJ";
    }
}

@page "/portal/signup"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.DependencyInjection
@inject DemoPlatformState PlatformState
@inject NavigationManager Navigation
@inject IServiceProvider Services

<PageTitle>Set Up Your Shop</PageTitle>

<section class="signup-journey-strip signup-journey-strip--entry">
    <OnboardingJourney CurrentStep="account"
                       AccountComplete="false"
                       PlanComplete="false"
                       BillingComplete="false"
                       ShopComplete="false"
                       ProgrammeComplete="false"
                       IsStrip="true"
                       AccountUrl="/portal/signup" />
</section>

<section class="panel signup-panel signup-panel--entry onboarding-step">
    <div class="panel__header onboarding-step__header">
        <div class="onboarding-step__copy">
            <p class="eyebrow">Step 1 of 5</p>
            <h2>Create your shop</h2>
            <p class="lede">Start with shop details. Next, choose a plan, set billing and owner access, then pick your first programme template.</p>
        </div>
    </div>

    <EditForm Model="_form" OnValidSubmit="HandleSubmitAsync" FormName="create-shop" class="form-stack onboarding-form" aria-describedby="signup-required-note">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="form-grid">
            <label class="field">
                <span>Coffee shop name</span>
                <InputText @bind-Value="_form.DisplayName" class="input" autocomplete="organization" placeholder="Jo's Coffee" />
                <ValidationMessage For="() => _form.DisplayName" class="field-error" />
            </label>

            <label class="field">
                <span>Owner email</span>
                <InputText @bind-Value="_form.ContactEmail" class="input" autocomplete="email" placeholder="owner@shop.com" />
                <ValidationMessage For="() => _form.ContactEmail" class="field-error" />
            </label>

        </div>

        <p id="signup-required-note" class="field-hint onboarding-required-note">Both fields are required to create your workspace and continue to plan selection.</p>

        <div class="form-actions form-actions--onboarding">
            <button class="button button--primary button--wide" type="submit" disabled="@_isSubmitting">Continue to Plan</button>
            @if (IsSignupDemoSeedEnabled)
            {
                <button class="button button--secondary button--wide" type="button" disabled="@_isSubmitting" @onclick="ApplyDemoSeed">Use demo details</button>
            }
        </div>

        <p class="onboarding-back-link"><a class="inline-link" href="/">Back to start</a></p>
    </EditForm>
</section>

@code {
    private readonly SignupFormModel _form = new();
    private bool _isSubmitting;
    private bool IsSignupDemoSeedEnabled =>
        Services.GetService<IConfiguration>()?.GetValue<bool>("Features:SignupDemoSeedEnabled") ?? false;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var workspace = await PlatformState.CreateMerchantAsync(
                _form.DisplayName,
                string.Empty,
                string.Empty,
                _form.ContactEmail,
                null,
                BuildFallbackLogo(_form.DisplayName, DefaultPrimaryColor, DefaultAccentColor),
                DefaultPrimaryColor,
                DefaultAccentColor,
                Navigation.BaseUri);

            Navigation.NavigateTo($"/portal/signup/plan/{workspace.Merchant.MerchantId}");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private void ApplyDemoSeed()
    {
        _form.DisplayName = "Jo's Coffee";
        _form.ContactEmail = "owner@joscoffee.test";
    }

    private static string GetInitials(string name)
    {
        var initials = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length == 0 ? "F" : new string(initials);
    }

    private static string BuildFallbackLogo(string displayName, string primaryColor, string accentColor)
    {
        var initials = GetInitials(displayName);
        var svg =
            $"""
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" role="img" aria-label="{displayName}">
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="{NormalizeColor(primaryColor)}" />
                  <stop offset="100%" stop-color="{NormalizeColor(accentColor)}" />
                </linearGradient>
              </defs>
              <rect width="160" height="160" rx="34" fill="url(#g)" />
              <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-size="58" font-family="Trebuchet MS, sans-serif" fill="#fff8e3">{initials}</text>
            </svg>
            """;

        return $"data:image/svg+xml;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(svg))}";
    }

    private const string DefaultPrimaryColor = "#1f3731";
    private const string DefaultAccentColor = "#f4c15d";

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private sealed class SignupFormModel
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = string.Empty;

    }
}

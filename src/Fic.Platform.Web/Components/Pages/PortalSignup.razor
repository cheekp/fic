@page "/portal/signup"
@using System.ComponentModel.DataAnnotations
@using System.Text
@using Fic.MerchantAccounts
@inject DemoPlatformState PlatformState
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject MerchantBrandPresentationService BrandPresentation

<PageTitle>Create Your Loyalty Card</PageTitle>

<section class="section-header">
    <div>
        <p class="eyebrow">Set up your programme</p>
        <h2>Create the loyalty card your customers will join</h2>
        <p class="lede">This is the self-serve setup flow: add your business name, reward offer, and brand assets, then publish the join QR and start stamping visits.</p>
    </div>
</section>

<section class="panel">
    <EditForm Model="_form" OnValidSubmit="HandleSubmitAsync" FormName="create-loyalty-card" class="form-stack">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="form-grid">
            <label class="field">
                <span>Business name</span>
                <InputText @bind-Value="_form.DisplayName" class="input" />
            </label>

            <label class="field">
                <span>Owner email</span>
                <InputText @bind-Value="_form.ContactEmail" class="input" />
            </label>

            <label class="field">
                <span>What are customers collecting?</span>
                <InputText @bind-Value="_form.RewardItemLabel" class="input" />
            </label>

            <label class="field">
                <span>How many before the reward?</span>
                <InputNumber @bind-Value="_form.RewardThreshold" class="input" />
            </label>

            <label class="field field--full">
                <span>Offer text shown to customers</span>
                <InputText @bind-Value="_form.RewardCopy" class="input" />
            </label>

            <label class="field">
                <span>Site primary colour</span>
                <InputText @bind-Value="_form.PrimaryColor" class="input" />
            </label>

            <label class="field">
                <span>Site accent colour</span>
                <InputText @bind-Value="_form.AccentColor" class="input" />
            </label>

            <div class="field field--full">
                <span>Your logo</span>
                <label class="upload-control">
                    <InputFile OnChange="HandleLogoSelectedAsync" accept=".png" />
                    <span>Upload a PNG logo for the cleanest Apple Wallet result, or let the preview generate a simple initials mark for now.</span>
                </label>
                @if (!string.IsNullOrWhiteSpace(_logoUploadMessage))
                {
                    <p class="field-hint">@_logoUploadMessage</p>
                }
            </div>

            <div class="field field--full">
                <span>Wallet card branding</span>
                <p class="field-hint">The wallet card inherits your site logo and colours by default. We can add card-level overrides later without changing the merchant setup model.</p>
            </div>
        </div>

        @{
            var previewTheme = BuildPreviewTheme();
        }
        <div class="signup-preview signup-preview--studio @previewTheme.ThemeClass" style="@previewTheme.CssVariables">
            <div class="signup-preview__shell">
                <div class="signup-preview__chrome">
                    <div class="signup-preview__logo">
                        @if (!string.IsNullOrWhiteSpace(_logoPreviewUri))
                        {
                            <img src="@_logoPreviewUri" alt="@_form.DisplayName logo preview" />
                        }
                        else
                        {
                            <span>@GetInitials(_form.DisplayName)</span>
                        }
                    </div>
                    <div>
                        <p class="eyebrow">Merchant workspace feel</p>
                        <h3>@_form.DisplayName</h3>
                        <p>@BuildRewardHeadline()</p>
                        <p class="field-hint">The shell, panels, and pass all inherit the same derived brand tokens.</p>
                    </div>
                </div>

                <div class="signup-preview__surface">
                    <span class="chip chip--accent">Brand system compiled</span>
                    <div class="signup-preview__actions">
                        <span class="signup-preview__action">Customer join QR</span>
                        <span class="signup-preview__action">Till-side stamping</span>
                    </div>
                </div>
            </div>

            <div class="signup-preview__wallet @previewTheme.ThemeClass" style="@previewTheme.CssVariables">
                <p class="wallet-pass__label">Wallet card direction</p>
                <h3>@_form.DisplayName</h3>
                <p class="signup-preview__wallet-copy">@_form.RewardCopy</p>
                <p class="wallet-pass__progress">2/@_form.RewardThreshold</p>
                <div class="stamp-track" aria-label="preview stamps">
                    @for (var i = 0; i < _form.RewardThreshold; i++)
                    {
                        <span class="stamp @(i < 2 ? "stamp--filled" : string.Empty)">@(@i + 1)</span>
                    }
                </div>
            </div>
        </div>

        <div class="form-actions">
            <button class="button button--primary" type="submit" disabled="@_isSubmitting">Create My Loyalty Card</button>
            <a class="button button--ghost" href="/">Back to start</a>
        </div>
    </EditForm>
</section>

@code {
    private readonly SignupFormModel _form = new();
    private bool _isSubmitting;
    private string? _logoPreviewUri;
    private string? _logoUploadMessage;
    private byte[]? _logoUploadBytes;
    private string _logoFileName = "logo.png";
    private MerchantLogoMetadata _logoMetadata = new(160, 160);

    private async Task HandleLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!string.Equals(file.ContentType, "image/png", StringComparison.OrdinalIgnoreCase))
        {
            _logoUploadBytes = null;
            _logoPreviewUri = null;
            _logoMetadata = new MerchantLogoMetadata(160, 160);
            _logoUploadMessage = "Please upload a PNG logo for the merchant brand asset flow.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var buffer = new MemoryStream();
        await stream.CopyToAsync(buffer);

        _logoUploadBytes = buffer.ToArray();
        _logoMetadata = MerchantBrandAssetInspector.ReadLogoMetadata(_logoUploadBytes);
        _logoFileName = file.Name;
        _logoPreviewUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(_logoUploadBytes)}";
        await SuggestPaletteFromLogoAsync(_logoPreviewUri);
        _logoUploadMessage = $"{file.Name} loaded into your site preview. Suggested colours have been matched from the logo and you can still tweak them below.";
    }

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var workspace = await PlatformState.CreateMerchantAsync(
                _form.DisplayName,
                _form.ContactEmail,
                _form.RewardItemLabel,
                _form.RewardThreshold,
                _form.RewardCopy,
                _logoUploadBytes is null ? null : new MerchantLogoUpload(_logoUploadBytes, "image/png", _logoFileName),
                _logoPreviewUri ?? BuildFallbackLogo(_form.DisplayName, _form.PrimaryColor, _form.AccentColor),
                _form.PrimaryColor,
                _form.AccentColor,
                Navigation.BaseUri);

            Navigation.NavigateTo($"/portal/merchant/{workspace.Merchant.MerchantId}");
        }
        catch (InvalidOperationException ex)
        {
            _logoUploadMessage = ex.Message;
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string BuildRewardHeadline() =>
        $"Buy {_form.RewardThreshold} {_form.RewardItemLabel.ToLowerInvariant()}, get one free";

    private MerchantThemeView BuildPreviewTheme() =>
        BrandPresentation.BuildPreview(
            NormalizeColor(_form.PrimaryColor),
            NormalizeColor(_form.AccentColor),
            _logoMetadata.Width,
            _logoMetadata.Height);

    private async Task SuggestPaletteFromLogoAsync(string logoPreviewUri)
    {
        try
        {
            var palette = await JS.InvokeAsync<string[]>("ficBranding.extractPaletteFromDataUrl", logoPreviewUri);
            if (palette.Length >= 2)
            {
                _form.PrimaryColor = NormalizeColor(palette[0]);
                _form.AccentColor = NormalizeColor(palette[1]);
            }
        }
        catch (JSException)
        {
            // Keep manual colours if local JS palette extraction is unavailable.
        }
    }

    private static string GetInitials(string name)
    {
        var initials = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length == 0 ? "F" : new string(initials);
    }

    private static string BuildFallbackLogo(string displayName, string primaryColor, string accentColor)
    {
        var initials = GetInitials(displayName);
        var svg =
            $"""
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" role="img" aria-label="{displayName}">
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="{NormalizeColor(primaryColor)}" />
                  <stop offset="100%" stop-color="{NormalizeColor(accentColor)}" />
                </linearGradient>
              </defs>
              <rect width="160" height="160" rx="34" fill="url(#g)" />
              <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-size="58" font-family="Trebuchet MS, sans-serif" fill="#fff8e3">{initials}</text>
            </svg>
            """;

        return $"data:image/svg+xml;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(svg))}";
    }

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private sealed class SignupFormModel
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = "Jo's Coffee";

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = "owner@joscoffee.test";

        [Required, StringLength(40)]
        public string RewardItemLabel { get; set; } = "coffees";

        [Range(2, 20)]
        public int RewardThreshold { get; set; } = 5;

        [Required, StringLength(120)]
        public string RewardCopy { get; set; } = "Your next cuppa is free once you reach the full stamp count.";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string PrimaryColor { get; set; } = "#1f3731";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string AccentColor { get; set; } = "#f4c15d";
    }
}

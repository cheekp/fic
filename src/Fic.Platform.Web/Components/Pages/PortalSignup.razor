@page "/portal/signup"
@using System.ComponentModel.DataAnnotations
@using System.Text
@inject DemoPlatformState PlatformState
@inject NavigationManager Navigation

<PageTitle>Create Merchant Workspace</PageTitle>

<section class="section-header">
    <div>
        <p class="eyebrow">Merchant onboarding</p>
        <h2>Set up the shop, then finish everything inside the merchant workspace</h2>
        <p class="lede">Keep this step light. We create the merchant workspace and starter loyalty card template, then take you straight into the place where the owner will manage branding, card settings, join QR, and customer cards.</p>
    </div>
</section>

<section class="signup-shell">
    <article class="panel">
        <div class="panel__header">
            <div>
                <p class="eyebrow">Step 1</p>
                <h3>Create your merchant workspace</h3>
            </div>
            <span class="chip">Under a minute</span>
        </div>

        <EditForm Model="_form" OnValidSubmit="HandleSubmitAsync" FormName="create-merchant-workspace" class="form-stack">
            <DataAnnotationsValidator />
            <ValidationSummary class="validation-summary" />

            <div class="form-grid">
                <label class="field">
                    <span>Business name</span>
                    <InputText @bind-Value="_form.DisplayName" class="input" />
                </label>

                <label class="field">
                    <span>Owner email</span>
                    <InputText @bind-Value="_form.ContactEmail" class="input" />
                </label>

                <label class="field">
                    <span>What are customers collecting?</span>
                    <InputText @bind-Value="_form.RewardItemLabel" class="input" />
                </label>

                <label class="field">
                    <span>How many before the reward?</span>
                    <InputNumber @bind-Value="_form.RewardThreshold" class="input" />
                </label>
            </div>

            <p class="field-hint">We will start with a simple generated brand mark and sensible defaults. The owner uploads the real logo, tunes colours, and edits customer-facing copy inside the workspace.</p>

            <div class="form-actions">
                <button class="button button--primary" type="submit" disabled="@_isSubmitting">Continue to Merchant Workspace</button>
                <a class="button button--ghost" href="/">Back to start</a>
            </div>
        </EditForm>
    </article>

    <aside class="panel signup-sidecar">
        <div class="panel__header">
            <div>
                <p class="eyebrow">What happens next</p>
                <h3>The workspace becomes the real product</h3>
            </div>
            <span class="chip chip--accent">@BuildRewardHeadline()</span>
        </div>

        <div class="signup-checklist">
            <article class="signup-checklist__item">
                <h4>Brand the workspace</h4>
                <p>Upload the real logo, confirm colours, and make the merchant area feel like the shop.</p>
            </article>
            <article class="signup-checklist__item">
                <h4>Shape the loyalty card</h4>
                <p>Refine the reward copy and preview how the wallet card inherits the workspace brand.</p>
            </article>
            <article class="signup-checklist__item">
                <h4>Start customer operations</h4>
                <p>Open the join QR, issue customer cards, and stamp visits from the same workspace.</p>
            </article>
        </div>

        <div class="signup-summary">
            <p class="eyebrow">Starter workspace</p>
            <div class="signup-summary__identity">
                <div class="brand-lockup brand-lockup--resume signup-summary__mark">
                    <span>@GetInitials(_form.DisplayName)</span>
                </div>
                <div>
                    <h4>@_form.DisplayName</h4>
                    <p class="field-hint">@BuildRewardCopy()</p>
                </div>
            </div>
            <p class="field-hint">This is just the starting point. The more complete experience begins once the merchant lands in their own workspace.</p>
        </div>
    </aside>
</section>

@code {
    private readonly SignupFormModel _form = new();
    private bool _isSubmitting;

    private async Task HandleSubmitAsync()
    {
        _isSubmitting = true;

        try
        {
            var workspace = await PlatformState.CreateMerchantAsync(
                _form.DisplayName,
                _form.ContactEmail,
                _form.RewardItemLabel,
                _form.RewardThreshold,
                BuildRewardCopy(),
                null,
                BuildFallbackLogo(_form.DisplayName, DefaultPrimaryColor, DefaultAccentColor),
                DefaultPrimaryColor,
                DefaultAccentColor,
                Navigation.BaseUri);

            Navigation.NavigateTo($"/portal/merchant/{workspace.Merchant.MerchantId}?tab=brand");
        }
        finally
        {
            _isSubmitting = false;
        }
    }

    private string BuildRewardHeadline() =>
        $"Buy {_form.RewardThreshold} {_form.RewardItemLabel.ToLowerInvariant()}, get one free";

    private string BuildRewardCopy() => $"{BuildRewardHeadline()}.";

    private static string GetInitials(string name)
    {
        var initials = name
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Take(2)
            .Select(part => char.ToUpperInvariant(part[0]))
            .ToArray();

        return initials.Length == 0 ? "F" : new string(initials);
    }

    private static string BuildFallbackLogo(string displayName, string primaryColor, string accentColor)
    {
        var initials = GetInitials(displayName);
        var svg =
            $"""
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 160 160" role="img" aria-label="{displayName}">
              <defs>
                <linearGradient id="g" x1="0" y1="0" x2="1" y2="1">
                  <stop offset="0%" stop-color="{NormalizeColor(primaryColor)}" />
                  <stop offset="100%" stop-color="{NormalizeColor(accentColor)}" />
                </linearGradient>
              </defs>
              <rect width="160" height="160" rx="34" fill="url(#g)" />
              <text x="50%" y="54%" text-anchor="middle" dominant-baseline="middle" font-size="58" font-family="Trebuchet MS, sans-serif" fill="#fff8e3">{initials}</text>
            </svg>
            """;

        return $"data:image/svg+xml;base64,{Convert.ToBase64String(Encoding.UTF8.GetBytes(svg))}";
    }

    private const string DefaultPrimaryColor = "#1f3731";
    private const string DefaultAccentColor = "#f4c15d";

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private sealed class SignupFormModel
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = "Jo's Coffee";

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = "owner@joscoffee.test";

        [Required, StringLength(40)]
        public string RewardItemLabel { get; set; } = "coffees";

        [Range(2, 20)]
        public int RewardThreshold { get; set; } = 5;
    }
}

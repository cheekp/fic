@page "/join/{JoinCode}"
@inject DemoPlatformState PlatformState

<PageTitle>Join Loyalty Programme</PageTitle>

@if (_experience is null)
{
    <section class="empty-state">
        <h2>Join link not found.</h2>
        <p>The QR code may be stale or this demo instance has been restarted.</p>
    </section>
}
else
{
    <section class="join-hero" style="@BuildHeroStyle()">
        <div class="join-hero__content">
            <p class="eyebrow">Wallet join flow</p>
            <h2>@_experience.Merchant.DisplayName</h2>
            <p class="lede">@_experience.Programme.RewardCopy</p>
            <p class="field-hint">No customer app required. This browser step hands off to the wallet card only.</p>
        </div>
        <div class="join-hero__logo">
            <img src="@_experience.BrandProfile.LogoUrl" alt="@_experience.Merchant.DisplayName logo" />
        </div>
    </section>

    @if (_walletCard is null)
    {
        <section class="panel">
            <div class="panel__header">
                <div>
                    <p class="eyebrow">Join summary</p>
                    <h3>Issue the wallet card</h3>
                </div>
                <span class="chip chip--accent">Apple Wallet first</span>
            </div>
            <dl class="merchant-card__metrics">
                <div>
                    <dt>Offer</dt>
                    <dd>Buy @_experience.Programme.RewardThreshold @_experience.Programme.RewardItemLabel, get one free</dd>
                </div>
                <div>
                    <dt>Initial state</dt>
                    <dd>0/@_experience.Programme.RewardThreshold @_experience.Programme.RewardItemLabel.ToLowerInvariant()</dd>
                </div>
                <div>
                    <dt>Channel</dt>
                    <dd>Browser join, then wallet-only customer experience</dd>
                </div>
            </dl>
            <div class="form-actions">
                <button class="button button--primary" type="button" @onclick="IssueWalletCardAsync">Add to Wallet (demo)</button>
            </div>
        </section>
    }
    else
    {
        <section class="panel">
            <div class="panel__header">
                <div>
                    <p class="eyebrow">Wallet issued</p>
                    <h3>Pass created for the demo</h3>
                </div>
                <span class="chip chip--success">@_walletCard.ProgressDisplayText</span>
            </div>
            <p>The production path will return a signed <code>.pkpass</code>. This internal MVP opens a live wallet preview that updates when the vendor awards visits.</p>
            <div class="form-actions">
                <a class="button button--primary" href="/wallet/card/@_walletCard.CardId">Open wallet preview</a>
                <span class="field-hint">Scan code: <code>@_walletCard.CardCode</code></span>
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string JoinCode { get; set; } = string.Empty;

    private JoinExperienceSnapshot? _experience;
    private WalletCardSnapshot? _walletCard;

    protected override void OnParametersSet()
    {
        _experience = PlatformState.GetJoinExperience(JoinCode);
    }

    private Task IssueWalletCardAsync()
    {
        _walletCard = PlatformState.JoinCustomer(JoinCode);
        return Task.CompletedTask;
    }

    private string BuildHeroStyle() =>
        _experience is null
            ? string.Empty
            : $"--join-primary: {_experience.BrandProfile.PrimaryColor}; --join-accent: {_experience.BrandProfile.AccentColor};";
}

@page "/join/{JoinCode}"
@inject DemoPlatformState PlatformState
@inject NavigationManager Navigation
@inject IAppleWalletPassService WalletPasses
@inject MerchantBrandPresentationService BrandPresentation

<PageTitle>Join Loyalty Card</PageTitle>

@if (_experience is null)
{
    <section class="empty-state">
        <h2>Join link not found.</h2>
        <p>The QR code may be stale or this demo instance has been restarted.</p>
    </section>
}
else
{
    var joinTheme = BrandPresentation.Build(_experience.BrandProfile);
    var walletCapability = WalletPasses.GetCapability();

        <section class="join-hero @joinTheme.ThemeClass" style="@joinTheme.CssVariables">
            <div class="join-hero__content">
            <p class="eyebrow">Join this loyalty card</p>
            <h2>@_experience.Merchant.DisplayName</h2>
            <p class="lede">@_experience.Programme.RewardCopy</p>
            <p class="field-hint">No app to install. Join here once, then keep the card in Apple Wallet.</p>
        </div>
            <div class="join-hero__logo">
                <img src="@_experience.BrandProfile.LogoUrl" alt="@_experience.Merchant.DisplayName logo" />
            </div>
    </section>

    @if (_walletCard is null)
    {
        <section class="panel join-panel @joinTheme.ThemeClass" style="@joinTheme.CssVariables">
            <div class="panel__header">
                <div>
                    <p class="eyebrow">Save your card</p>
                    <h3>Add this loyalty card to Apple Wallet</h3>
                </div>
                <span class="chip chip--accent">Apple Wallet first</span>
            </div>
            <dl class="merchant-card__metrics">
                <div>
                    <dt>Offer</dt>
                    <dd>Buy @_experience.Programme.RewardThreshold @_experience.Programme.RewardItemLabel, get one free</dd>
                </div>
                <div>
                    <dt>Initial state</dt>
                    <dd>0/@_experience.Programme.RewardThreshold @_experience.Programme.RewardItemLabel.ToLowerInvariant()</dd>
                </div>
                <div>
                    <dt>Validity</dt>
                    <dd>@FormatDate(_experience.Programme.StartsOn) to @FormatDate(_experience.Programme.EndsOn)</dd>
                </div>
                <div>
                    <dt>Channel</dt>
                    <dd>Quick web join, then wallet-only customer experience</dd>
                </div>
            </dl>
            @if (!ProgrammeIsJoinOpen)
            {
                <p class="field-hint">@BuildProgrammeWindowMessage(_experience.Programme.StartsOn, _experience.Programme.EndsOn)</p>
            }
            <p class="field-hint">@walletCapability.HelperText</p>
            @if (walletCapability.HasDiagnostics)
            {
                <ul class="support-list">
                    @foreach (var issue in walletCapability.DiagnosticItems!)
                    {
                        <li>@issue</li>
                    }
                </ul>
                <div class="form-actions">
                    <a class="button button--ghost" href="/support/wallet-demo">Wallet demo setup</a>
                </div>
            }
            <div class="form-actions">
                <button class="button button--primary" type="button" disabled="@(!ProgrammeIsJoinOpen)" @onclick="IssueWalletCardAsync">@walletCapability.ActionLabel</button>
            </div>
        </section>
    }
    else
    {
        <section class="panel join-panel @joinTheme.ThemeClass" style="@joinTheme.CssVariables">
            <div class="panel__header">
                <div>
                    <p class="eyebrow">Your card is ready</p>
                    <h3>Your loyalty card has been created</h3>
                </div>
                <span class="chip chip--success">@_walletCard.ProgressDisplayText</span>
            </div>
            <p>This preview stands in for the final signed Apple Wallet pass and updates as the business stamps your visits.</p>
            <p class="field-hint">Valid @FormatDate(_walletCard.StartsOn) to @FormatDate(_walletCard.EndsOn)</p>
            <div class="form-actions">
                <a class="button button--primary" href="/wallet/card/@_walletCard.CardId">Open Card Preview</a>
                <span class="field-hint">Pass code: <code>@_walletCard.CardCode</code></span>
            </div>
        </section>
    }
}

@code {
    [Parameter]
    public string JoinCode { get; set; } = string.Empty;

    private JoinExperienceSnapshot? _experience;
    private WalletCardSnapshot? _walletCard;
    private bool ProgrammeIsJoinOpen =>
        _experience is not null && IsProgrammeActiveOn(_experience.Programme.StartsOn, _experience.Programme.EndsOn);

    protected override void OnParametersSet()
    {
        _experience = PlatformState.GetJoinExperience(JoinCode);
    }

    private Task IssueWalletCardAsync()
    {
        if (!ProgrammeIsJoinOpen)
        {
            return Task.CompletedTask;
        }

        _walletCard = PlatformState.JoinCustomer(JoinCode);
        if (_walletCard is not null)
        {
            if (WalletPasses.GetCapability().SupportsAppleWalletPass)
            {
                Navigation.NavigateTo($"/wallet/passes/{_walletCard.CardId}.pkpass", forceLoad: true);
            }
            else
            {
                Navigation.NavigateTo($"/wallet/card/{_walletCard.CardId}");
            }
        }
        return Task.CompletedTask;
    }

    private static bool IsProgrammeActiveOn(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        return today >= startsOn && today <= endsOn;
    }

    private static string FormatDate(DateOnly date) => date.ToString("dd MMM yyyy");

    private static string BuildProgrammeWindowMessage(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return $"This loyalty card becomes available on {FormatDate(startsOn)}.";
        }

        if (today > endsOn)
        {
            return $"This loyalty card expired on {FormatDate(endsOn)}.";
        }

        return $"This loyalty card is active until {FormatDate(endsOn)}.";
    }

}

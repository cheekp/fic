@page "/account/login"
@inject NavigationManager Navigation

<PageTitle>Log In</PageTitle>

<section class="panel company-support account-panel">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star account support</p>
            <h2>Log in to your FIC workspace</h2>
            <p class="lede">
                Sign in with the owner email and password set during onboarding. This keeps merchant workspace access
                separate from the public product lane.
            </p>
        </div>
    </div>

    <form method="post" action="/account/session/login" class="form-stack">
        <input type="hidden" name="returnUrl" value="@ResolvedReturnUrl" />
        <div class="form-grid">
            <label class="field">
                <span>Email</span>
                <input class="input" type="email" name="email" value="@ResolvedEmail" autocomplete="email" required />
            </label>

            <label class="field">
                <span>Password</span>
                <input class="input" type="password" name="password" autocomplete="current-password" required />
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="field-hint">@_message</p>
        }

        <div class="form-actions">
            <button class="button button--primary" type="submit">Log In</button>
            <a class="button button--ghost" href="/account/forgot-password">Forgot password?</a>
        </div>
    </form>

    <div class="company-support__footer">
        <p>Need help with access, billing, or rollout questions?</p>
        <div class="company-support__links">
            <a class="inline-link" href="/support/account">Account support</a>
            <a class="inline-link" href="/support/billing">Billing support</a>
            <a class="inline-link" href="/consultancy">Training &amp; consultancy</a>
        </div>
    </div>
</section>

@code {
    private string? _message;

    [SupplyParameterFromQuery]
    public string? ReturnUrl { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    [SupplyParameterFromQuery(Name = "email")]
    public string? PrefillEmail { get; set; }

    private string? ResolvedReturnUrl => string.IsNullOrWhiteSpace(ReturnUrl) ? null : ReturnUrl;
    private string ResolvedEmail => string.IsNullOrWhiteSpace(PrefillEmail) ? "owner@joscoffee.test" : PrefillEmail;

    protected override void OnParametersSet()
    {
        _message = Error switch
        {
            "merchant-not-found" => "No merchant account was found for that owner email.",
            "credentials-not-configured" => "This merchant has not finished account setup yet. Return to onboarding or support.",
            "invalid-credentials" => "The email or password did not match.",
            _ => null
        };
    }
}

@page "/account/login"
@using System.ComponentModel.DataAnnotations

<PageTitle>Log In</PageTitle>

<section class="panel company-support account-panel">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star account support</p>
            <h2>Log in to your FIC workspace</h2>
            <p class="lede">
                Merchant access sits inside the North Star support layer. Authentication is still a stub in this
                internal MVP, but the route and support framing are now in place.
            </p>
        </div>
    </div>

    <EditForm Model="_form" OnValidSubmit="HandleSubmit" FormName="log-in" class="form-stack">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <div class="form-grid">
            <label class="field">
                <span>Email</span>
                <InputText @bind-Value="_form.Email" class="input" />
            </label>

            <label class="field">
                <span>Password</span>
                <InputText @bind-Value="_form.Password" class="input" type="password" />
            </label>
        </div>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="field-hint">@_message</p>
        }

        <div class="form-actions">
            <button class="button button--primary" type="submit">Log In</button>
            <a class="button button--ghost" href="/account/forgot-password">Forgot password?</a>
        </div>
    </EditForm>

    <div class="company-support__footer">
        <p>Need help with access, billing, or rollout questions?</p>
        <div class="company-support__links">
            <a class="inline-link" href="/support/account">Account support</a>
            <a class="inline-link" href="/support/billing">Billing support</a>
            <a class="inline-link" href="/consultancy">Training &amp; consultancy</a>
        </div>
    </div>
</section>

@code {
    private readonly LoginFormModel _form = new();
    private string? _message;

    private void HandleSubmit() =>
        _message = "Authentication is not wired in this slice yet. This company-branded login surface is the supported entry point for merchants.";

    private sealed class LoginFormModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "owner@joscoffee.test";

        [Required]
        public string Password { get; set; } = "password";
    }
}

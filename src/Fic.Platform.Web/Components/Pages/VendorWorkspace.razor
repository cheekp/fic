@page "/portal/merchant/{MerchantId:guid}"
@implements IDisposable
@using System.ComponentModel.DataAnnotations
@using Fic.Contracts
@using Fic.MerchantAccounts
@inject DemoPlatformState PlatformState
@inject JoinQrCodeService QrCodes
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IAppleWalletPassService WalletPasses
@inject MerchantBrandPresentationService BrandPresentation

<PageTitle>Your Shop</PageTitle>

@if (_workspace is null)
{
    <section class="empty-state">
        <h2>Shop area not found.</h2>
        <p>The merchant account may not exist in the current demo instance.</p>
        <a class="button button--primary" href="/">Back to FIC Home</a>
    </section>
}
else
{
    var workspaceTheme = BrandPresentation.Build(_workspace.BrandProfile);
    var brandPreviewTheme = BuildBrandPreviewTheme();
    var selectedProgrammeSummary = SelectedProgrammeSummary;
    var setupSteps = BuildSetupSteps();
    var completedSetupSteps = setupSteps.Count(x => x.IsComplete);

    <div class="workspace-stage @workspaceTheme.ThemeClass" style="@workspaceTheme.CssVariables">
        <section class="workspace-header">
            <div class="workspace-brand">
                <div class="brand-lockup brand-lockup--merchant">
                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo" />
                </div>
                <div class="workspace-brand__copy">
                    <p class="eyebrow">Your shop</p>
                    <h2>@_workspace.Merchant.DisplayName</h2>
                    <p class="field-hint">@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>
                    <p class="lede">Run the shop, manage loyalty programmes, and view customer activity from one merchant-owned area.</p>
                </div>
            </div>
            <div class="workspace-actions">
                <span class="chip">@_workspace.ShopInsights.ProgrammesCount programmes</span>
                <span class="chip">@_workspace.ShopInsights.ActiveCards customers</span>
                <span class="chip">@_workspace.ShopInsights.RewardsUnlocked unlocked</span>
                @if (WalletCapability.SupportsAppleWalletPass)
                {
                    <span class="chip chip--success">Signed Apple Wallet ready</span>
                }
            </div>
        </section>

        <nav class="workspace-tabs" aria-label="Workspace scopes">
            <a class="workspace-tabs__item @(IsPrimaryTab("shop") ? "workspace-tabs__item--active" : string.Empty)" href="@GetPrimaryTabUrl("shop")">Shop</a>
            <a class="workspace-tabs__item @(IsPrimaryTab("programmes") ? "workspace-tabs__item--active" : string.Empty)" href="@GetPrimaryTabUrl("programmes")">Programmes</a>
        </nav>

        @if (IsPrimaryTab("shop"))
        {
            <nav class="workspace-tabs workspace-tabs--sub" aria-label="Shop sections">
                <a class="workspace-tabs__item @(IsShopSection("overview") ? "workspace-tabs__item--active" : string.Empty)" href="@GetShopSectionUrl("overview")">Overview</a>
                <a class="workspace-tabs__item @(IsShopSection("edit") ? "workspace-tabs__item--active" : string.Empty)" href="@GetShopSectionUrl("edit")">Edit Shop</a>
                <a class="workspace-tabs__item @(IsShopSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetShopSectionUrl("insights")">Insights</a>
            </nav>

            @if (IsShopSection("overview"))
            {
                @if (!_isSetupRoadmapDismissed)
                {
                    <section class="panel setup-roadmap @(_isSetupRoadmapCollapsed ? "setup-roadmap--collapsed" : string.Empty)">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Onboarding roadmap</p>
                                <h3>@BuildSetupRoadmapHeadline(completedSetupSteps, setupSteps.Count)</h3>
                            </div>
                            <div class="workspace-actions">
                                <span class="chip chip--accent">@completedSetupSteps/@setupSteps.Count complete</span>
                                <button class="button button--ghost button--compact" type="button" @onclick="ToggleSetupRoadmap">
                                    @(_isSetupRoadmapCollapsed ? "Show setup" : "Hide setup")
                                </button>
                                <button class="button button--ghost button--compact" type="button" @onclick="DismissSetupRoadmap">Dismiss</button>
                            </div>
                        </div>

                        @if (!_isSetupRoadmapCollapsed)
                        {
                            <p class="field-hint">@BuildSetupRoadmapMessage(setupSteps)</p>
                            <div class="setup-roadmap__steps">
                                @foreach (var step in setupSteps)
                                {
                                    <a class="setup-roadmap__step @(step.IsComplete ? "setup-roadmap__step--complete" : string.Empty) @(IsSetupStepActive(step) ? "setup-roadmap__step--current" : string.Empty)"
                                       href="@GetSetupStepUrl(step)">
                                        <span class="setup-roadmap__step-index">@step.Order</span>
                                        <span class="setup-roadmap__step-copy">
                                            <strong>@step.Label</strong>
                                            <span>@step.StatusLabel</span>
                                        </span>
                                    </a>
                                }
                            </div>
                        }
                    </section>
                }

                <section class="workspace-detail-grid">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Shop overview</p>
                                <h3>Merchant-owned root context</h3>
                            </div>
                            <div class="workspace-actions">
                                <span class="chip">Shop level</span>
                                <a class="button button--ghost button--compact" href="@GetShopSectionUrl("edit")">Edit shop</a>
                            </div>
                        </div>
                        <dl class="shop-profile-summary">
                            <div>
                                <dt>Coffee shop name</dt>
                                <dd>@_workspace.Merchant.DisplayName</dd>
                            </div>
                            <div>
                                <dt>Owner email</dt>
                                <dd>@_workspace.Merchant.ContactEmail</dd>
                            </div>
                            <div>
                                <dt>Location</dt>
                                <dd>@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</dd>
                            </div>
                            <div>
                                <dt>Current brand colours</dt>
                                <dd>@_shopForm.PrimaryColor / @_shopForm.AccentColor</dd>
                            </div>
                        </dl>
                        <p class="field-hint">Use Shop when you need to update the merchant identity or understand whole-shop performance. Use Programmes when you need to run loyalty day to day.</p>
                    </article>

                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Shop-level insights</p>
                                <h3>Across every programme</h3>
                            </div>
                            <a class="button button--ghost button--compact" href="@GetShopSectionUrl("insights")">Open shop insights</a>
                        </div>
                        <div class="metrics-grid">
                            <article class="metric-card">
                                <span class="metric-card__label">Programmes</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.ProgrammesCount</strong>
                                <p class="metric-card__copy">Active and scheduled programmes owned by this shop.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Customers</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.ActiveCards</strong>
                                <p class="metric-card__copy">Customer passes currently enrolled across every programme.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Unlocked</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.RewardsUnlocked</strong>
                                <p class="metric-card__copy">Rewards currently available to redeem across the whole shop.</p>
                            </article>
                        </div>
                    </article>
                </section>

                <section class="workspace-detail-grid">
                    <article class="panel workspace-preview-panel @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Shop brand</p>
                                <h3>Inherited by every programme by default</h3>
                            </div>
                            <span class="chip chip--accent">Source of truth</span>
                        </div>
                        <div class="workspace-preview-card">
                            <div class="brand-lockup brand-lockup--merchant">
                                <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                            </div>
                            <div>
                                <p class="field-hint">The shop brand drives the workspace feel and the default wallet-card appearance. Programmes inherit it unless card-level overrides are introduced later.</p>
                                <p class="workspace-preview-copy">@_shopForm.DisplayName</p>
                                <p class="field-hint">Selected programme example: @selectedProgrammeSummary.RewardHeadline</p>
                            </div>
                        </div>
                    </article>

                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Programmes in this shop</p>
                                <h3>Pick a programme to run daily loyalty</h3>
                            </div>
                            <a class="button button--ghost button--compact" href="@GetPrimaryTabUrl("programmes")">Open programmes</a>
                        </div>
                        <div class="programme-list">
                            @foreach (var programme in _workspace.Programmes)
                            {
                                <a class="programme-list__item @(programme.ProgrammeId == _workspace.SelectedProgramme.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                                   href="@GetProgrammeUrl(programme.ProgrammeId, "operate")">
                                    <div>
                                        <p class="eyebrow">Loyalty programme</p>
                                        <h4>@programme.RewardHeadline</h4>
                                        <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                    </div>
                                    <div class="programme-list__meta">
                                        <span class="chip">@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                        <span>@programme.ActiveCards customers</span>
                                        <span>@programme.RewardsUnlocked unlocked</span>
                                    </div>
                                </a>
                            }
                        </div>
                    </article>
                </section>
            }
            else if (IsShopSection("edit"))
            {
                <section class="workspace-detail-grid">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Edit shop</p>
                                <h3>Change profile and brand</h3>
                            </div>
                            <span class="chip">Shop level</span>
                        </div>

                        <EditForm Model="_shopForm" OnValidSubmit="HandleShopSaveAsync" FormName="update-shop" class="form-stack">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="validation-summary" />

                            <div class="form-grid">
                                <label class="field">
                                    <span>Coffee shop name</span>
                                    <InputText @bind-Value="_shopForm.DisplayName" class="input" />
                                </label>

                                <label class="field">
                                    <span>Owner email</span>
                                    <InputText @bind-Value="_shopForm.ContactEmail" class="input" />
                                </label>

                                <label class="field">
                                    <span>Town or city</span>
                                    <InputText @bind-Value="_shopForm.TownOrCity" class="input" />
                                </label>

                                <label class="field">
                                    <span>Postcode</span>
                                    <InputText @bind-Value="_shopForm.Postcode" class="input" />
                                </label>

                                <label class="field">
                                    <span>Site primary colour</span>
                                    <InputText @bind-Value="_shopForm.PrimaryColor" class="input" />
                                </label>

                                <label class="field">
                                    <span>Site accent colour</span>
                                    <InputText @bind-Value="_shopForm.AccentColor" class="input" />
                                </label>

                                <div class="field field--full">
                                    <span>Replace logo</span>
                                    <label class="upload-control">
                                        <InputFile OnChange="HandleBrandLogoSelectedAsync" accept=".png" />
                                        <span>Upload a PNG logo. We will suggest colours from it, but you can still override them manually.</span>
                                    </label>
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_shopMessage))
                            {
                                <p class="field-hint">@_shopMessage</p>
                            }

                            <div class="form-actions">
                                <button class="button button--primary" type="submit" disabled="@_isSavingShop">Save Shop</button>
                                <button class="button button--ghost" type="button" @onclick="ResetShopForm">Reset</button>
                            </div>
                        </EditForm>
                    </article>

                    <div class="workspace-stack">
                        <article class="panel workspace-preview-panel @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                            <div class="panel__header">
                                <div>
                                    <p class="eyebrow">Brand preview</p>
                                    <h3>How the shop presents itself</h3>
                                </div>
                                <span class="chip chip--accent">Inherited by default</span>
                            </div>
                            <div class="workspace-preview-card">
                                <div class="brand-lockup brand-lockup--merchant">
                                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                                </div>
                                <div>
                                    <p class="field-hint">Programmes and wallet cards inherit this look unless you later introduce card-specific overrides.</p>
                                    <p class="workspace-preview-copy">@_shopForm.DisplayName</p>
                                    <p class="field-hint">Selected programme example: @selectedProgrammeSummary.RewardHeadline</p>
                                </div>
                            </div>
                        </article>

                        <article class="panel">
                            <div class="panel__header">
                                <div>
                                    <p class="eyebrow">What changes here</p>
                                    <h3>Shop-level controls only</h3>
                                </div>
                            </div>
                            <div class="metrics-grid">
                                <article class="metric-card">
                                    <span class="metric-card__label">Brand</span>
                                    <strong class="metric-card__value">Shop identity</strong>
                                    <p class="metric-card__copy">Logo, colours, and merchant profile live here.</p>
                                </article>
                                <article class="metric-card">
                                    <span class="metric-card__label">Programmes</span>
                                    <strong class="metric-card__value">Inherited default</strong>
                                    <p class="metric-card__copy">Programmes reuse the shop brand until you opt into overrides later.</p>
                                </article>
                            </div>
                        </article>
                    </div>
                </section>
            }
            else
            {
                <section class="workspace-detail-grid">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Shop insights</p>
                                <h3>Across every programme in the shop</h3>
                            </div>
                            <span class="chip">Shop level</span>
                        </div>
                        <div class="metrics-grid">
                            <article class="metric-card">
                                <span class="metric-card__label">Programmes</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.ProgrammesCount</strong>
                                <p class="metric-card__copy">Programmes configured for this shop.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Customers</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.ActiveCards</strong>
                                <p class="metric-card__copy">Customer cards currently live across every programme.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Unlocked</span>
                                <strong class="metric-card__value">@_workspace.ShopInsights.RewardsUnlocked</strong>
                                <p class="metric-card__copy">Rewards available to redeem across the whole shop.</p>
                            </article>
                        </div>
                    </article>

                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Programme comparison</p>
                                <h3>How each programme is performing</h3>
                            </div>
                        </div>
                        <div class="programme-list">
                            @foreach (var programme in _workspace.Programmes)
                            {
                                <a class="programme-list__item @(programme.ProgrammeId == _workspace.SelectedProgramme.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                                   href="@GetProgrammeUrl(programme.ProgrammeId, "insights")">
                                    <div>
                                        <p class="eyebrow">Programme</p>
                                        <h4>@programme.RewardHeadline</h4>
                                        <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                    </div>
                                    <div class="programme-list__meta">
                                        <span>@programme.ActiveCards customers</span>
                                        <span>@programme.RewardsUnlocked unlocked</span>
                                        <span>@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                    </div>
                                </a>
                            }
                        </div>
                    </article>
                </section>
            }
        }
        else
        {
            <section class="workspace-detail-grid">
                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Programmes</p>
                            <h3>Select the programme you want to run</h3>
                        </div>
                        <button class="button button--secondary" type="button" @onclick="HandleCreateProgrammeAsync">Add Programme</button>
                    </div>
                    <p class="field-hint">A programme defines the reward rule, dates, customer join QR, and the wallet card behaviour customers keep in Apple Wallet.</p>
                    <div class="programme-list">
                        @foreach (var programme in _workspace.Programmes)
                        {
                            <a class="programme-list__item @(programme.ProgrammeId == _workspace.SelectedProgramme.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                               href="@GetProgrammeUrl(programme.ProgrammeId)">
                                <div>
                                    <p class="eyebrow">Programme</p>
                                    <h4>@programme.RewardHeadline</h4>
                                    <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                </div>
                                <div class="programme-list__meta">
                                    <span class="chip">@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                    <span>@programme.ActiveCards customers</span>
                                    <span>@programme.RewardsUnlocked unlocked</span>
                                </div>
                            </a>
                        }
                    </div>
                </article>

                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Selected programme</p>
                            <h3>@selectedProgrammeSummary.RewardHeadline</h3>
                        </div>
                        <div class="workspace-actions">
                            <span class="chip">@BuildProgrammeWindowBadge(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</span>
                            <span class="chip chip--accent">Wallet card inherits shop brand</span>
                        </div>
                    </div>
                    <p class="field-hint">Focus here when you need to run join QR, stamp visits, edit the reward rule, or inspect programme-specific performance.</p>
                    <div class="metrics-grid">
                        <article class="metric-card">
                            <span class="metric-card__label">Status</span>
                            <strong class="metric-card__value">@BuildProgrammeWindowBadge(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</strong>
                            <p class="metric-card__copy">@BuildProgrammeWindowMessage(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Customers</span>
                            <strong class="metric-card__value">@selectedProgrammeSummary.ActiveCards</strong>
                            <p class="metric-card__copy">Customer passes currently enrolled on this programme.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Unlocked</span>
                            <strong class="metric-card__value">@selectedProgrammeSummary.RewardsUnlocked</strong>
                            <p class="metric-card__copy">Rewards currently available to redeem on this programme.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Validity</span>
                            <strong class="metric-card__value">@selectedProgrammeSummary.StartsOn.ToString("dd MMM")</strong>
                            <p class="metric-card__copy">Runs until @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy").</p>
                        </article>
                    </div>
                </article>
            </section>

            <nav class="workspace-tabs workspace-tabs--sub" aria-label="Programme sections">
                <a class="workspace-tabs__item @(IsProgrammeSection("operate") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("operate")">Operate</a>
                <a class="workspace-tabs__item @(IsProgrammeSection("configure") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("configure")">Configure</a>
                <a class="workspace-tabs__item @(IsProgrammeSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("insights")">Insights</a>
            </nav>

            @if (IsProgrammeSection("operate"))
            {
                <section class="workspace-detail-grid">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Customer join</p>
                                <h3>@selectedProgrammeSummary.RewardHeadline</h3>
                            </div>
                            <span class="chip">Programme specific</span>
                        </div>
                        <div class="qr-panel">
                            <div class="qr-panel__graphic">
                                @((MarkupString)_joinQrSvg)
                            </div>
                            <div class="qr-panel__meta">
                                <p>Customers scan this QR for the selected programme, then keep progress in Apple Wallet.</p>
                                <p class="field-hint">Valid @selectedProgrammeSummary.StartsOn.ToString("dd MMM yyyy") to @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy")</p>
                                <code>@_workspace.SelectedJoinUrl</code>
                                @if (!SelectedProgrammeIsActive)
                                {
                                    <p class="field-hint">@BuildProgrammeWindowMessage(_workspace.SelectedProgramme.StartsOn, _workspace.SelectedProgramme.EndsOn)</p>
                                }
                                <div class="form-actions">
                                    @if (SelectedProgrammeIsActive)
                                    {
                                        <a class="button button--secondary" href="@_workspace.SelectedJoinUrl" target="_blank">Open Customer Join</a>
                                    }
                                    else
                                    {
                                        <button class="button button--secondary" type="button" disabled>Open Customer Join</button>
                                    }
                                </div>
                            </div>
                        </div>
                    </article>

                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Till-side stamping</p>
                                <h3>Daily use for this programme</h3>
                            </div>
                            <span class="chip">@_workspace.SelectedProgrammeCards.Count active cards</span>
                        </div>
                        <EditForm OnValidSubmit="HandleAwardVisitAsync" Model="this" FormName="award-visit" class="form-stack">
                            <label class="field">
                                <span>Customer pass code</span>
                                <InputText @bind-Value="_scanCode" class="input" placeholder="card-..." />
                            </label>
                            <div class="form-actions">
                                <button class="button button--primary" type="submit" disabled="@(!SelectedProgrammeIsActive || string.IsNullOrWhiteSpace(_scanCode))">Award visit</button>
                                <button class="button button--ghost" type="button" @onclick="ClearScan">Clear</button>
                            </div>
                        </EditForm>
                        @if (!SelectedProgrammeIsActive)
                        {
                            <p class="field-hint">@BuildProgrammeWindowMessage(_workspace.SelectedProgramme.StartsOn, _workspace.SelectedProgramme.EndsOn)</p>
                        }
                        @if (!string.IsNullOrWhiteSpace(_scanMessage))
                        {
                            <p class="field-hint">@_scanMessage</p>
                        }
                    </article>
                </section>

                @if (_workspace.SelectedProgrammeCards.Count == 0)
                {
                    <section class="empty-state">
                        <h4>No customer passes issued yet.</h4>
                        <p>Share the join QR for this selected programme first. Once someone joins, their pass and progress will appear here.</p>
                    </section>
                }
                else
                {
                    <section class="card-list">
                        @foreach (var card in _workspace.SelectedProgrammeCards)
                        {
                            <article class="card-row">
                                <div>
                                    <p class="eyebrow">Issued customer pass</p>
                                    <h4>@card.ProgressDisplayText</h4>
                                    <p class="field-hint">Valid @FormatDate(card.StartsOn) to @FormatDate(card.EndsOn)</p>
                                    <p class="field-hint">Pass code: <code>@card.CardCode</code></p>
                                </div>
                                <div class="card-row__meta">
                                    <span class="chip @(card.RewardState == RewardState.Unlocked ? "chip--success" : string.Empty)">@card.RewardState</span>
                                    <a class="button button--ghost" href="/wallet/card/@card.CardId" target="_blank">Open Preview</a>
                                    @if (WalletCapability.SupportsAppleWalletPass)
                                    {
                                        <a class="button button--ghost" href="/wallet/passes/@(card.CardId).pkpass" target="_blank">Download Wallet Pass</a>
                                    }
                                    <button class="button button--secondary" type="button" @onclick="@(() => UseScanCode(card.CardCode))">Load Pass Code</button>
                                    <button class="button button--secondary" type="button" disabled="@(card.RewardState != RewardState.Unlocked)" @onclick="@(() => HandleRedeemAsync(card.CardId))">Mark Reward Redeemed</button>
                                </div>
                            </article>
                        }
                    </section>
                }

                <section class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Recent activity</p>
                            <h3>Selected programme timeline</h3>
                        </div>
                    </div>
                    <div class="timeline">
                        @foreach (var entry in _workspace.Timeline)
                        {
                            <article class="timeline__entry">
                                <div class="timeline__dot"></div>
                                <div>
                                    <p class="timeline__event">@entry.EventType</p>
                                    <p>@entry.Summary</p>
                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                </div>
                            </article>
                        }
                    </div>
                </section>
            }
            else if (IsProgrammeSection("configure"))
            {
                <section class="workspace-detail-grid workspace-detail-grid--card-editor">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Programme configuration</p>
                                <h3>Define the reward rule and wallet output</h3>
                            </div>
                            <span class="chip">@BuildProgrammeWindowBadge(_workspace.SelectedProgramme.StartsOn, _workspace.SelectedProgramme.EndsOn)</span>
                        </div>
                        <EditForm Model="_cardForm" OnValidSubmit="HandleCardSaveAsync" FormName="update-card-template" class="form-stack">
                            <DataAnnotationsValidator />
                            <ValidationSummary class="validation-summary" />

                            <div class="form-grid">
                                <label class="field">
                                    <span>Reward item</span>
                                    <InputText @bind-Value="_cardForm.RewardItemLabel" class="input" />
                                </label>

                                <label class="field">
                                    <span>Visits before reward</span>
                                    <InputNumber @bind-Value="_cardForm.RewardThreshold" class="input" />
                                </label>

                                <label class="field">
                                    <span>Begins on</span>
                                    <InputDate @bind-Value="_cardForm.StartsOn" class="input" />
                                </label>

                                <label class="field">
                                    <span>Expires on</span>
                                    <InputDate @bind-Value="_cardForm.EndsOn" class="input" />
                                </label>

                                <label class="field field--full">
                                    <span>Wallet card copy</span>
                                    <InputText @bind-Value="_cardForm.RewardCopy" class="input" />
                                </label>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(_cardMessage))
                            {
                                <p class="field-hint">@_cardMessage</p>
                            }

                            <p class="field-hint">The wallet card is the customer-facing output of this programme. Customers can only join and stamp visits between the begin and expiry dates.</p>

                            <div class="form-actions">
                                <button class="button button--primary" type="submit" disabled="@_isSavingCard">Save Programme</button>
                                <button class="button button--ghost" type="button" @onclick="ResetCardForm">Reset</button>
                            </div>
                        </EditForm>
                    </article>

                    <div class="workspace-stack">
                        <article class="wallet-pass @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                            <header class="wallet-pass__header">
                                <div>
                                    <p class="wallet-pass__label">Wallet card preview</p>
                                    <h2>@_shopForm.DisplayName</h2>
                                </div>
                                <div class="wallet-pass__mark">
                                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName wallet logo" />
                                </div>
                            </header>

                            <div class="wallet-pass__body">
                                <div>
                                    <p class="wallet-pass__copy">@_cardForm.RewardCopy</p>
                                    <p class="wallet-pass__progress">2/@_cardForm.RewardThreshold</p>
                                    <p class="field-hint">Valid @FormatDate(_cardForm.StartsOn) to @FormatDate(_cardForm.EndsOn)</p>
                                </div>
                                <div class="stamp-track" aria-label="wallet template preview">
                                    @for (var i = 0; i < _cardForm.RewardThreshold; i++)
                                    {
                                        <span class="stamp @(i < 2 ? "stamp--filled" : string.Empty)">@(@i + 1)</span>
                                    }
                                </div>
                                <p class="wallet-pass__status">This wallet card inherits the shop brand and the selected programme rule.</p>
                            </div>
                        </article>

                        <article class="panel">
                            <div class="panel__header">
                                <div>
                                    <p class="eyebrow">What changes here</p>
                                    <h3>Programme-level controls only</h3>
                                </div>
                            </div>
                            <div class="metrics-grid">
                                <article class="metric-card">
                                    <span class="metric-card__label">Rule</span>
                                    <strong class="metric-card__value">@selectedProgrammeSummary.RewardThreshold visits</strong>
                                    <p class="metric-card__copy">Reward threshold and copy belong to the programme.</p>
                                </article>
                                <article class="metric-card">
                                    <span class="metric-card__label">Validity</span>
                                    <strong class="metric-card__value">@BuildProgrammeWindowBadge(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</strong>
                                    <p class="metric-card__copy">@BuildProgrammeWindowMessage(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</p>
                                </article>
                            </div>
                        </article>
                    </div>
                </section>
            }
            else
            {
                <section class="workspace-detail-grid">
                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Programme insights</p>
                                <h3>@selectedProgrammeSummary.RewardHeadline</h3>
                            </div>
                            <span class="chip">Programme level</span>
                        </div>
                        <div class="metrics-grid">
                            <article class="metric-card">
                                <span class="metric-card__label">Customers</span>
                                <strong class="metric-card__value">@selectedProgrammeSummary.ActiveCards</strong>
                                <p class="metric-card__copy">Customer passes issued from this programme.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Unlocked</span>
                                <strong class="metric-card__value">@selectedProgrammeSummary.RewardsUnlocked</strong>
                                <p class="metric-card__copy">Rewards currently unlocked on this programme.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Join code</span>
                                <strong class="metric-card__value">@selectedProgrammeSummary.JoinCode</strong>
                                <p class="metric-card__copy">This join code belongs only to the selected programme.</p>
                            </article>
                            <article class="metric-card">
                                <span class="metric-card__label">Validity</span>
                                <strong class="metric-card__value">@BuildProgrammeWindowBadge(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</strong>
                                <p class="metric-card__copy">@BuildProgrammeWindowMessage(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</p>
                            </article>
                        </div>
                    </article>

                    <article class="panel">
                        <div class="panel__header">
                            <div>
                                <p class="eyebrow">Programme activity</p>
                                <h3>Recent events for the selected programme</h3>
                            </div>
                        </div>
                        <div class="timeline">
                            @foreach (var entry in _workspace.Timeline)
                            {
                                <article class="timeline__entry">
                                    <div class="timeline__dot"></div>
                                    <div>
                                        <p class="timeline__event">@entry.EventType</p>
                                        <p>@entry.Summary</p>
                                        <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                    </div>
                                </article>
                            }
                        </div>
                    </article>
                </section>
            }
        }
    </div>
}

@code {
    [Parameter]
    public Guid MerchantId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    [SupplyParameterFromQuery(Name = "programme")]
    public Guid? ProgrammeId { get; set; }

    private MerchantWorkspaceSnapshot? _workspace;
    private string _joinQrSvg = string.Empty;
    private string _scanCode = string.Empty;
    private string? _scanMessage;
    private string? _shopMessage;
    private string? _cardMessage;
    private bool _isSavingShop;
    private bool _isSavingCard;
    private bool _isSetupRoadmapCollapsed;
    private bool _isSetupRoadmapDismissed;
    private bool _didInitializeRoadmapState;
    private readonly ShopForm _shopForm = new();
    private readonly CardTemplateForm _cardForm = new();
    private byte[]? _pendingLogoUploadBytes;
    private string? _pendingLogoPreviewUri;
    private string _pendingLogoFileName = "logo.png";
    private MerchantLogoMetadata _pendingLogoMetadata = new(160, 160);

    private WalletPassCapability WalletCapability => WalletPasses.GetCapability();
    private ProgrammeSummarySnapshot SelectedProgrammeSummary =>
        _workspace!.Programmes.First(x => x.ProgrammeId == _workspace.SelectedProgramme.ProgrammeId);
    private bool SelectedProgrammeIsActive =>
        _workspace is not null && IsProgrammeActiveOn(_workspace.SelectedProgramme.StartsOn, _workspace.SelectedProgramme.EndsOn);

    protected override void OnInitialized()
    {
        PlatformState.Changed += HandleStateChanged;
    }

    protected override void OnParametersSet()
    {
        LoadWorkspace(refreshForms: true);
    }

    private void LoadWorkspace(bool refreshForms)
    {
        _workspace = PlatformState.GetMerchantWorkspace(MerchantId, Navigation.BaseUri, ProgrammeId);
        _joinQrSvg = _workspace is null ? string.Empty : QrCodes.RenderSvg(_workspace.SelectedJoinUrl);

        if (_workspace is null)
        {
            return;
        }

        if (!_didInitializeRoadmapState)
        {
            _isSetupRoadmapCollapsed = _workspace.SetupChecklist.JoinReady;
            _didInitializeRoadmapState = true;
        }

        if (!refreshForms)
        {
            return;
        }

        _shopForm.DisplayName = _workspace.Merchant.DisplayName;
        _shopForm.TownOrCity = _workspace.Merchant.TownOrCity;
        _shopForm.Postcode = _workspace.Merchant.Postcode;
        _shopForm.ContactEmail = _workspace.Merchant.ContactEmail;
        _shopForm.PrimaryColor = _workspace.BrandProfile.PrimaryColor;
        _shopForm.AccentColor = _workspace.BrandProfile.AccentColor;

        _cardForm.RewardItemLabel = _workspace.SelectedProgramme.RewardItemLabel;
        _cardForm.RewardThreshold = _workspace.SelectedProgramme.RewardThreshold;
        _cardForm.RewardCopy = _workspace.SelectedProgramme.RewardCopy;
        _cardForm.StartsOn = _workspace.SelectedProgramme.StartsOn;
        _cardForm.EndsOn = _workspace.SelectedProgramme.EndsOn;

        _pendingLogoUploadBytes = null;
        _pendingLogoPreviewUri = null;
        _pendingLogoFileName = "logo.png";
        _pendingLogoMetadata = new MerchantLogoMetadata(_workspace.BrandProfile.LogoWidth, _workspace.BrandProfile.LogoHeight);
    }

    private MerchantThemeView BuildBrandPreviewTheme() =>
        BrandPresentation.BuildPreview(
            NormalizeColor(_shopForm.PrimaryColor),
            NormalizeColor(_shopForm.AccentColor),
            _pendingLogoMetadata.Width,
            _pendingLogoMetadata.Height);

    private bool IsPrimaryTab(string tab) => string.Equals(GetActivePrimaryTab(), tab, StringComparison.OrdinalIgnoreCase);

    private bool IsShopSection(string section) =>
        IsPrimaryTab("shop") && string.Equals(GetActiveSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsProgrammeSection(string section) =>
        IsPrimaryTab("programmes") && string.Equals(GetActiveSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsSetupStepActive(SetupStepView step) =>
        IsPrimaryTab(step.PrimaryTab) && string.Equals(GetActiveSection(), step.Section, StringComparison.OrdinalIgnoreCase);

    private string GetActivePrimaryTab()
    {
        var normalizedTab = Tab?.Trim().ToLowerInvariant();
        if (string.IsNullOrWhiteSpace(normalizedTab))
        {
            var normalizedSection = Section?.Trim().ToLowerInvariant();
            return normalizedSection switch
            {
                "edit" or "overview" => "shop",
                "operate" or "configure" => "programmes",
                _ => _workspace is not null && _workspace.SetupChecklist.HasAnyProgramme ? "programmes" : "shop"
            };
        }

        return normalizedTab switch
        {
            "shop" => "shop",
            "brand" => "shop",
            "programmes" => "programmes",
            "programme" => "programmes",
            "cards" => "programmes",
            "card" => "programmes",
            "customers" => "programmes",
            "insights" => ProgrammeId.HasValue ? "programmes" : "shop",
            _ => _workspace is not null && _workspace.SetupChecklist.HasAnyProgramme ? "programmes" : "shop"
        };
    }

    private string GetActiveSection() =>
        GetActivePrimaryTab() == "shop"
            ? NormalizeShopSection(Tab, Section)
            : NormalizeProgrammeSection(Tab, Section);

    private string GetPrimaryTabUrl(string primaryTab)
    {
        var section = primaryTab == GetActivePrimaryTab()
            ? GetActiveSection()
            : primaryTab == "shop" ? "overview" : "operate";

        return Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = primaryTab,
            ["section"] = section,
            ["programme"] = _workspace?.SelectedProgramme.ProgrammeId
        });
    }

    private string GetShopSectionUrl(string section) =>
        Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = "shop",
            ["section"] = section,
            ["programme"] = _workspace?.SelectedProgramme.ProgrammeId
        });

    private string GetProgrammeSectionUrl(string section, Guid? programmeId = null) =>
        Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = "programmes",
            ["section"] = section,
            ["programme"] = programmeId ?? _workspace?.SelectedProgramme.ProgrammeId
        });

    private string GetProgrammeUrl(Guid programmeId, string? section = null) =>
        GetProgrammeSectionUrl(section ?? (IsPrimaryTab("programmes") ? GetActiveSection() : "operate"), programmeId);

    private string GetSetupStepUrl(SetupStepView step) =>
        step.PrimaryTab == "shop"
            ? GetShopSectionUrl(step.Section)
            : GetProgrammeSectionUrl(step.Section);

    private static string NormalizeShopSection(string? legacyTab, string? section) => section?.Trim().ToLowerInvariant() switch
    {
        "overview" => "overview",
        "edit" => "edit",
        "insights" => "insights",
        _ => legacyTab?.Trim().ToLowerInvariant() switch
        {
            "brand" => "edit",
            "insights" => "insights",
            _ => "overview"
        }
    };

    private static string NormalizeProgrammeSection(string? legacyTab, string? section) => section?.Trim().ToLowerInvariant() switch
    {
        "operate" => "operate",
        "configure" => "configure",
        "insights" => "insights",
        _ => legacyTab?.Trim().ToLowerInvariant() switch
        {
            "cards" => "configure",
            "card" => "configure",
            "customers" => "operate",
            "programmes" => "operate",
            "programme" => "operate",
            "insights" => "insights",
            _ => "operate"
        }
    };

    private async Task HandleBrandLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!string.Equals(file.ContentType, "image/png", StringComparison.OrdinalIgnoreCase))
        {
            _pendingLogoUploadBytes = null;
            _pendingLogoPreviewUri = null;
            _pendingLogoMetadata = _workspace is null
                ? new MerchantLogoMetadata(160, 160)
                : new MerchantLogoMetadata(_workspace.BrandProfile.LogoWidth, _workspace.BrandProfile.LogoHeight);
            _shopMessage = "Please upload a PNG logo for the shop profile.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var buffer = new MemoryStream();
        await stream.CopyToAsync(buffer);

        _pendingLogoUploadBytes = buffer.ToArray();
        _pendingLogoMetadata = MerchantBrandAssetInspector.ReadLogoMetadata(_pendingLogoUploadBytes);
        _pendingLogoFileName = file.Name;
        _pendingLogoPreviewUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(_pendingLogoUploadBytes)}";
        await SuggestPaletteFromLogoAsync(_pendingLogoPreviewUri);
        _shopMessage = $"{file.Name} loaded. Suggested site colours have been updated from the logo.";
    }

    private async Task HandleShopSaveAsync()
    {
        if (_workspace is null)
        {
            return;
        }

        _isSavingShop = true;

        try
        {
            var updated = await PlatformState.UpdateMerchantBrandAsync(
                MerchantId,
                _shopForm.DisplayName,
                _shopForm.TownOrCity,
                _shopForm.Postcode,
                _shopForm.ContactEmail,
                _shopForm.PrimaryColor,
                _shopForm.AccentColor,
                _pendingLogoUploadBytes is null ? null : new MerchantLogoUpload(_pendingLogoUploadBytes, "image/png", _pendingLogoFileName),
                _workspace.SelectedProgramme.ProgrammeId,
                Navigation.BaseUri);

            if (updated is not null)
            {
                _shopMessage = "Shop updated.";
                LoadWorkspace(refreshForms: true);
            }
        }
        catch (InvalidOperationException ex)
        {
            _shopMessage = ex.Message;
        }
        finally
        {
            _isSavingShop = false;
        }
    }

    private void ResetShopForm()
    {
        _shopMessage = null;
        LoadWorkspace(refreshForms: true);
    }

    private Task HandleCreateProgrammeAsync()
    {
        var updated = PlatformState.CreateProgramme(MerchantId, Navigation.BaseUri);
        if (updated is not null)
        {
            Navigation.NavigateTo($"/portal/merchant/{MerchantId}?tab=programmes&section=configure&programme={updated.SelectedProgramme.ProgrammeId}");
        }

        return Task.CompletedTask;
    }

    private Task HandleCardSaveAsync()
    {
        if (_workspace is null)
        {
            return Task.CompletedTask;
        }

        _isSavingCard = true;

        try
        {
            var updated = PlatformState.UpdateProgramme(
                MerchantId,
                _workspace.SelectedProgramme.ProgrammeId,
                _cardForm.RewardItemLabel,
                _cardForm.RewardThreshold,
                _cardForm.RewardCopy,
                _cardForm.StartsOn,
                _cardForm.EndsOn,
                Navigation.BaseUri);

            if (updated is not null)
            {
                _cardMessage = "Programme updated.";
                LoadWorkspace(refreshForms: true);
            }
        }
        catch (InvalidOperationException ex)
        {
            _cardMessage = ex.Message;
        }
        finally
        {
            _isSavingCard = false;
        }

        return Task.CompletedTask;
    }

    private void ResetCardForm()
    {
        _cardMessage = null;
        LoadWorkspace(refreshForms: true);
    }

    private Task HandleAwardVisitAsync()
    {
        if (_workspace is null)
        {
            return Task.CompletedTask;
        }

        var updated = PlatformState.AwardVisit(MerchantId, _workspace.SelectedProgramme.ProgrammeId, _scanCode, Navigation.BaseUri);
        _scanMessage = updated is null
            ? "That pass code does not belong to this programme, or the programme is outside its active dates."
            : $"Visit stamped. The customer pass now shows {updated.SelectedProgrammeCards.First(x => x.CardCode == _scanCode.Trim()).ProgressDisplayText}.";

        _scanCode = string.Empty;
        LoadWorkspace(refreshForms: false);
        return Task.CompletedTask;
    }

    private Task HandleRedeemAsync(Guid cardId)
    {
        if (_workspace is null)
        {
            return Task.CompletedTask;
        }

        var updated = PlatformState.RedeemReward(MerchantId, _workspace.SelectedProgramme.ProgrammeId, cardId, Navigation.BaseUri);
        _scanMessage = updated is null ? "The reward could not be marked as redeemed." : "Reward redeemed and the customer pass has reset for the next cycle.";
        LoadWorkspace(refreshForms: false);
        return Task.CompletedTask;
    }

    private void UseScanCode(string cardCode)
    {
        _scanCode = cardCode;
        _scanMessage = "The customer pass code has been loaded into the scanner field.";
    }

    private void ClearScan()
    {
        _scanCode = string.Empty;
        _scanMessage = null;
    }

    private async Task SuggestPaletteFromLogoAsync(string logoPreviewUri)
    {
        try
        {
            var palette = await JS.InvokeAsync<string[]>("ficBranding.extractPaletteFromDataUrl", logoPreviewUri);
            if (palette.Length >= 2)
            {
                _shopForm.PrimaryColor = NormalizeColor(palette[0]);
                _shopForm.AccentColor = NormalizeColor(palette[1]);
            }
        }
        catch (JSException)
        {
            // Keep manual colours if local JS palette extraction is unavailable.
        }
    }

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private static string FormatDate(DateOnly date) => date.ToString("dd MMM yyyy");

    private IReadOnlyList<SetupStepView> BuildSetupSteps()
    {
        if (_workspace is null)
        {
            return [];
        }

        return
        [
            new SetupStepView(1, "Shop details", "shop", "edit", _workspace.SetupChecklist.ShopDetailsComplete, _workspace.SetupChecklist.ShopDetailsComplete ? "Complete" : "Add details"),
            new SetupStepView(2, "Branding", "shop", "edit", _workspace.SetupChecklist.BrandComplete, _workspace.SetupChecklist.BrandComplete ? "Complete" : "Upload logo"),
            new SetupStepView(3, "Programme", "programmes", "configure", _workspace.SetupChecklist.HasAnyProgramme, _workspace.SetupChecklist.HasAnyProgramme ? "Complete" : "Create first programme"),
            new SetupStepView(4, "Customer join", "programmes", "operate", _workspace.SetupChecklist.JoinReady, _workspace.SetupChecklist.JoinReady ? "Ready" : "Publish join QR")
        ];
    }

    private static string BuildSetupRoadmapHeadline(int completed, int total) =>
        completed == total ? "Your shop is ready." : $"{completed} of {total} setup steps complete";

    private static string BuildSetupRoadmapMessage(IReadOnlyList<SetupStepView> steps)
    {
        var nextStep = steps.FirstOrDefault(step => !step.IsComplete);
        return nextStep is null
            ? "Setup is complete. Use Programmes to run join, stamping, and loyalty insights."
            : $"Next best step: {nextStep.Label}.";
    }

    private void ToggleSetupRoadmap() => _isSetupRoadmapCollapsed = !_isSetupRoadmapCollapsed;

    private void DismissSetupRoadmap() => _isSetupRoadmapDismissed = true;

    private static bool IsProgrammeActiveOn(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        return today >= startsOn && today <= endsOn;
    }

    private static string BuildProgrammeWindowBadge(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return "Scheduled";
        }

        return today > endsOn ? "Expired" : "Active";
    }

    private static string BuildProgrammeWindowMessage(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return $"This programme opens on {FormatDate(startsOn)}.";
        }

        if (today > endsOn)
        {
            return $"This programme expired on {FormatDate(endsOn)}.";
        }

        return $"This programme is live until {FormatDate(endsOn)}.";
    }

    private void HandleStateChanged() =>
        _ = InvokeAsync(() =>
        {
            LoadWorkspace(refreshForms: false);
            StateHasChanged();
        });

    public void Dispose()
    {
        PlatformState.Changed -= HandleStateChanged;
    }

    private sealed class ShopForm
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = string.Empty;

        [Required, StringLength(60)]
        public string TownOrCity { get; set; } = string.Empty;

        [Required, StringLength(12)]
        public string Postcode { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = string.Empty;

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string PrimaryColor { get; set; } = "#1f3731";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string AccentColor { get; set; } = "#f4c15d";
    }

    private sealed class CardTemplateForm : IValidatableObject
    {
        [Required, StringLength(40)]
        public string RewardItemLabel { get; set; } = "coffees";

        [Range(2, 20)]
        public int RewardThreshold { get; set; } = 5;

        [Required, StringLength(120)]
        public string RewardCopy { get; set; } = string.Empty;

        [Required]
        public DateOnly StartsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        [Required]
        public DateOnly EndsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddYears(1));

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (EndsOn < StartsOn)
            {
                yield return new ValidationResult(
                    "Expiry date must be on or after the begin date.",
                    [nameof(EndsOn)]);
            }
        }
    }

    private sealed record SetupStepView(
        int Order,
        string Label,
        string PrimaryTab,
        string Section,
        bool IsComplete,
        string StatusLabel);
}

@page "/portal/merchant/{MerchantId:guid}"
@implements IDisposable
@using System.ComponentModel.DataAnnotations
@using Fic.Contracts
@using Fic.MerchantAccounts
@inject DemoPlatformState PlatformState
@inject JoinQrCodeService QrCodes
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IAppleWalletPassService WalletPasses
@inject MerchantBrandPresentationService BrandPresentation

<PageTitle>Your Shop</PageTitle>

@if (_workspace is null)
{
    <section class="empty-state">
        <h2>Shop area not found.</h2>
        <p>The merchant account may not exist in the current demo instance.</p>
        <a class="button button--primary" href="/">Back to FIC Home</a>
    </section>
}
else
{
    var workspaceTheme = BrandPresentation.Build(_workspace.BrandProfile);
    var brandPreviewTheme = BuildBrandPreviewTheme();
    var selectedProgrammeSummary = SelectedProgrammeSummary;
    var selectedProgramme = _workspace.SelectedProgramme;
    var hasProgrammes = _workspace.Programmes.Count > 0;
    var hasSelectedProgramme = selectedProgramme is not null && selectedProgrammeSummary is not null;
    var selectedProgrammeBadge = hasSelectedProgramme
        ? BuildProgrammeWindowBadge(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)
        : string.Empty;
    var setupSteps = BuildSetupSteps();
    var completedSetupSteps = setupSteps.Count(x => x.IsComplete);
    var programmeGroups = BuildProgrammeGroups();
    var activeProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Active")?.Programmes.Count ?? 0;
    var scheduledProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Scheduled")?.Programmes.Count ?? 0;
    var expiredProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Expired")?.Programmes.Count ?? 0;
    var selectedProgrammeCards = _workspace.SelectedProgrammeCards;
    var customerCardGroups = BuildCustomerCardGroups(selectedProgrammeCards);
    var rewardReadyCardsCount = selectedProgrammeCards.Count(card => card.CustomerCardStatus == CustomerCardStatus.RewardReady);
    var redeemedCardsCount = selectedProgrammeCards.Count(card => card.CustomerCardStatus == CustomerCardStatus.Redeemed);
    var inactiveCardsCount = selectedProgrammeCards.Count(card =>
        card.CustomerCardStatus is CustomerCardStatus.Scheduled or CustomerCardStatus.Expired);

    <div class="workspace-stage @workspaceTheme.ThemeClass" style="@workspaceTheme.CssVariables">
        <section class="workspace-header">
            <div class="workspace-brand">
                <div class="brand-lockup brand-lockup--merchant">
                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo" />
                </div>
                <div class="workspace-brand__copy">
                    <p class="eyebrow">Your shop</p>
                    <h2>@_workspace.Merchant.DisplayName</h2>
                    <p class="field-hint">@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>
                    <p class="lede">Run the shop, manage loyalty programmes, and view customer activity from one merchant-owned area.</p>
                </div>
            </div>
            <div class="workspace-header__actions">
                @if (WalletCapability.SupportsAppleWalletPass)
                {
                    <span class="chip chip--success">Signed Apple Wallet ready</span>
                }
                else
                {
                    <span class="chip">Preview fallback</span>
                    <a class="button button--ghost button--compact" href="/support/wallet-demo">Wallet demo setup</a>
                }
            </div>
        </section>

        <div class="workspace-tabs-bar">
            <nav class="workspace-tabs" aria-label="Shop sections">
                <a class="workspace-tabs__item @(IsWorkspaceSection("overview") ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("overview")">Overview</a>
                <a class="workspace-tabs__item @(IsWorkspaceSection("programmes") ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("programmes")">Programmes</a>
                <a class="workspace-tabs__item @(IsWorkspaceSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("insights")">Insights</a>
            </nav>
            @if (!IsShopSettingsOpen())
            {
                <a class="button button--ghost button--compact workspace-tabs-bar__action" href="@GetShopSettingsUrl()">Shop settings</a>
            }
        </div>

        @if (IsWorkspaceSection("overview"))
        {
            @if (!_isSetupRoadmapDismissed)
            {
                <section class="panel setup-roadmap @(_isSetupRoadmapCollapsed ? "setup-roadmap--collapsed" : string.Empty)">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Onboarding roadmap</p>
                            <h3>@BuildSetupRoadmapHeadline(completedSetupSteps, setupSteps.Count)</h3>
                        </div>
                        <div class="workspace-actions">
                            <span class="chip chip--accent">@completedSetupSteps/@setupSteps.Count complete</span>
                            <button class="button button--ghost button--compact" type="button" @onclick="ToggleSetupRoadmap">
                                @(_isSetupRoadmapCollapsed ? "Show setup" : "Hide setup")
                            </button>
                            <button class="button button--ghost button--compact" type="button" @onclick="DismissSetupRoadmap">Dismiss</button>
                        </div>
                    </div>

                    @if (!_isSetupRoadmapCollapsed)
                    {
                        <p class="field-hint">@BuildSetupRoadmapMessage(setupSteps)</p>
                        <div class="setup-roadmap__steps">
                            @foreach (var step in setupSteps)
                            {
                                <a class="setup-roadmap__step @(step.IsComplete ? "setup-roadmap__step--complete" : string.Empty) @(IsSetupStepActive(step) ? "setup-roadmap__step--current" : string.Empty)"
                                   href="@GetSetupStepUrl(step)">
                                    <span class="setup-roadmap__step-index">@step.Order</span>
                                    <span class="setup-roadmap__step-copy">
                                        <strong>@step.Label</strong>
                                        <span>@step.StatusLabel</span>
                                    </span>
                                </a>
                            }
                        </div>
                    }
                </section>
            }

            <section class="workspace-detail-grid">
                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop overview</p>
                            <h3>Shop at a glance</h3>
                        </div>
                    </div>
                    <div class="workspace-preview-card">
                        <div class="brand-lockup brand-lockup--merchant">
                            <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                        </div>
                        <div>
                            <p class="workspace-preview-copy">@_workspace.Merchant.DisplayName</p>
                            <p class="field-hint">@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>
                            <p class="field-hint">Brand defaults, merchant details, and whole-shop insight live here.</p>
                        </div>
                    </div>
                    <dl class="shop-profile-summary">
                        <div>
                            <dt>Owner email</dt>
                            <dd>@_workspace.Merchant.ContactEmail</dd>
                        </div>
                        <div>
                            <dt>Location</dt>
                            <dd>@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</dd>
                        </div>
                        <div>
                            <dt>Brand default</dt>
                            <dd>Inherited by all programmes</dd>
                        </div>
                        <div>
                            <dt>Setup status</dt>
                            <dd>@BuildSetupRoadmapHeadline(completedSetupSteps, setupSteps.Count)</dd>
                        </div>
                    </dl>
                </article>

                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Programmes in this shop</p>
                            <h3>Where loyalty actually runs</h3>
                        </div>
                        <a class="button button--ghost button--compact" href="@GetProgrammeSectionUrl("operate")">Open programmes</a>
                    </div>
                    <div class="workspace-overview-strip workspace-summary-grid">
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Active</span>
                            <strong class="workspace-overview-card__value">@activeProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Currently open to join, stamp, and redeem.</p>
                        </article>
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Scheduled</span>
                            <strong class="workspace-overview-card__value">@scheduledProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Configured and waiting for their begin date.</p>
                        </article>
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Expired</span>
                            <strong class="workspace-overview-card__value">@expiredProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Past programmes retained for reference and insight.</p>
                        </article>
                    </div>
                    <p class="field-hint">@(selectedProgrammeSummary is null ? "Create the first programme to open customer join, Wallet delivery, and daily operations." : $"Current programme focus: {selectedProgrammeSummary.RewardHeadline}. Customer join, stamping, dates, and delivery all live inside the programme workspace.")</p>
                </article>
            </section>
        }
        else if (IsWorkspaceSection("insights"))
        {
            <section class="workspace-detail-grid">
                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop insights</p>
                            <h3>Across every programme in the shop</h3>
                        </div>
                        <span class="chip">Shop level</span>
                    </div>
                    <div class="metrics-grid">
                        <article class="metric-card">
                            <span class="metric-card__label">Programmes</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.ProgrammesCount</strong>
                            <p class="metric-card__copy">Programmes configured for this shop.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Customers</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.ActiveCards</strong>
                            <p class="metric-card__copy">Customer cards currently live across every programme.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Unlocked</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.RewardsUnlocked</strong>
                            <p class="metric-card__copy">Rewards available to redeem across the whole shop.</p>
                        </article>
                    </div>
                </article>

                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Programme comparison</p>
                            <h3>How each programme is performing</h3>
                        </div>
                    </div>
                    <div class="programme-list">
                        @foreach (var programme in _workspace.Programmes)
                        {
                            <a class="programme-list__item @(programme.ProgrammeId == selectedProgramme?.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                               href="@GetProgrammeUrl(programme.ProgrammeId, "insights")">
                                <div>
                                    <p class="eyebrow">Programme</p>
                                    <h4>@programme.RewardHeadline</h4>
                                    <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                </div>
                                <div class="programme-list__meta">
                                    <span>@programme.ActiveCards customers</span>
                                    <span>@programme.RewardsUnlocked unlocked</span>
                                    <span>@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                </div>
                            </a>
                        }
                    </div>
                </article>
            </section>
        }
        else
        {
            <section class="workspace-detail-grid workspace-detail-grid--programme-shell">
                <aside class="programme-sidebar programme-rail">
                    <div class="programme-rail__header">
                        <div>
                            <p class="eyebrow">Programmes</p>
                            <h3>Programmes</h3>
                        </div>
                        <a class="button button--secondary" href="@GetProgrammeSectionUrl("create")">New programme</a>
                    </div>

                    <div class="programme-groups">
                        @if (programmeGroups.Count == 0)
                        {
                            <p class="field-hint">No programmes yet. Create the first one to launch customer join, Wallet delivery, and daily operations.</p>
                        }
                        else
                        {
                            @foreach (var group in programmeGroups)
                            {
                                <section class="programme-group">
                                    <div class="programme-group__header">
                                        <h4>@group.Label</h4>
                                        <span class="chip">@group.Programmes.Count</span>
                                    </div>
                                    <div class="programme-list">
                                        @foreach (var programme in group.Programmes)
                                        {
                                            <a class="programme-list__item @(programme.ProgrammeId == selectedProgramme?.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                                               href="@GetProgrammeUrl(programme.ProgrammeId)">
                                                <div>
                                                    <h4>@programme.RewardHeadline</h4>
                                                    <p class="field-hint">@programme.ProgrammeTypeLabel · @programme.TemplateLabel</p>
                                                    <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                                </div>
                                                <span class="chip">@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                            </a>
                                        }
                                    </div>
                                </section>
                            }
                        }
                    </div>
                </aside>

                <div class="workspace-stack workspace-stack--programme programme-workpane">
                    @if (!hasProgrammes || IsProgrammeSection("create"))
                    {
                        <section class="panel programme-setup-flow">
                            <div class="panel__header">
                                <div>
                                    <p class="eyebrow">@(hasProgrammes ? "New programme" : "Step 3 of 3")</p>
                                    <h3>@(hasProgrammes ? "Add another programme" : "Create your first programme")</h3>
                                    <p class="lede">Choose the programme template first. The current customer delivery output is then configured inside the programme workspace.</p>
                                </div>
                            </div>

                            <div class="template-grid">
                                @foreach (var template in ProgrammeTemplates)
                                {
                                    <article class="template-card">
                                        <div class="template-card__header">
                                            <div>
                                                <p class="eyebrow">@template.ProgrammeTypeLabel</p>
                                                <h4>@template.TemplateLabel</h4>
                                            </div>
                                            <span class="chip chip--accent">@template.DeliveryTypeLabel</span>
                                        </div>
                                        <p class="template-card__headline">@template.Headline</p>
                                        <p class="field-hint">@template.Description</p>
                                        <dl class="template-card__facts">
                                            <div>
                                                <dt>Programme type</dt>
                                                <dd>@template.ProgrammeTypeLabel</dd>
                                            </div>
                                            <div>
                                                <dt>Reward rule</dt>
                                                <dd>@template.RewardCopy</dd>
                                            </div>
                                            <div>
                                                <dt>Current delivery</dt>
                                                <dd>@template.DeliveryTypeLabel</dd>
                                            </div>
                                            <div>
                                                <dt>Current output</dt>
                                                <dd>@template.OutputLabel</dd>
                                            </div>
                                        </dl>
                                        <div class="form-actions">
                                            <button class="button button--primary" type="button" @onclick="@(() => HandleCreateProgrammeAsync(template.TemplateKey))">Use this template</button>
                                        </div>
                                    </article>
                                }
                            </div>
                        </section>
                    }
                    else
                    {
                        <section class="programme-context-bar">
                            <div class="programme-context-bar__title">
                                <p class="eyebrow">Current programme</p>
                                <h3>@selectedProgrammeSummary!.RewardHeadline</h3>
                                <p class="field-hint">Started from @selectedProgrammeSummary.TemplateLabel</p>
                            </div>
                            <div class="programme-context-bar__meta">
                                <span class="chip">@selectedProgrammeBadge</span>
                                <span>@selectedProgrammeSummary.StartsOn.ToString("dd MMM yyyy") - @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy")</span>
                                <span class="chip">@selectedProgrammeSummary.ProgrammeTypeLabel</span>
                                <span class="chip">@selectedProgrammeSummary.DeliveryTypeLabel</span>
                            </div>
                        </section>

                        <nav class="workspace-tabs workspace-tabs--sub workspace-tabs--programme" aria-label="Programme sections">
                            <a class="workspace-tabs__item @(IsProgrammeSection("operate") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("operate")">Operate</a>
                            <a class="workspace-tabs__item @(IsProgrammeSection("customers") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("customers")">Customers</a>
                            <a class="workspace-tabs__item @(IsProgrammeSection("configure") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("configure")">Configure</a>
                            <a class="workspace-tabs__item @(IsProgrammeSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("insights")">Insights</a>
                        </nav>

                        @if (IsProgrammeSection("operate"))
                        {
                            <section class="workspace-detail-grid">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Customer join</p>
                                            <h3>Customer join QR</h3>
                                        </div>
                                    </div>
                                    <div class="qr-panel">
                                        <div class="qr-panel__graphic">
                                            @((MarkupString)_joinQrSvg)
                                        </div>
                                        <div class="qr-panel__meta">
                                            <p>Customers scan this QR, join the programme, and receive the current output through @selectedProgrammeSummary.DeliveryTypeLabel.</p>
                                            <p class="field-hint">Valid @selectedProgrammeSummary.StartsOn.ToString("dd MMM yyyy") to @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy")</p>
                                            <code>@_workspace.SelectedJoinUrl</code>
                                            @if (!SelectedProgrammeIsActive)
                                            {
                                                <p class="field-hint">@BuildProgrammeWindowMessage(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)</p>
                                            }
                                            <div class="form-actions">
                                                @if (SelectedProgrammeIsActive)
                                                {
                                                    <a class="button button--secondary" href="@_workspace.SelectedJoinUrl" target="_blank">Open Customer Join</a>
                                                }
                                                else
                                                {
                                                    <button class="button button--secondary" type="button" disabled>Open Customer Join</button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </article>

                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Till-side stamping</p>
                                            <h3>Stamp visits</h3>
                                        </div>
                                    </div>
                                    <p class="field-hint">@_workspace.SelectedProgrammeCards.Count active cards on this programme.</p>
                                    <EditForm OnValidSubmit="HandleAwardVisitAsync" Model="this" FormName="award-visit" class="form-stack">
                                        <label class="field">
                                            <span>Customer pass code</span>
                                            <InputText @bind-Value="_scanCode" class="input" placeholder="card-..." />
                                        </label>
                                        <div class="form-actions">
                                            <button class="button button--primary" type="submit" disabled="@(!SelectedProgrammeIsActive || string.IsNullOrWhiteSpace(_scanCode))">Award visit</button>
                                            <button class="button button--ghost" type="button" @onclick="ClearScan">Clear</button>
                                        </div>
                                    </EditForm>
                                    @if (!SelectedProgrammeIsActive)
                                    {
                                        <p class="field-hint">@BuildProgrammeWindowMessage(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_scanMessage))
                                    {
                                        <p class="field-hint">@_scanMessage</p>
                                    }
                                </article>
                            </section>

                            <section class="workspace-detail-grid workspace-detail-grid--programme-operate-secondary">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Daily use</p>
                                            <h3>Quick programme picture</h3>
                                        </div>
                                    </div>
                                    <div class="workspace-overview-strip workspace-summary-grid">
                                        <article class="workspace-overview-card">
                                            <span class="workspace-overview-card__label">Issued</span>
                                            <strong class="workspace-overview-card__value">@selectedProgrammeCards.Count</strong>
                                            <p class="workspace-overview-card__copy">Customer passes currently issued on this programme.</p>
                                        </article>
                                        <article class="workspace-overview-card">
                                            <span class="workspace-overview-card__label">Reward ready</span>
                                            <strong class="workspace-overview-card__value">@rewardReadyCardsCount</strong>
                                            <p class="workspace-overview-card__copy">Ready to redeem right now.</p>
                                        </article>
                                        <article class="workspace-overview-card">
                                            <span class="workspace-overview-card__label">Redeemed</span>
                                            <strong class="workspace-overview-card__value">@redeemedCardsCount</strong>
                                            <p class="workspace-overview-card__copy">Most recently completed and reset.</p>
                                        </article>
                                        <article class="workspace-overview-card">
                                            <span class="workspace-overview-card__label">Inactive</span>
                                            <strong class="workspace-overview-card__value">@inactiveCardsCount</strong>
                                            <p class="workspace-overview-card__copy">Currently outside the programme’s active date window.</p>
                                        </article>
                                    </div>
                                    <div class="form-actions">
                                        <a class="button button--secondary" href="@GetProgrammeSectionUrl("customers")">Manage customer passes</a>
                                    </div>
                                </article>

                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Recent activity</p>
                                            <h3>Programme timeline</h3>
                                        </div>
                                    </div>
                                    <div class="timeline">
                                        @foreach (var entry in _workspace.Timeline)
                                        {
                                            <article class="timeline__entry">
                                                <div class="timeline__dot"></div>
                                                <div>
                                                    <p class="timeline__event">@entry.EventType</p>
                                                    <p>@entry.Summary</p>
                                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </article>
                            </section>
                        }
                        else if (IsProgrammeSection("customers"))
                        {
                            <section class="workspace-stack workspace-stack--programme-customers">
                                <section class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Customer pass management</p>
                                            <h3>Issued passes on this programme</h3>
                                        </div>
                                        <span class="chip">@selectedProgrammeCards.Count cards</span>
                                    </div>

                                    @if (selectedProgrammeCards.Count == 0)
                                    {
                                        <div class="empty-state empty-state--compact">
                                            <h4>No customer passes issued yet.</h4>
                                            <p>Share the join QR from Operate first. Once someone joins, their pass appears here with status and actions.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="customer-card-groups">
                                            @foreach (var group in customerCardGroups)
                                            {
                                                <section class="customer-card-group">
                                                    <div class="customer-card-group__header">
                                                        <h4>@group.Label</h4>
                                                        <span class="chip">@group.Cards.Count</span>
                                                    </div>
                                                    <div class="card-list">
                                                        @foreach (var card in group.Cards)
                                                        {
                                                            <article class="card-row">
                                                                <div>
                                                                    <p class="eyebrow">Issued customer pass</p>
                                                                    <h4>@card.ProgressDisplayText</h4>
                                                                    <p class="field-hint">Status: @card.CustomerCardStatusLabel</p>
                                                                    <p class="field-hint">Valid @FormatDate(card.StartsOn) to @FormatDate(card.EndsOn)</p>
                                                                    <p class="field-hint">Pass code: <code>@card.CardCode</code></p>
                                                                </div>
                                                                <div class="card-row__meta">
                                                                    <span class="chip @(card.CustomerCardStatus == CustomerCardStatus.RewardReady ? "chip--success" : string.Empty)">@card.CustomerCardStatusLabel</span>
                                                                    <a class="button button--ghost" href="/wallet/card/@card.CardId" target="_blank">Preview</a>
                                                                    @if (WalletCapability.SupportsAppleWalletPass)
                                                                    {
                                                                        <a class="button button--ghost" href="/wallet/passes/@(card.CardId).pkpass" target="_blank">Wallet Pass</a>
                                                                    }
                                                                    <button class="button button--secondary" type="button" @onclick="@(() => UseScanCode(card.CardCode))">Load Code</button>
                                                                    <button class="button button--secondary" type="button" disabled="@(!card.CanRedeem)" @onclick="@(() => HandleRedeemAsync(card.CardId))">Redeem</button>
                                                                </div>
                                                            </article>
                                                        }
                                                    </div>
                                                </section>
                                            }
                                        </div>
                                    }
                                </section>

                                <section class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Recent activity</p>
                                            <h3>Programme timeline</h3>
                                        </div>
                                    </div>
                                    <div class="timeline">
                                        @foreach (var entry in _workspace.Timeline)
                                        {
                                            <article class="timeline__entry">
                                                <div class="timeline__dot"></div>
                                                <div>
                                                    <p class="timeline__event">@entry.EventType</p>
                                                    <p>@entry.Summary</p>
                                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </section>
                            </section>
                        }
                        else if (IsProgrammeSection("configure"))
                        {
                            <section class="workspace-detail-grid workspace-detail-grid--programme-configure">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme configuration</p>
                                            <h3>Programme setup and current delivery</h3>
                                        </div>
                                    </div>
                                    <EditForm Model="_programmeForm" OnValidSubmit="HandleProgrammeSaveAsync" FormName="update-programme" class="form-stack">
                                        <DataAnnotationsValidator />
                                        <ValidationSummary class="validation-summary" />

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Programme model</h4>
                                                <p class="field-hint">Template, type, and current delivery for this programme.</p>
                                            </div>
                                            <dl class="template-card__facts programme-model-summary">
                                                <div>
                                                    <dt>Starter template</dt>
                                                    <dd>@selectedProgrammeSummary.TemplateLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Programme type</dt>
                                                    <dd>@selectedProgrammeSummary.ProgrammeTypeLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Delivery type</dt>
                                                    <dd>@selectedProgrammeSummary.DeliveryTypeLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Current output</dt>
                                                    <dd>@selectedProgrammeSummary.OutputLabel</dd>
                                                </div>
                                            </dl>
                                        </section>

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Rule and schedule</h4>
                                                <p class="field-hint">@selectedProgrammeSummary.ProgrammeTypeLabel</p>
                                            </div>
                                            <div class="form-grid">
                                                <label class="field">
                                                    <span>Reward item</span>
                                                    <InputText @bind-Value="_programmeForm.RewardItemLabel" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Visits before reward</span>
                                                    <InputNumber @bind-Value="_programmeForm.RewardThreshold" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Begins on</span>
                                                    <InputDate @bind-Value="_programmeForm.StartsOn" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Expires on</span>
                                                    <InputDate @bind-Value="_programmeForm.EndsOn" class="input" />
                                                </label>
                                            </div>
                                        </section>

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Customer delivery</h4>
                                                <p class="field-hint">@selectedProgrammeSummary.DeliveryTypeLabel</p>
                                            </div>
                                            <div class="delivery-options">
                                                <article class="delivery-option delivery-option--selected">
                                                    <div class="delivery-option__copy">
                                                        <strong>@selectedProgrammeSummary.OutputLabel</strong>
                                                        <span>Current live output for this programme.</span>
                                                    </div>
                                                    <span class="chip chip--accent">Current</span>
                                                </article>
                                            </div>
                                            <div class="form-grid">
                                                <label class="field field--full">
                                                    <span>Customer-facing copy</span>
                                                    <InputText @bind-Value="_programmeForm.RewardCopy" class="input" />
                                                </label>
                                            </div>
                                        </section>

                                        @if (!string.IsNullOrWhiteSpace(_programmeMessage))
                                        {
                                            <p class="field-hint">@_programmeMessage</p>
                                        }

                                        <div class="form-actions">
                                            <button class="button button--primary" type="submit" disabled="@_isSavingProgramme">Save Programme</button>
                                            <button class="button button--ghost" type="button" @onclick="ResetProgrammeForm">Reset</button>
                                        </div>
                                    </EditForm>
                                </article>

                                <article class="panel workspace-preview-panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Preview</p>
                                            <h3>@selectedProgrammeSummary.OutputLabel preview</h3>
                                        </div>
                                    </div>
                                    <div class="wallet-pass @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                                        <header class="wallet-pass__header">
                                            <div>
                                                <p class="wallet-pass__label">Current delivery</p>
                                                <h2>@_shopForm.DisplayName</h2>
                                            </div>
                                            <div class="wallet-pass__mark">
                                                <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName wallet logo" />
                                            </div>
                                        </header>

                                        <div class="wallet-pass__body">
                                            <div>
                                                <p class="wallet-pass__copy">@_programmeForm.RewardCopy</p>
                                                <p class="wallet-pass__progress">2/@_programmeForm.RewardThreshold</p>
                                                <p class="field-hint">Valid @FormatDate(_programmeForm.StartsOn) to @FormatDate(_programmeForm.EndsOn)</p>
                                            </div>
                                            <div class="stamp-track" aria-label="wallet template preview">
                                                @for (var i = 0; i < _programmeForm.RewardThreshold; i++)
                                                {
                                                    <span class="stamp @(i < 2 ? "stamp--filled" : string.Empty)">@(@i + 1)</span>
                                                }
                                            </div>
                                            <p class="wallet-pass__status">Uses the shop brand defaults for this programme.</p>
                                        </div>
                                    </div>
                                </article>
                            </section>
                        }
                        else
                        {
                            <section class="workspace-detail-grid">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme insights</p>
                                            <h3>@selectedProgrammeSummary.RewardHeadline</h3>
                                        </div>
                                        <span class="chip">Programme level</span>
                                    </div>
                                    <div class="metrics-grid">
                                        <article class="metric-card">
                                            <span class="metric-card__label">Customers</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.ActiveCards</strong>
                                            <p class="metric-card__copy">Customer passes issued from this programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Unlocked</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.RewardsUnlocked</strong>
                                            <p class="metric-card__copy">Rewards currently unlocked on this programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Join code</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.JoinCode</strong>
                                            <p class="metric-card__copy">This join code belongs only to the selected programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Validity</span>
                                            <strong class="metric-card__value">@selectedProgrammeBadge</strong>
                                            <p class="metric-card__copy">@BuildProgrammeWindowMessage(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</p>
                                        </article>
                                    </div>
                                </article>

                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme activity</p>
                                            <h3>Recent events for the selected programme</h3>
                                        </div>
                                    </div>
                                    <div class="timeline">
                                        @foreach (var entry in _workspace.Timeline)
                                        {
                                            <article class="timeline__entry">
                                                <div class="timeline__dot"></div>
                                                <div>
                                                    <p class="timeline__event">@entry.EventType</p>
                                                    <p>@entry.Summary</p>
                                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </article>
                            </section>
                        }
                    }
                </div>
            </section>
        }

        @if (IsShopSettingsOpen())
        {
            <div class="workspace-drawer-backdrop">
                <aside class="panel workspace-drawer" aria-label="Shop settings drawer">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop settings</p>
                            <h3>Change profile and brand defaults</h3>
                        </div>
                        <div class="workspace-actions">
                            <span class="chip">Shop level</span>
                            <a class="button button--ghost button--compact" href="@GetCloseShopSettingsUrl()">Close</a>
                        </div>
                    </div>

                    <p class="field-hint">These defaults apply across the shop. Programmes inherit them unless a customer delivery output introduces its own overrides later.</p>

                    <EditForm Model="_shopForm" OnValidSubmit="HandleShopSaveAsync" FormName="update-shop" class="form-stack">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <div class="form-grid">
                            <label class="field">
                                <span>Coffee shop name</span>
                                <InputText @bind-Value="_shopForm.DisplayName" class="input" />
                            </label>

                            <label class="field">
                                <span>Owner email</span>
                                <InputText @bind-Value="_shopForm.ContactEmail" class="input" />
                            </label>

                            <label class="field">
                                <span>Town or city</span>
                                <InputText @bind-Value="_shopForm.TownOrCity" class="input" />
                            </label>

                            <label class="field">
                                <span>Postcode</span>
                                <InputText @bind-Value="_shopForm.Postcode" class="input" />
                            </label>

                            <label class="field">
                                <span>Site primary colour</span>
                                <InputText @bind-Value="_shopForm.PrimaryColor" class="input" />
                            </label>

                            <label class="field">
                                <span>Site accent colour</span>
                                <InputText @bind-Value="_shopForm.AccentColor" class="input" />
                            </label>

                            <div class="field field--full">
                                <span>Replace logo</span>
                                <label class="upload-control">
                                    <InputFile OnChange="HandleBrandLogoSelectedAsync" accept=".png" />
                                    <span>Upload a PNG logo. We will suggest colours from it, but you can still override them manually.</span>
                                </label>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_shopMessage))
                        {
                            <p class="field-hint">@_shopMessage</p>
                        }

                        <section class="workspace-drawer__preview @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                            <div class="workspace-preview-card">
                                <div class="brand-lockup brand-lockup--merchant">
                                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                                </div>
                                <div>
                                    <p class="eyebrow">Shared brand preview</p>
                                    <p class="workspace-preview-copy">@_shopForm.DisplayName</p>
                                    <p class="field-hint">Example output: @(selectedProgrammeSummary?.RewardHeadline ?? "Create the first programme to preview customer delivery.")</p>
                                </div>
                            </div>
                        </section>

                        <div class="form-actions">
                            <button class="button button--primary" type="submit" disabled="@_isSavingShop">Save Shop</button>
                            <button class="button button--ghost" type="button" @onclick="ResetShopForm">Reset</button>
                        </div>
                    </EditForm>
                </aside>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid MerchantId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    [SupplyParameterFromQuery(Name = "programmeSection")]
    public string? ProgrammeSection { get; set; }

    [SupplyParameterFromQuery(Name = "programme")]
    public Guid? ProgrammeId { get; set; }

    [SupplyParameterFromQuery(Name = "settings")]
    public string? Settings { get; set; }

    private MerchantWorkspaceSnapshot? _workspace;
    private string _joinQrSvg = string.Empty;
    private string _scanCode = string.Empty;
    private string? _scanMessage;
    private string? _shopMessage;
    private string? _programmeMessage;
    private bool _isSavingShop;
    private bool _isSavingProgramme;
    private bool _isSetupRoadmapCollapsed;
    private bool _isSetupRoadmapDismissed;
    private bool _didInitializeRoadmapState;
    private readonly ShopForm _shopForm = new();
    private readonly ProgrammeConfigurationForm _programmeForm = new();
    private byte[]? _pendingLogoUploadBytes;
    private string? _pendingLogoPreviewUri;
    private string _pendingLogoFileName = "logo.png";
    private MerchantLogoMetadata _pendingLogoMetadata = new(160, 160);

    private WalletPassCapability WalletCapability => WalletPasses.GetCapability();
    private IReadOnlyList<ProgrammeTemplateOption> ProgrammeTemplates => PlatformState.GetProgrammeTemplates();
    private ProgrammeSummarySnapshot? SelectedProgrammeSummary
    {
        get
        {
            var selectedProgrammeId = _workspace?.SelectedProgramme?.ProgrammeId;
            return selectedProgrammeId is null
                ? null
                : _workspace!.Programmes.FirstOrDefault(x => x.ProgrammeId == selectedProgrammeId.Value);
        }
    }
    private bool SelectedProgrammeIsActive =>
        _workspace?.SelectedProgramme is { } selectedProgramme && IsProgrammeActiveOn(selectedProgramme.StartsOn, selectedProgramme.EndsOn);

    protected override void OnInitialized()
    {
        PlatformState.Changed += HandleStateChanged;
    }

    protected override void OnParametersSet()
    {
        LoadWorkspace(refreshForms: true);
    }

    private void LoadWorkspace(bool refreshForms)
    {
        _workspace = PlatformState.GetMerchantWorkspace(MerchantId, Navigation.BaseUri, ProgrammeId);
        _joinQrSvg = _workspace?.SelectedJoinUrl is { Length: > 0 } selectedJoinUrl
            ? QrCodes.RenderSvg(selectedJoinUrl)
            : string.Empty;

        if (_workspace is null)
        {
            return;
        }

        if (!_didInitializeRoadmapState)
        {
            _isSetupRoadmapCollapsed = _workspace.SetupChecklist.JoinReady;
            _didInitializeRoadmapState = true;
        }

        if (!refreshForms)
        {
            return;
        }

        _shopForm.DisplayName = _workspace.Merchant.DisplayName;
        _shopForm.TownOrCity = _workspace.Merchant.TownOrCity;
        _shopForm.Postcode = _workspace.Merchant.Postcode;
        _shopForm.ContactEmail = _workspace.Merchant.ContactEmail;
        _shopForm.PrimaryColor = _workspace.BrandProfile.PrimaryColor;
        _shopForm.AccentColor = _workspace.BrandProfile.AccentColor;

        if (_workspace.SelectedProgramme is { } selectedProgramme)
        {
            _programmeForm.RewardItemLabel = selectedProgramme.RewardItemLabel;
            _programmeForm.RewardThreshold = selectedProgramme.RewardThreshold;
            _programmeForm.RewardCopy = selectedProgramme.RewardCopy;
            _programmeForm.StartsOn = selectedProgramme.StartsOn;
            _programmeForm.EndsOn = selectedProgramme.EndsOn;
        }
        else
        {
            var defaultTemplate = ProgrammeTemplates.First();
            _programmeForm.RewardItemLabel = defaultTemplate.RewardItemLabel;
            _programmeForm.RewardThreshold = defaultTemplate.RewardThreshold;
            _programmeForm.RewardCopy = defaultTemplate.RewardCopy;
            _programmeForm.StartsOn = DateOnly.FromDateTime(DateTime.Today);
            _programmeForm.EndsOn = DateOnly.FromDateTime(DateTime.Today.AddYears(1));
        }

        _pendingLogoUploadBytes = null;
        _pendingLogoPreviewUri = null;
        _pendingLogoFileName = "logo.png";
        _pendingLogoMetadata = new MerchantLogoMetadata(_workspace.BrandProfile.LogoWidth, _workspace.BrandProfile.LogoHeight);
    }

    private MerchantThemeView BuildBrandPreviewTheme() =>
        BrandPresentation.BuildPreview(
            NormalizeColor(_shopForm.PrimaryColor),
            NormalizeColor(_shopForm.AccentColor),
            _pendingLogoMetadata.Width,
            _pendingLogoMetadata.Height);

    private bool IsWorkspaceSection(string section) =>
        string.Equals(GetActiveSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsProgrammeSection(string section) =>
        IsWorkspaceSection("programmes") && string.Equals(GetActiveProgrammeSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsShopSettingsOpen() =>
        string.Equals(Settings, "shop", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Section, "edit", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Tab, "brand", StringComparison.OrdinalIgnoreCase);

    private bool IsSetupStepActive(SetupStepView step) =>
        (string.Equals(step.Section, "edit", StringComparison.OrdinalIgnoreCase)
            ? IsShopSettingsOpen()
            : string.Equals(GetActiveSection(), step.Section, StringComparison.OrdinalIgnoreCase))
        && (step.Section != "programmes"
            || string.Equals(GetActiveProgrammeSection(), step.ProgrammeSection ?? "operate", StringComparison.OrdinalIgnoreCase));

    private string GetActiveSection() =>
        NormalizeWorkspaceSection(Tab, Section);

    private string GetActiveProgrammeSection() =>
        NormalizeProgrammeSection(Tab, Section, ProgrammeSection);

    private string GetWorkspaceSectionUrl(string section) =>
        GetWorkspaceUrl(
            section,
            section == "programmes" ? GetActiveProgrammeSection() : null,
            _workspace?.SelectedProgramme?.ProgrammeId,
            settings: null);

    private string GetShopSettingsUrl() =>
        GetWorkspaceUrl(
            GetActiveSection(),
            IsWorkspaceSection("programmes") ? GetActiveProgrammeSection() : null,
            _workspace?.SelectedProgramme?.ProgrammeId,
            settings: "shop");

    private string GetCloseShopSettingsUrl() =>
        GetWorkspaceUrl(
            GetActiveSection(),
            IsWorkspaceSection("programmes") ? GetActiveProgrammeSection() : null,
            _workspace?.SelectedProgramme?.ProgrammeId,
            settings: null);

    private string GetWorkspaceUrl(string section, string? programmeSection, Guid? programmeId, string? settings) =>
        Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = section == "programmes" ? "programmes" : "shop",
            ["section"] = section,
            ["programmeSection"] = section == "programmes" ? (programmeSection ?? (_workspace?.SetupChecklist.HasAnyProgramme == true ? "operate" : "create")) : null,
            ["programme"] = programmeId,
            ["settings"] = settings
        });

    private string GetProgrammeSectionUrl(string section, Guid? programmeId = null) =>
        GetWorkspaceUrl("programmes", section, programmeId ?? _workspace?.SelectedProgramme?.ProgrammeId, settings: null);

    private string GetProgrammeUrl(Guid programmeId, string? section = null) =>
        GetProgrammeSectionUrl(section ?? (IsWorkspaceSection("programmes") ? GetActiveProgrammeSection() : "operate"), programmeId);

    private string GetSetupStepUrl(SetupStepView step) =>
        step.Section == "programmes"
            ? GetProgrammeSectionUrl(step.ProgrammeSection ?? "operate")
            : GetShopSettingsUrl();

    private string NormalizeWorkspaceSection(string? legacyTab, string? section) => section?.Trim().ToLowerInvariant() switch
    {
        "overview" => "overview",
        "edit" => "overview",
        "insights" => "insights",
        "programmes" => "programmes",
        _ => legacyTab?.Trim().ToLowerInvariant() switch
        {
            "brand" => "overview",
            "programmes" => "programmes",
            "programme" => "programmes",
            "cards" => "programmes",
            "card" => "programmes",
            "customers" => "programmes",
            "shop" => "overview",
            "insights" => "insights",
            _ => _workspace is not null && _workspace.SetupChecklist.HasAnyProgramme ? "programmes" : "programmes"
        }
    };

    private string NormalizeProgrammeSection(string? legacyTab, string? section, string? programmeSection) => programmeSection?.Trim().ToLowerInvariant() switch
    {
        "create" => "create",
        "operate" => "operate",
        "customers" => "customers",
        "configure" => "configure",
        "insights" => "insights",
        _ => section?.Trim().ToLowerInvariant() switch
        {
            "create" => "create",
            "operate" => "operate",
            "customers" => "customers",
            "configure" => "configure",
            "insights" => "insights",
            _ => legacyTab?.Trim().ToLowerInvariant() switch
            {
                "cards" => "configure",
                "card" => "configure",
                "customers" => "customers",
                "programmes" => "operate",
                "programme" => "operate",
                "insights" => "insights",
                _ => _workspace?.SetupChecklist.HasAnyProgramme == true ? "operate" : "create"
            }
        }
    };

    private async Task HandleBrandLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!string.Equals(file.ContentType, "image/png", StringComparison.OrdinalIgnoreCase))
        {
            _pendingLogoUploadBytes = null;
            _pendingLogoPreviewUri = null;
            _pendingLogoMetadata = _workspace is null
                ? new MerchantLogoMetadata(160, 160)
                : new MerchantLogoMetadata(_workspace.BrandProfile.LogoWidth, _workspace.BrandProfile.LogoHeight);
            _shopMessage = "Please upload a PNG logo for the shop profile.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var buffer = new MemoryStream();
        await stream.CopyToAsync(buffer);

        _pendingLogoUploadBytes = buffer.ToArray();
        _pendingLogoMetadata = MerchantBrandAssetInspector.ReadLogoMetadata(_pendingLogoUploadBytes);
        _pendingLogoFileName = file.Name;
        _pendingLogoPreviewUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(_pendingLogoUploadBytes)}";
        await SuggestPaletteFromLogoAsync(_pendingLogoPreviewUri);
        _shopMessage = $"{file.Name} loaded. Suggested site colours have been updated from the logo.";
    }

    private async Task HandleShopSaveAsync()
    {
        if (_workspace is null)
        {
            return;
        }

        _isSavingShop = true;

        try
        {
            var updated = await PlatformState.UpdateMerchantBrandAsync(
                MerchantId,
                _shopForm.DisplayName,
                _shopForm.TownOrCity,
                _shopForm.Postcode,
                _shopForm.ContactEmail,
                _shopForm.PrimaryColor,
                _shopForm.AccentColor,
                _pendingLogoUploadBytes is null ? null : new MerchantLogoUpload(_pendingLogoUploadBytes, "image/png", _pendingLogoFileName),
                _workspace.SelectedProgramme?.ProgrammeId,
                Navigation.BaseUri);

            if (updated is not null)
            {
                _shopMessage = "Shop updated.";
                LoadWorkspace(refreshForms: true);
            }
        }
        catch (InvalidOperationException ex)
        {
            _shopMessage = ex.Message;
        }
        finally
        {
            _isSavingShop = false;
        }
    }

    private void ResetShopForm()
    {
        _shopMessage = null;
        LoadWorkspace(refreshForms: true);
    }

    private Task HandleCreateProgrammeAsync(string templateKey)
    {
        var updated = PlatformState.CreateProgramme(MerchantId, templateKey, Navigation.BaseUri);
        if (updated?.SelectedProgramme is not null)
        {
            Navigation.NavigateTo($"/portal/merchant/{MerchantId}?tab=programmes&section=programmes&programmeSection=configure&programme={updated.SelectedProgramme.ProgrammeId}");
        }

        return Task.CompletedTask;
    }

    private Task HandleProgrammeSaveAsync()
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return Task.CompletedTask;
        }

        _isSavingProgramme = true;

        try
        {
            var updated = PlatformState.UpdateProgramme(
                MerchantId,
                selectedProgramme.ProgrammeId,
                _programmeForm.RewardItemLabel,
                _programmeForm.RewardThreshold,
                _programmeForm.RewardCopy,
                _programmeForm.StartsOn,
                _programmeForm.EndsOn,
                Navigation.BaseUri);

            if (updated is not null)
            {
                _programmeMessage = "Programme updated.";
                LoadWorkspace(refreshForms: true);
            }
        }
        catch (InvalidOperationException ex)
        {
            _programmeMessage = ex.Message;
        }
        finally
        {
            _isSavingProgramme = false;
        }

        return Task.CompletedTask;
    }

    private void ResetProgrammeForm()
    {
        _programmeMessage = null;
        LoadWorkspace(refreshForms: true);
    }

    private Task HandleAwardVisitAsync()
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return Task.CompletedTask;
        }

        var updated = PlatformState.AwardVisit(MerchantId, selectedProgramme.ProgrammeId, _scanCode, Navigation.BaseUri);
        _scanMessage = updated is null
            ? "That pass code does not belong to this programme, or the programme is outside its active dates."
            : $"Visit stamped. The customer pass now shows {updated.SelectedProgrammeCards.First(x => x.CardCode == _scanCode.Trim()).ProgressDisplayText}.";

        _scanCode = string.Empty;
        LoadWorkspace(refreshForms: false);
        return Task.CompletedTask;
    }

    private Task HandleRedeemAsync(Guid cardId)
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return Task.CompletedTask;
        }

        var updated = PlatformState.RedeemReward(MerchantId, selectedProgramme.ProgrammeId, cardId, Navigation.BaseUri);
        _scanMessage = updated is null ? "The reward could not be marked as redeemed." : "Reward redeemed and the customer pass has reset for the next cycle.";
        LoadWorkspace(refreshForms: false);
        return Task.CompletedTask;
    }

    private void UseScanCode(string cardCode)
    {
        _scanCode = cardCode;
        _scanMessage = "The customer pass code has been loaded into the scanner field.";
    }

    private void ClearScan()
    {
        _scanCode = string.Empty;
        _scanMessage = null;
    }

    private async Task SuggestPaletteFromLogoAsync(string logoPreviewUri)
    {
        try
        {
            var palette = await JS.InvokeAsync<string[]>("ficBranding.extractPaletteFromDataUrl", logoPreviewUri);
            if (palette.Length >= 2)
            {
                _shopForm.PrimaryColor = NormalizeColor(palette[0]);
                _shopForm.AccentColor = NormalizeColor(palette[1]);
            }
        }
        catch (JSException)
        {
            // Keep manual colours if local JS palette extraction is unavailable.
        }
    }

    private static string NormalizeColor(string value) =>
        value.StartsWith('#') ? value : $"#{value}";

    private static string FormatDate(DateOnly date) => date.ToString("dd MMM yyyy");

    private IReadOnlyList<SetupStepView> BuildSetupSteps()
    {
        if (_workspace is null)
        {
            return [];
        }

        return
        [
            new SetupStepView(1, "Shop details", "edit", null, _workspace.SetupChecklist.ShopDetailsComplete, _workspace.SetupChecklist.ShopDetailsComplete ? "Complete" : "Add details"),
            new SetupStepView(2, "Branding", "edit", null, _workspace.SetupChecklist.BrandComplete, _workspace.SetupChecklist.BrandComplete ? "Complete" : "Upload logo"),
            new SetupStepView(3, "Programme", "programmes", "configure", _workspace.SetupChecklist.HasAnyProgramme, _workspace.SetupChecklist.HasAnyProgramme ? "Complete" : "Create first programme"),
            new SetupStepView(4, "Customer join", "programmes", "operate", _workspace.SetupChecklist.JoinReady, _workspace.SetupChecklist.JoinReady ? "Ready" : "Publish join QR")
        ];
    }

    private IReadOnlyList<ProgrammeGroupView> BuildProgrammeGroups()
    {
        if (_workspace is null)
        {
            return [];
        }

        static IReadOnlyList<ProgrammeSummarySnapshot> FilterByStatus(IEnumerable<ProgrammeSummarySnapshot> programmes, string status) =>
            programmes.Where(programme =>
                    string.Equals(
                        BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn),
                        status,
                        StringComparison.OrdinalIgnoreCase))
                .ToArray();

        var active = FilterByStatus(_workspace.Programmes, "Active");
        var scheduled = FilterByStatus(_workspace.Programmes, "Scheduled");
        var expired = FilterByStatus(_workspace.Programmes, "Expired");

        return new[]
        {
            new ProgrammeGroupView("Active", active),
            new ProgrammeGroupView("Scheduled", scheduled),
            new ProgrammeGroupView("Expired", expired)
        }
        .Where(group => group.Programmes.Count > 0)
        .ToArray();
    }

    private static IReadOnlyList<CustomerCardGroupView> BuildCustomerCardGroups(IReadOnlyList<WalletCardSnapshot> cards)
    {
        if (cards.Count == 0)
        {
            return [];
        }

        static IReadOnlyList<WalletCardSnapshot> FilterByStatus(IEnumerable<WalletCardSnapshot> source, CustomerCardStatus status) =>
            source.Where(card => card.CustomerCardStatus == status).ToArray();

        return new[]
        {
            new CustomerCardGroupView("Reward ready", FilterByStatus(cards, CustomerCardStatus.RewardReady)),
            new CustomerCardGroupView("Active", FilterByStatus(cards, CustomerCardStatus.Active)),
            new CustomerCardGroupView("Scheduled", FilterByStatus(cards, CustomerCardStatus.Scheduled)),
            new CustomerCardGroupView("Expired", FilterByStatus(cards, CustomerCardStatus.Expired)),
            new CustomerCardGroupView("Redeemed", FilterByStatus(cards, CustomerCardStatus.Redeemed))
        }
        .Where(group => group.Cards.Count > 0)
        .ToArray();
    }

    private static string BuildSetupRoadmapHeadline(int completed, int total) =>
        completed == total ? "Your shop is ready." : $"{completed} of {total} setup steps complete";

    private static string BuildSetupRoadmapMessage(IReadOnlyList<SetupStepView> steps)
    {
        var nextStep = steps.FirstOrDefault(step => !step.IsComplete);
        return nextStep is null
            ? "Setup is complete. Use Programmes to run join, stamping, and loyalty insights."
            : $"Next best step: {nextStep.Label}.";
    }

    private void ToggleSetupRoadmap() => _isSetupRoadmapCollapsed = !_isSetupRoadmapCollapsed;

    private void DismissSetupRoadmap() => _isSetupRoadmapDismissed = true;

    private static bool IsProgrammeActiveOn(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        return today >= startsOn && today <= endsOn;
    }

    private static string BuildProgrammeWindowBadge(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return "Scheduled";
        }

        return today > endsOn ? "Expired" : "Active";
    }

    private static string BuildProgrammeWindowMessage(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return $"This programme opens on {FormatDate(startsOn)}.";
        }

        if (today > endsOn)
        {
            return $"This programme expired on {FormatDate(endsOn)}.";
        }

        return $"This programme is live until {FormatDate(endsOn)}.";
    }

    private void HandleStateChanged() =>
        _ = InvokeAsync(() =>
        {
            LoadWorkspace(refreshForms: false);
            StateHasChanged();
        });

    public void Dispose()
    {
        PlatformState.Changed -= HandleStateChanged;
    }

    private sealed class ShopForm
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = string.Empty;

        [Required, StringLength(60)]
        public string TownOrCity { get; set; } = string.Empty;

        [Required, StringLength(12)]
        public string Postcode { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = string.Empty;

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string PrimaryColor { get; set; } = "#1f3731";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string AccentColor { get; set; } = "#f4c15d";
    }

    private sealed class ProgrammeConfigurationForm : IValidatableObject
    {
        [Required, StringLength(40)]
        public string RewardItemLabel { get; set; } = "coffees";

        [Range(1, 20)]
        public int RewardThreshold { get; set; } = 5;

        [Required, StringLength(120)]
        public string RewardCopy { get; set; } = string.Empty;

        [Required]
        public DateOnly StartsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        [Required]
        public DateOnly EndsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddYears(1));

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (EndsOn < StartsOn)
            {
                yield return new ValidationResult(
                    "Expiry date must be on or after the begin date.",
                    [nameof(EndsOn)]);
            }
        }
    }

    private sealed record SetupStepView(
        int Order,
        string Label,
        string Section,
        string? ProgrammeSection,
        bool IsComplete,
        string StatusLabel);

    private sealed record ProgrammeGroupView(
        string Label,
        IReadOnlyList<ProgrammeSummarySnapshot> Programmes);

    private sealed record CustomerCardGroupView(
        string Label,
        IReadOnlyList<WalletCardSnapshot> Cards);
}

    private Task HandleCreateProgrammeAsync(string templateKey)
    {
        if (_workspace?.SetupChecklist.ShopDetailsComplete != true)
        {
            _programmeMessage = "Complete shop details before creating the first programme.";
            Navigation.NavigateTo(GetShopSettingsUrl());
            return Task.CompletedTask;
        }

        var isFirstProgrammeSetup = _workspace?.Programmes.Count == 0;
        var updated = PlatformState.CreateProgramme(MerchantId, templateKey, Navigation.BaseUri);
        if (updated?.SelectedProgramme is not null)
        {
            _isFinishingFirstProgrammeSetup = isFirstProgrammeSetup;
            Navigation.NavigateTo(GetProgrammeSectionUrl("configure", updated.SelectedProgramme.ProgrammeId));
        }

        return Task.CompletedTask;
    }

    private Task HandleProgrammeSaveAsync()
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return Task.CompletedTask;
        }

        _isSavingProgramme = true;

        try
        {
            var updated = PlatformState.UpdateProgramme(
                MerchantId,
                selectedProgramme.ProgrammeId,
                _programmeForm.RewardItemLabel,
                _programmeForm.RewardThreshold,
                _programmeForm.RewardCopy,
                _programmeForm.StartsOn,
                _programmeForm.EndsOn,
                Navigation.BaseUri);

            if (updated is not null)
            {
                if (IsFinishingFirstProgrammeSetup)
                {
                    _isFinishingFirstProgrammeSetup = false;
                    Navigation.NavigateTo(GetProgrammeSectionUrl("operate", updated.SelectedProgramme?.ProgrammeId));
                    return Task.CompletedTask;
                }

                _programmeMessage = "Programme updated.";
                LoadWorkspace(refreshForms: true);
            }
        }
        catch (InvalidOperationException ex)
        {
            _programmeMessage = ex.Message;
        }
        finally
        {
            _isSavingProgramme = false;
        }

        return Task.CompletedTask;
    }


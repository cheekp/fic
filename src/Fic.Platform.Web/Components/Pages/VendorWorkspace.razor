    private string GetWalletStatusLabel()
    {
        if (!WalletCapability.SupportsAppleWalletPass)
        {
            return "Preview fallback";
        }

        return WalletPushCapability.IsReady ? "Wallet refresh ready" : "Refresh setup";
    }

    private static bool IsProgrammeActiveOn(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        return today >= startsOn && today <= endsOn;
    }

    private static string BuildProgrammeWindowBadge(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return "Scheduled";
        }

        return today > endsOn ? "Expired" : "Active";
    }

    private static string BuildProgrammeWindowClass(string badge) =>
        badge switch
        {
            "Active" => "programme-list__item--window-active",
            "Scheduled" => "programme-list__item--window-scheduled",
            "Expired" => "programme-list__item--window-expired",
            _ => string.Empty
        };

    private static string BuildProgrammeTypeClass(string programmeTypeKey) =>
        programmeTypeKey switch
        {
            "visit-reward" => "programme-list__item--type-visit",
            "conditional-offer" => "programme-list__item--type-offer",
            _ => string.Empty
        };

    private static string BuildProgrammeWindowMessage(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return $"This programme opens on {FormatDate(startsOn)}.";
        }

        if (today > endsOn)
        {
            return $"This programme expired on {FormatDate(endsOn)}.";
        }

        return $"This programme is live until {FormatDate(endsOn)}.";
    }

    private static string BuildProgrammeWindowSummary(DateOnly startsOn, DateOnly endsOn)
    {
        var today = DateOnly.FromDateTime(DateTime.UtcNow);
        if (today < startsOn)
        {
            return $"Starts {FormatDate(startsOn)}";
        }

        if (today > endsOn)
        {
            return $"Expired {FormatDate(endsOn)}";
        }

        return $"Live until {FormatDate(endsOn)}";
    }

    private void HandleStateChanged() =>
        _ = InvokeAsync(() =>
        {
            LoadWorkspace(refreshForms: false);
            StateHasChanged();
        });

    public void Dispose()
    {
        PlatformState.Changed -= HandleStateChanged;
    }

    private sealed class ShopForm
    {
        [Required, StringLength(80)]
        public string DisplayName { get; set; } = string.Empty;

        [Required, StringLength(60)]
        public string TownOrCity { get; set; } = string.Empty;

        [Required, StringLength(12)]
        public string Postcode { get; set; } = string.Empty;

        [Required, EmailAddress]
        public string ContactEmail { get; set; } = string.Empty;

        [Required]
        public string ShopTypeKey { get; set; } = "coffee";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string PrimaryColor { get; set; } = "#1f3731";

        [Required, RegularExpression("^#?[0-9a-fA-F]{6}$", ErrorMessage = "Use a 6 digit hex colour.")]
        public string AccentColor { get; set; } = "#f4c15d";
    }

    private sealed class ProgrammeConfigurationForm : IValidatableObject
    {
        [Required, StringLength(40)]
        public string RewardItemLabel { get; set; } = "coffees";

        [Range(1, 20)]
        public int RewardThreshold { get; set; } = 5;

        [Required, StringLength(120)]
        public string RewardCopy { get; set; } = string.Empty;

        [Required]
        public DateOnly StartsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today);

        [Required]
        public DateOnly EndsOn { get; set; } = DateOnly.FromDateTime(DateTime.Today.AddYears(1));

        public IEnumerable<ValidationResult> Validate(ValidationContext validationContext)
        {
            if (EndsOn < StartsOn)
            {
                yield return new ValidationResult(
                    "Expiry date must be on or after the begin date.",
                    [nameof(EndsOn)]);
            }
        }
    }


            settings: null,
            launch: null);

    private string GetWorkspaceUrl(string section, string? programmeSection, Guid? programmeId, string? settings, string? launch) =>
        Navigation.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["tab"] = section == "programmes" ? "programmes" : "shop",
            ["section"] = section,
            ["programmeSection"] = section == "programmes" ? (programmeSection ?? (_workspace?.SetupChecklist.HasAnyProgramme == true ? "operate" : "create")) : null,
            ["programme"] = programmeId,
            ["settings"] = settings,
            ["launch"] = section == "programmes" ? launch : null
        });

    private string GetProgrammeSectionUrl(string section, Guid? programmeId = null, string? launch = null) =>
        GetWorkspaceUrl("programmes", section, programmeId ?? _workspace?.SelectedProgramme?.ProgrammeId, settings: null, launch: launch);

    private string GetProgrammeUrl(Guid programmeId, string? section = null) =>
        GetProgrammeSectionUrl(section ?? (IsWorkspaceSection("programmes") ? GetActiveProgrammeSection() : "operate"), programmeId);

    private string GetSetupStepUrl(SetupStepView step) =>
        step.Section == "programmes"
            ? GetProgrammeSectionUrl(step.ProgrammeSection ?? "operate")

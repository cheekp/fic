@page "/portal/merchant/{MerchantId:guid}"
@implements IDisposable
@using System.ComponentModel.DataAnnotations
@using Fic.Contracts
@using Fic.MerchantAccounts
@using Microsoft.Extensions.Configuration
@using Microsoft.Extensions.DependencyInjection
@inject DemoPlatformState PlatformState
@inject JoinQrCodeService QrCodes
@inject IJSRuntime JS
@inject NavigationManager Navigation
@inject IAppleWalletPassService WalletPasses
@inject IWalletPassUpdateNotifier WalletPushes
@inject MerchantBrandPresentationService BrandPresentation
@inject IServiceProvider Services

<PageTitle>Your Shop</PageTitle>

@if (_workspace is null)
{
    <section class="empty-state">
        <h2>Shop area not found.</h2>
        <p>The merchant account may not exist in the current demo instance.</p>
        <a class="button button--primary" href="/">Back to FIC Home</a>
    </section>
}
else
{
    var workspaceTheme = BrandPresentation.Build(_workspace.BrandProfile);
    var brandPreviewTheme = BuildBrandPreviewTheme();
    var selectedProgrammeSummary = SelectedProgrammeSummary;
    var selectedProgramme = _workspace.SelectedProgramme;
    var hasProgrammes = _workspace.Programmes.Count > 0;
    var hasSelectedProgramme = selectedProgramme is not null && selectedProgrammeSummary is not null;
    var selectedProgrammeBadge = hasSelectedProgramme
        ? BuildProgrammeWindowBadge(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)
        : string.Empty;
    var setupSteps = BuildSetupSteps();
    var completedSetupSteps = setupSteps.Count(x => x.IsComplete);
    var programmeGroups = BuildProgrammeGroups();
    var activeProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Active")?.Programmes.Count ?? 0;
    var scheduledProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Scheduled")?.Programmes.Count ?? 0;
    var expiredProgrammesCount = programmeGroups.FirstOrDefault(group => group.Label == "Expired")?.Programmes.Count ?? 0;
    var selectedProgrammeCards = _workspace.SelectedProgrammeCards;
    var isFirstTimeMode = IsFirstTimeMode;
    var isProgrammeWorkspaceSection = IsWorkspaceSection("programmes");
    var shopDetailsReady = _workspace.SetupChecklist.ShopDetailsComplete;
    var showProgrammeRail = hasProgrammes && !isFirstTimeMode;
    var showAdvancedProgrammeSections = !isFirstTimeMode;
    var customerCardGroups = BuildCustomerCardGroups(selectedProgrammeCards);
    var rewardReadyCardsCount = selectedProgrammeCards.Count(card => card.CustomerCardStatus == CustomerCardStatus.RewardReady);
    var redeemedCardsCount = selectedProgrammeCards.Count(card => card.CustomerCardStatus == CustomerCardStatus.Redeemed);
    var inactiveCardsCount = selectedProgrammeCards.Count(card =>
        card.CustomerCardStatus is CustomerCardStatus.Scheduled or CustomerCardStatus.Expired);
    var firstTimeProgrammeStepComplete = _workspace.SetupChecklist.HasAnyProgramme && !IsFinishingFirstProgrammeSetup;
    var showSetupCompletionNotice = ShowSetupCompletionNotice;
    var isSignupDemoSeedEnabled = IsSignupDemoSeedEnabled;

    <div class="workspace-stage @workspaceTheme.ThemeClass @(isFirstTimeMode ? "workspace-stage--first-time" : string.Empty)" style="@workspaceTheme.CssVariables">
        <div class="workspace-chrome-shell">
            <section class="workspace-header">
                <div class="workspace-brand">
                    <div class="brand-lockup brand-lockup--merchant">
                        <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo" />
                    </div>
                    <div class="workspace-brand__copy">
                        <p class="eyebrow">Your shop</p>
                        <h2>@_workspace.Merchant.DisplayName</h2>
                        <p class="field-hint">@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>
                        <p class="field-hint">Shop type: @CurrentShopTypeLabel</p>
                        @if (!IsShopSettingsOpen())
                        {
                            <a class="workspace-inline-link" href="@GetShopSettingsUrl()">Shop settings</a>
                        }
                    </div>
                </div>
                @if (!isFirstTimeMode)
                {
                    <div class="workspace-header__actions">
                        <a class="button button--ghost button--compact" href="/support/wallet-demo">@GetWalletStatusLabel()</a>
                    </div>
                }
            </section>

            @if (!isFirstTimeMode)
            {
                <div class="workspace-tabs-bar @(isProgrammeWorkspaceSection ? "workspace-tabs-bar--programme" : string.Empty)">
                    <nav class="workspace-tabs workspace-tabs--primary segmented-control" aria-label="Shop sections">
                        <a class="workspace-tabs__item segmented-control__item @(IsWorkspaceSection("overview") ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("overview")">Overview</a>
                        <a class="workspace-tabs__item segmented-control__item @(isProgrammeWorkspaceSection ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("programmes")">Programmes</a>
                        <a class="workspace-tabs__item segmented-control__item @(IsWorkspaceSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetWorkspaceSectionUrl("insights")">Insights</a>
                    </nav>
                    @if (showSetupCompletionNotice)
                    {
                        <div class="workspace-chrome-status" aria-live="polite">
                            <span class="workspace-chrome-status__label">Setup complete</span>
                            <div class="workspace-chrome-status__actions">
                                <a class="workspace-chrome-status__link" aria-label="Open overview" href='@GetWorkspaceSectionUrl("overview")'>Overview</a>
                                <a class="workspace-chrome-status__link" aria-label="Open insights" href='@GetWorkspaceSectionUrl("insights")'>Insights</a>
                                <button class="workspace-chrome-status__link workspace-chrome-status__link--button" type="button" @onclick="DismissSetupCompletionNotice">Dismiss</button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        @if (isFirstTimeMode)
        {
            <OnboardingJourney CurrentStep="@(shopDetailsReady ? "programme" : "shop")"
                               AccountComplete="true"
                               PlanComplete="_workspace.SetupChecklist.OwnerAccessConfigured"
                               BillingComplete="_workspace.SetupChecklist.OwnerAccessConfigured"
                               ShopComplete="shopDetailsReady"
                               ProgrammeComplete="firstTimeProgrammeStepComplete"
                               IsStrip="true"
                               AccountUrl="/portal/signup"
                               PlanUrl="@($"/portal/signup/plan/{MerchantId:D}")"
                               BillingUrl="@($"/portal/signup/billing/{MerchantId:D}?plan=starter")"
                               ShopUrl="@GetShopSettingsUrl()"
                               ProgrammeUrl="@GetProgrammeSectionUrl(_workspace.SetupChecklist.HasAnyProgramme ? "configure" : "create")" />
        }

        @if (IsWorkspaceSection("overview"))
        {
            @if (!_isSetupRoadmapDismissed && completedSetupSteps < setupSteps.Count)
            {
                <section class="panel setup-roadmap @(_isSetupRoadmapCollapsed ? "setup-roadmap--collapsed" : string.Empty)">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Onboarding roadmap</p>
                            <h3>@BuildSetupRoadmapHeadline(completedSetupSteps, setupSteps.Count)</h3>
                        </div>
                        <div class="workspace-actions">
                            <span class="chip chip--accent">@completedSetupSteps/@setupSteps.Count complete</span>
                            <button class="button button--ghost button--compact" type="button" @onclick="ToggleSetupRoadmap">
                                @(_isSetupRoadmapCollapsed ? "Show setup" : "Hide setup")
                            </button>
                            <button class="button button--ghost button--compact" type="button" @onclick="DismissSetupRoadmap">Dismiss</button>
                        </div>
                    </div>

                    @if (!_isSetupRoadmapCollapsed)
                    {
                        <p class="field-hint">@BuildSetupRoadmapMessage(setupSteps)</p>
                        <div class="setup-roadmap__steps">
                            @foreach (var step in setupSteps)
                            {
                                <a class="setup-roadmap__step @(step.IsComplete ? "setup-roadmap__step--complete" : string.Empty) @(IsSetupStepActive(step) ? "setup-roadmap__step--current" : string.Empty)"
                                   href="@GetSetupStepUrl(step)">
                                    <span class="setup-roadmap__step-index">@step.Order</span>
                                    <span class="setup-roadmap__step-copy">
                                        <strong>@step.Label</strong>
                                        <span>@step.StatusLabel</span>
                                    </span>
                                </a>
                            }
                        </div>
                    }
                </section>
            }

            <section class="workspace-detail-grid">
                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop overview</p>
                            <h3>Shop at a glance</h3>
                        </div>
                    </div>
                    <div class="workspace-preview-card">
                        <div class="brand-lockup brand-lockup--merchant">
                            <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                        </div>
                        <div>
                            <p class="workspace-preview-copy">@_workspace.Merchant.DisplayName</p>
                            <p class="field-hint">@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>
                            <p class="field-hint">Brand defaults, merchant details, and whole-shop insight live here.</p>
                        </div>
                    </div>
                    <dl class="shop-profile-summary">
                        <div>
                            <dt>Owner email</dt>
                            <dd>@_workspace.Merchant.ContactEmail</dd>
                        </div>
                        <div>
                            <dt>Location</dt>
                            <dd>@_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</dd>
                        </div>
                        <div>
                            <dt>Brand default</dt>
                            <dd>Inherited by all programmes</dd>
                        </div>
                        <div>
                            <dt>Setup status</dt>
                            <dd>@BuildSetupRoadmapHeadline(completedSetupSteps, setupSteps.Count)</dd>
                        </div>
                    </dl>
                </article>

                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Programmes in this shop</p>
                            <h3>Where loyalty actually runs</h3>
                        </div>
                        <a class="button button--ghost button--compact" href="@GetProgrammeSectionUrl("operate")">Open programmes</a>
                    </div>
                    <div class="workspace-overview-strip workspace-summary-grid">
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Active</span>
                            <strong class="workspace-overview-card__value">@activeProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Currently open to join, stamp, and redeem.</p>
                        </article>
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Scheduled</span>
                            <strong class="workspace-overview-card__value">@scheduledProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Configured and waiting for their begin date.</p>
                        </article>
                        <article class="workspace-overview-card">
                            <span class="workspace-overview-card__label">Expired</span>
                            <strong class="workspace-overview-card__value">@expiredProgrammesCount</strong>
                            <p class="workspace-overview-card__copy">Past programmes retained for reference and insight.</p>
                        </article>
                    </div>
                    <p class="field-hint">@(selectedProgrammeSummary is null ? "Create the first programme to open customer join, Wallet delivery, and daily operations." : $"Current programme focus: {selectedProgrammeSummary.RewardHeadline}. Customer join, stamping, dates, and delivery all live inside the programme workspace.")</p>
                </article>
            </section>
        }
        else if (IsWorkspaceSection("insights"))
        {
            <section class="workspace-detail-grid">
                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop insights</p>
                            <h3>Across every programme in the shop</h3>
                        </div>
                        <span class="chip">Shop level</span>
                    </div>
                    <div class="metrics-grid">
                        <article class="metric-card">
                            <span class="metric-card__label">Programmes</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.ProgrammesCount</strong>
                            <p class="metric-card__copy">Programmes configured for this shop.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Customers</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.ActiveCards</strong>
                            <p class="metric-card__copy">Customer cards currently live across every programme.</p>
                        </article>
                        <article class="metric-card">
                            <span class="metric-card__label">Unlocked</span>
                            <strong class="metric-card__value">@_workspace.ShopInsights.RewardsUnlocked</strong>
                            <p class="metric-card__copy">Rewards available to redeem across the whole shop.</p>
                        </article>
                    </div>
                </article>

                <article class="panel">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Programme comparison</p>
                            <h3>How each programme is performing</h3>
                        </div>
                    </div>
                    <div class="programme-list">
                        @foreach (var programme in _workspace.Programmes)
                        {
                            <a class="programme-list__item @(programme.ProgrammeId == selectedProgramme?.ProgrammeId ? "programme-list__item--active" : string.Empty)"
                               href="@GetProgrammeUrl(programme.ProgrammeId, "insights")">
                                <div>
                                    <p class="eyebrow">Programme</p>
                                    <h4>@programme.RewardHeadline</h4>
                                    <p class="field-hint">@BuildProgrammeWindowMessage(programme.StartsOn, programme.EndsOn)</p>
                                </div>
                                <div class="programme-list__meta">
                                    <span>@programme.ActiveCards customers</span>
                                    <span>@programme.RewardsUnlocked unlocked</span>
                                    <span>@BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn)</span>
                                </div>
                            </a>
                        }
                    </div>
                </article>
            </section>
        }
        else
        {
            <section class="workspace-programme-shell">
                <section class="workspace-detail-grid @(showProgrammeRail ? "workspace-detail-grid--programme-shell" : "workspace-detail-grid--single-pane")">
                    @if (showProgrammeRail)
                    {
                        <aside class="programme-sidebar programme-rail">
                            <div class="programme-rail__header">
                                <div class="programme-rail__title">
                                    <p class="eyebrow">Programmes</p>
                                    <h3>Programmes</h3>
                                </div>
                            </div>

                            <div class="programme-rail__controls">
                                <a class="button button--secondary button--compact programme-rail__new-button" href="@GetProgrammeSectionUrl("create")" aria-label="Add programme">
                                    <span class="programme-rail__new-icon" aria-hidden="true">+</span>
                                    <span>Add programme</span>
                                </a>
                                <label class="programme-rail__sort" for="programme-rail-sort">
                                    <span>Sort</span>
                                    <select id="programme-rail-sort" class="programme-rail__select" value="@_programmeGroupSort" @onchange="HandleProgrammeGroupSortChanged">
                                        <option value="end-date">Ends soonest</option>
                                        <option value="name">Name A-Z</option>
                                        <option value="start-date">Starts soonest</option>
                                    </select>
                                </label>
                            </div>

                            <div class="programme-groups">
                                @foreach (var group in programmeGroups)
                                {
                                    <section class="programme-group">
                                        <button class="programme-group__toggle"
                                                type="button"
                                                aria-expanded="@(group.IsCollapsed ? "false" : "true")"
                                                aria-controls="@BuildProgrammeGroupContentId(group.Label)"
                                                @onclick="@(() => ToggleProgrammeGroup(group.Label))">
                                            <span class="programme-group__label">@group.Label</span>
                                            <span class="chip">@group.Programmes.Count</span>
                                            <span class="programme-group__action">@(group.IsCollapsed ? "Show" : "Hide")</span>
                                        </button>

                                        @if (!group.IsCollapsed)
                                        {
                                            <div id="@BuildProgrammeGroupContentId(group.Label)" class="programme-list">
                                                @foreach (var programme in group.Programmes)
                                                {
                                                    var programmeWindowBadge = BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn);
                                                    var programmeWindowClass = BuildProgrammeWindowClass(programmeWindowBadge);
                                                    var programmeTypeClass = BuildProgrammeTypeClass(programme.ProgrammeTypeKey);
                                                    var isSelectedProgramme = programme.ProgrammeId == selectedProgramme?.ProgrammeId;

                                                    <a class="programme-list__item programme-list__item--pass @programmeWindowClass @programmeTypeClass @(isSelectedProgramme ? "programme-list__item--active" : string.Empty)"
                                                       href="@GetProgrammeUrl(programme.ProgrammeId)"
                                                       aria-current="@(isSelectedProgramme ? "page" : null)"
                                                       aria-controls="programme-detail-panel">
                                                        <div class="programme-list__pass-face">
                                                            <div class="programme-list__pass-top">
                                                                <p class="eyebrow">Wallet pass preview</p>
                                                                @if (isSelectedProgramme)
                                                                {
                                                                    <span class="chip chip--accent programme-list__selection-chip">Viewing</span>
                                                                }
                                                            </div>
                                                            <div class="programme-list__pass-body">
                                                                <div class="programme-list__pass-copy">
                                                                    <h4>@programme.RewardHeadline</h4>
                                                                    <p class="field-hint">@programme.ProgrammeTypeLabel · @programme.TemplateLabel</p>
                                                                </div>
                                                                <div class="brand-lockup brand-lockup--mini" aria-hidden="true">
                                                                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="" />
                                                                </div>
                                                            </div>
                                                            <div class="programme-list__meta">
                                                                <span>Card type: @programme.CardTypeLabel</span>
                                                                <span>@BuildProgrammeWindowSummary(programme.StartsOn, programme.EndsOn)</span>
                                                            </div>
                                                        </div>
                                                    </a>
                                                }
                                            </div>
                                        }
                                    </section>
                                }
                            </div>
                        </aside>
                    }

                    <div class="workspace-stack workspace-stack--programme programme-workpane @(_animateProgrammeSelection ? "programme-workpane--refresh" : string.Empty)" @key="selectedProgrammeSummary?.ProgrammeId">
                        @if (!hasProgrammes || IsProgrammeSection("create"))
                        {
                            <section class="panel programme-setup-flow @(hasProgrammes ? string.Empty : "onboarding-step onboarding-step--workspace")">
                                @{
                                    var filteredProgrammeTemplates = FilteredProgrammeTemplates;
                                }
                                <div class="panel__header onboarding-step__header">
                                    <div class="onboarding-step__copy">
                                        <p class="eyebrow">@(hasProgrammes ? "New programme" : "Step 5 of 5")</p>
                                        <h3>@(hasProgrammes ? "Add another programme" : "Create your first programme")</h3>
                                        <p class="lede">Pick one template to launch. You can fine-tune reward rules immediately after this step.</p>
                                    </div>
                                    @if (!hasProgrammes && isSignupDemoSeedEnabled)
                                    {
                                        <div class="workspace-actions">
                                            <button class="button button--secondary button--compact" type="button" disabled="@(!shopDetailsReady)" @onclick="ApplyProgrammeDemoSeedAsync">Use demo template</button>
                                        </div>
                                    }
                                </div>

                                @if (!shopDetailsReady)
                                {
                                    <p class="field-hint onboarding-required-note">Complete shop details first. Branding can be adjusted now or skipped for later.</p>
                                }

                                <section class="template-filter-bar" aria-label="Template filters">
                                    <label class="template-filter-bar__field" for="template-card-type-filter">
                                        <span>Card type</span>
                                        <select id="template-card-type-filter" class="template-filter-bar__select" value="@_selectedTemplateCardTypeKey" @onchange="HandleTemplateCardTypeChanged">
                                            <option value="all">All card types</option>
                                            @foreach (var cardType in CardTypes)
                                            {
                                                <option value="@cardType.CardTypeKey">@cardType.CardTypeLabel</option>
                                            }
                                        </select>
                                    </label>
                                    <p class="template-filter-bar__shop-type">
                                        <span class="chip">Shop type: @CurrentShopTypeLabel</span>
                                        <a class="inline-link" href="@GetShopSettingsUrl()">Change in shop settings</a>
                                    </p>
                                    <p class="field-hint template-filter-bar__summary">@BuildTemplateFilterSummary(filteredProgrammeTemplates.Count)</p>
                                </section>

                                @if (filteredProgrammeTemplates.Count == 0)
                                {
                                    <p class="field-hint onboarding-required-note">No templates match this filter. Try a different shop type or card type.</p>
                                }
                                else
                                {
                                    <div class="template-grid">
                                        @foreach (var template in filteredProgrammeTemplates)
                                        {
                                            <article class="template-card">
                                                <div class="template-card__header">
                                                    <div>
                                                        <p class="eyebrow">@template.ProgrammeTypeLabel</p>
                                                        <h4>@template.TemplateLabel</h4>
                                                    </div>
                                                    <span class="chip chip--accent">@template.DeliveryTypeLabel</span>
                                                </div>
                                                <p class="template-card__headline">@template.Headline</p>
                                                <p class="field-hint">@template.Description</p>
                                                <p class="field-hint">Reward rule: @template.RewardCopy</p>
                                                <p class="field-hint">Card type: @template.CardTypeLabel</p>
                                                <div class="template-card__meta">
                                                    <span class="chip">@GetShopTypeLabel(template.ShopTypeKey)</span>
                                                    <span class="chip">@template.CardTypeLabel</span>
                                                </div>
                                                <div class="form-actions form-actions--onboarding">
                                                    <button class="button button--primary button--wide button--block" type="button" disabled="@(!shopDetailsReady)" @onclick="@(() => HandleCreateProgrammeAsync(template.TemplateKey))">@(hasProgrammes ? "Use this template" : "Start with this template")</button>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                }
                            </section>
                        }
                        else
                        {
                            <section class="programme-selection-strip @(showProgrammeRail ? "programme-selection-strip--linked" : string.Empty) @(_animateProgrammeSelection ? "programme-selection-strip--refresh" : string.Empty)" id="programme-detail-panel">
                                <section class="programme-context-bar">
                                    <div class="programme-context-bar__identity">
                                        <div class="brand-lockup brand-lockup--mini programme-context-bar__logo" aria-hidden="true">
                                            <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="" />
                                        </div>
                                        <div class="programme-context-bar__title">
                                            <p class="eyebrow">Selected programme</p>
                                            <h3>@selectedProgrammeSummary!.RewardHeadline</h3>
                                            <p class="field-hint">From Programmes list · Started from @selectedProgrammeSummary.TemplateLabel</p>
                                        </div>
                                    </div>
                                    <div class="programme-context-bar__meta">
                                        <span class="chip">@selectedProgrammeBadge</span>
                                        <span class="programme-context-bar__window">@selectedProgrammeSummary.StartsOn.ToString("dd MMM yyyy") - @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy")</span>
                                        <span class="programme-context-bar__descriptor">@selectedProgrammeSummary.ProgrammeTypeLabel · @selectedProgrammeSummary.CardTypeLabel · @selectedProgrammeSummary.DeliveryTypeLabel</span>
                                    </div>
                                </section>

                                <nav class="workspace-tabs workspace-tabs--sub workspace-tabs--programme segmented-control" aria-label="Programme sections">
                                    <a class="workspace-tabs__item segmented-control__item @(IsProgrammeSection("operate") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("operate")">Operate</a>
                                    <a class="workspace-tabs__item segmented-control__item @(IsProgrammeSection("configure") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("configure")">Configure</a>
                                    @if (showAdvancedProgrammeSections)
                                    {
                                        <a class="workspace-tabs__item segmented-control__item @(IsProgrammeSection("customers") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("customers")">Customers</a>
                                        <a class="workspace-tabs__item segmented-control__item @(IsProgrammeSection("insights") ? "workspace-tabs__item--active" : string.Empty)" href="@GetProgrammeSectionUrl("insights")">Insights</a>
                                    }
                                </nav>
                            </section>

                        @if (IsProgrammeSection("operate"))
                        {
                            <section class="workspace-detail-grid">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Customer join</p>
                                            <h3>Customer join QR</h3>
                                        </div>
                                    </div>
                                    <div class="qr-panel">
                                        <div class="qr-panel__graphic">
                                            @((MarkupString)_joinQrSvg)
                                        </div>
                                        <div class="qr-panel__meta">
                                            <p>Customers scan this QR, join the programme, and receive the current output through @selectedProgrammeSummary.DeliveryTypeLabel.</p>
                                            <p class="field-hint">Valid @selectedProgrammeSummary.StartsOn.ToString("dd MMM yyyy") to @selectedProgrammeSummary.EndsOn.ToString("dd MMM yyyy")</p>
                                            <code class="join-link-code">@_workspace.SelectedJoinUrl</code>
                                            @if (!string.IsNullOrWhiteSpace(_operateMessage))
                                            {
                                                <p class="field-hint">@_operateMessage</p>
                                            }
                                            @if (!SelectedProgrammeIsActive)
                                            {
                                                <p class="field-hint">@BuildProgrammeWindowMessage(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)</p>
                                            }
                                            <div class="form-actions form-actions--join">
                                                @if (SelectedProgrammeIsActive)
                                                {
                                                    <a class="button button--secondary" href="@_workspace.SelectedJoinUrl" target="_blank">Open Customer Join</a>
                                                    <button class="button button--ghost" type="button" @onclick="HandleCopyJoinLinkAsync">Copy Join Link</button>
                                                }
                                                else
                                                {
                                                    <button class="button button--secondary" type="button" disabled>Open Customer Join</button>
                                                    <button class="button button--ghost" type="button" disabled>Copy Join Link</button>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </article>

                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Till-side stamping</p>
                                            <h3>Stamp visits</h3>
                                        </div>
                                    </div>
                                    <p class="field-hint">@_workspace.SelectedProgrammeCards.Count active cards on this programme.</p>
                                    <EditForm OnValidSubmit="HandleAwardVisitAsync" Model="this" FormName="award-visit" class="form-stack">
                                        <label class="field">
                                            <span>Customer pass code</span>
                                            <InputText @bind-Value="_scanCode" class="input" placeholder="card-..." />
                                        </label>
                                        <div class="form-actions">
                                            <button class="button button--primary" type="submit" disabled="@(!SelectedProgrammeIsActive || string.IsNullOrWhiteSpace(_scanCode))">Award visit</button>
                                            <button class="button button--ghost" type="button" @onclick="ClearScan">Clear</button>
                                        </div>
                                    </EditForm>
                                    @if (!SelectedProgrammeIsActive)
                                    {
                                        <p class="field-hint">@BuildProgrammeWindowMessage(selectedProgramme!.StartsOn, selectedProgramme.EndsOn)</p>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_scanMessage))
                                    {
                                        <p class="field-hint">@_scanMessage</p>
                                    }
                                </article>

                                @if (isFirstTimeMode)
                                {
                                    <article class="panel">
                                        <div class="panel__header">
                                            <div>
                                                <p class="eyebrow">Next step</p>
                                                <h3>Join one customer pass first</h3>
                                            </div>
                                        </div>
                                        <p class="field-hint">Open Customer Join on your phone, add the pass, then come back and stamp the first visit.</p>
                                    </article>
                                }
                            </section>

                            @if (!isFirstTimeMode)
                            {
                                <section class="workspace-detail-grid workspace-detail-grid--programme-operate-secondary">
                                    <article class="panel">
                                        <div class="panel__header">
                                            <div>
                                                <p class="eyebrow">Daily use</p>
                                                <h3>Quick programme picture</h3>
                                            </div>
                                        </div>
                                        <div class="workspace-overview-strip workspace-summary-grid">
                                            <article class="workspace-overview-card">
                                                <span class="workspace-overview-card__label">Issued</span>
                                                <strong class="workspace-overview-card__value">@selectedProgrammeCards.Count</strong>
                                                <p class="workspace-overview-card__copy">Customer passes currently issued on this programme.</p>
                                            </article>
                                            <article class="workspace-overview-card">
                                                <span class="workspace-overview-card__label">Reward ready</span>
                                                <strong class="workspace-overview-card__value">@rewardReadyCardsCount</strong>
                                                <p class="workspace-overview-card__copy">Ready to redeem right now.</p>
                                            </article>
                                            <article class="workspace-overview-card">
                                                <span class="workspace-overview-card__label">Redeemed</span>
                                                <strong class="workspace-overview-card__value">@redeemedCardsCount</strong>
                                                <p class="workspace-overview-card__copy">Most recently completed and reset.</p>
                                            </article>
                                            <article class="workspace-overview-card">
                                                <span class="workspace-overview-card__label">Inactive</span>
                                                <strong class="workspace-overview-card__value">@inactiveCardsCount</strong>
                                                <p class="workspace-overview-card__copy">Currently outside the programme’s active date window.</p>
                                            </article>
                                        </div>
                                        <div class="form-actions">
                                            <a class="button button--secondary" href="@GetProgrammeSectionUrl("customers")">Manage customer passes</a>
                                        </div>
                                    </article>

                                    <article class="panel">
                                        <div class="panel__header">
                                            <div>
                                                <p class="eyebrow">Recent activity</p>
                                                <h3>Programme timeline</h3>
                                            </div>
                                        </div>
                                        <div class="timeline">
                                            @foreach (var entry in _workspace.Timeline)
                                            {
                                                <article class="timeline__entry">
                                                    <div class="timeline__dot"></div>
                                                    <div>
                                                        <p class="timeline__event">@entry.EventType</p>
                                                        <p>@entry.Summary</p>
                                                        <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                    </div>
                                                </article>
                                            }
                                        </div>
                                    </article>
                                </section>
                            }
                        }
                        else if (IsProgrammeSection("customers"))
                        {
                            <section class="workspace-stack workspace-stack--programme-customers">
                                <section class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Customer pass management</p>
                                            <h3>Issued passes on this programme</h3>
                                        </div>
                                        <span class="chip">@selectedProgrammeCards.Count cards</span>
                                    </div>

                                    @if (selectedProgrammeCards.Count == 0)
                                    {
                                        <div class="empty-state empty-state--compact">
                                            <h4>No customer passes issued yet.</h4>
                                            <p>Share the join QR from Operate first. Once someone joins, their pass appears here with status and actions.</p>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="customer-card-groups">
                                            @foreach (var group in customerCardGroups)
                                            {
                                                <section class="customer-card-group">
                                                    <div class="customer-card-group__header">
                                                        <h4>@group.Label</h4>
                                                        <span class="chip">@group.Cards.Count</span>
                                                    </div>
                                                    <div class="card-list">
                                                        @foreach (var card in group.Cards)
                                                        {
                                                            <article class="card-row">
                                                                <div>
                                                                    <p class="eyebrow">Issued customer pass</p>
                                                                    <h4>@card.ProgressDisplayText</h4>
                                                                    <p class="field-hint">Status: @card.CustomerCardStatusLabel</p>
                                                                    <p class="field-hint">Valid @FormatDate(card.StartsOn) to @FormatDate(card.EndsOn)</p>
                                                                    <p class="field-hint">Pass code: <code>@card.CardCode</code></p>
                                                                </div>
                                                                <div class="card-row__meta">
                                                                    <span class="chip @(card.CustomerCardStatus == CustomerCardStatus.RewardReady ? "chip--success" : string.Empty)">@card.CustomerCardStatusLabel</span>
                                                                    <a class="button button--ghost" href="/wallet/card/@card.CardId" target="_blank">Preview</a>
                                                                    @if (WalletCapability.SupportsAppleWalletPass)
                                                                    {
                                                                        <a class="button button--ghost" href="/wallet/passes/@(card.CardId).pkpass" target="_blank">Wallet Pass</a>
                                                                    }
                                                                    <button class="button button--secondary" type="button" @onclick="@(() => UseScanCode(card.CardCode))">Load Code</button>
                                                                    <button class="button button--secondary" type="button" disabled="@(!card.CanRedeem)" @onclick="@(() => HandleRedeemAsync(card.CardId))">Redeem</button>
                                                                </div>
                                                            </article>
                                                        }
                                                    </div>
                                                </section>
                                            }
                                        </div>
                                    }
                                </section>

                                <section class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Recent activity</p>
                                            <h3>Programme timeline</h3>
                                        </div>
                                    </div>
                                    <div class="timeline">
                                        @foreach (var entry in _workspace.Timeline)
                                        {
                                            <article class="timeline__entry">
                                                <div class="timeline__dot"></div>
                                                <div>
                                                    <p class="timeline__event">@entry.EventType</p>
                                                    <p>@entry.Summary</p>
                                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </section>
                            </section>
                        }
                        else if (IsProgrammeSection("configure"))
                        {
                            <section class="workspace-detail-grid workspace-detail-grid--programme-configure">
                                <article class="panel programme-configure-editor">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme configuration</p>
                                            <h3>@(IsFinishingFirstProgrammeSetup ? "Finish programme setup" : "Programme setup and current delivery")</h3>
                                        </div>
                                    </div>
                                    <EditForm Model="_programmeForm" OnValidSubmit="HandleProgrammeSaveAsync" FormName="update-programme" class="form-stack">
                                        <DataAnnotationsValidator />
                                        <ValidationSummary class="validation-summary" />

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Programme model</h4>
                                                <p class="field-hint">Template, type, and current delivery for this programme.</p>
                                            </div>
                                            <dl class="template-card__facts programme-model-summary">
                                                <div>
                                                    <dt>Starter template</dt>
                                                    <dd>@selectedProgrammeSummary.TemplateLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Programme type</dt>
                                                    <dd>@selectedProgrammeSummary.ProgrammeTypeLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Delivery type</dt>
                                                    <dd>@selectedProgrammeSummary.DeliveryTypeLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Card type</dt>
                                                    <dd>@selectedProgrammeSummary.CardTypeLabel</dd>
                                                </div>
                                                <div>
                                                    <dt>Current output</dt>
                                                    <dd>@selectedProgrammeSummary.OutputLabel</dd>
                                                </div>
                                            </dl>
                                        </section>

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Rule and schedule</h4>
                                                <p class="field-hint">@selectedProgrammeSummary.ProgrammeTypeLabel</p>
                                            </div>
                                            <div class="form-grid">
                                                <label class="field">
                                                    <span>Reward item</span>
                                                    <InputText @bind-Value="_programmeForm.RewardItemLabel" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Visits before reward</span>
                                                    <InputNumber @bind-Value="_programmeForm.RewardThreshold" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Begins on</span>
                                                    <InputDate @bind-Value="_programmeForm.StartsOn" class="input" />
                                                </label>

                                                <label class="field">
                                                    <span>Expires on</span>
                                                    <InputDate @bind-Value="_programmeForm.EndsOn" class="input" />
                                                </label>
                                            </div>
                                        </section>

                                        <section class="form-section">
                                            <div class="form-section__header">
                                                <h4>Customer delivery</h4>
                                                <p class="field-hint">@selectedProgrammeSummary.DeliveryTypeLabel</p>
                                            </div>
                                            <div class="delivery-options">
                                                <article class="delivery-option delivery-option--selected">
                                                    <div class="delivery-option__copy">
                                                        <strong>@selectedProgrammeSummary.CardTypeLabel</strong>
                                                        <span>Output: @selectedProgrammeSummary.OutputLabel</span>
                                                        <span>Current live output for this programme.</span>
                                                    </div>
                                                    <span class="chip chip--accent">Current</span>
                                                </article>
                                            </div>
                                            <div class="form-grid">
                                                <label class="field field--full">
                                                    <span>Customer-facing copy</span>
                                                    <InputText @bind-Value="_programmeForm.RewardCopy" class="input" />
                                                </label>
                                            </div>
                                        </section>

                                        @if (!string.IsNullOrWhiteSpace(_programmeMessage))
                                        {
                                            <p class="field-hint">@_programmeMessage</p>
                                        }

                                        <div class="form-actions">
                                            <button class="button button--primary" type="submit" disabled="@_isSavingProgramme">@(IsFinishingFirstProgrammeSetup ? "Save and open operate" : "Save Programme")</button>
                                            <button class="button button--ghost" type="button" @onclick="ResetProgrammeForm">Reset</button>
                                        </div>
                                    </EditForm>
                                </article>

                                <article class="panel workspace-preview-panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Preview</p>
                                            <h3>@selectedProgrammeSummary.OutputLabel preview</h3>
                                        </div>
                                    </div>
                                    <div class="wallet-pass @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                                        <header class="wallet-pass__header">
                                            <div>
                                                <p class="wallet-pass__label">Current delivery</p>
                                                <h2>@_shopForm.DisplayName</h2>
                                            </div>
                                            <div class="wallet-pass__mark">
                                                <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName wallet logo" />
                                            </div>
                                        </header>

                                        <div class="wallet-pass__body">
                                            <div>
                                                <p class="wallet-pass__copy">@_programmeForm.RewardCopy</p>
                                                <p class="wallet-pass__progress">2/@_programmeForm.RewardThreshold</p>
                                                <p class="field-hint">Valid @FormatDate(_programmeForm.StartsOn) to @FormatDate(_programmeForm.EndsOn)</p>
                                            </div>
                                            <div class="stamp-track" aria-label="wallet template preview">
                                                @for (var i = 0; i < _programmeForm.RewardThreshold; i++)
                                                {
                                                    <span class="stamp @(i < 2 ? "stamp--filled" : string.Empty)">@(@i + 1)</span>
                                                }
                                            </div>
                                            <p class="wallet-pass__status">Uses the shop brand defaults for this programme.</p>
                                        </div>
                                    </div>
                                    <div class="workspace-preview-panel__details">
                                        <div>
                                            <span>Template</span>
                                            <strong>@selectedProgrammeSummary.TemplateLabel</strong>
                                        </div>
                                        <div>
                                            <span>Card type</span>
                                            <strong>@selectedProgrammeSummary.CardTypeLabel</strong>
                                        </div>
                                        <div>
                                            <span>Delivery type</span>
                                            <strong>@selectedProgrammeSummary.DeliveryTypeLabel</strong>
                                        </div>
                                        <div>
                                            <span>Current output</span>
                                            <strong>@selectedProgrammeSummary.OutputLabel</strong>
                                        </div>
                                        <div>
                                            <span>Programme window</span>
                                            <strong>@FormatDate(_programmeForm.StartsOn) to @FormatDate(_programmeForm.EndsOn)</strong>
                                        </div>
                                    </div>
                                    <p class="field-hint workspace-preview-panel__hint">Preview updates as you edit reward rules, dates, and customer-facing copy.</p>
                                </article>
                            </section>
                        }
                        else
                        {
                            <section class="workspace-detail-grid">
                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme insights</p>
                                            <h3>@selectedProgrammeSummary.RewardHeadline</h3>
                                        </div>
                                        <span class="chip">Programme level</span>
                                    </div>
                                    <div class="metrics-grid">
                                        <article class="metric-card">
                                            <span class="metric-card__label">Customers</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.ActiveCards</strong>
                                            <p class="metric-card__copy">Customer passes issued from this programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Unlocked</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.RewardsUnlocked</strong>
                                            <p class="metric-card__copy">Rewards currently unlocked on this programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Join code</span>
                                            <strong class="metric-card__value">@selectedProgrammeSummary.JoinCode</strong>
                                            <p class="metric-card__copy">This join code belongs only to the selected programme.</p>
                                        </article>
                                        <article class="metric-card">
                                            <span class="metric-card__label">Validity</span>
                                            <strong class="metric-card__value">@selectedProgrammeBadge</strong>
                                            <p class="metric-card__copy">@BuildProgrammeWindowMessage(selectedProgrammeSummary.StartsOn, selectedProgrammeSummary.EndsOn)</p>
                                        </article>
                                    </div>
                                </article>

                                <article class="panel">
                                    <div class="panel__header">
                                        <div>
                                            <p class="eyebrow">Programme activity</p>
                                            <h3>Recent events for the selected programme</h3>
                                        </div>
                                    </div>
                                    <div class="timeline">
                                        @foreach (var entry in _workspace.Timeline)
                                        {
                                            <article class="timeline__entry">
                                                <div class="timeline__dot"></div>
                                                <div>
                                                    <p class="timeline__event">@entry.EventType</p>
                                                    <p>@entry.Summary</p>
                                                    <small>@entry.OccurredAtUtc.ToLocalTime().ToString("dd MMM yyyy HH:mm:ss")</small>
                                                </div>
                                            </article>
                                        }
                                    </div>
                                </article>
                            </section>
                        }
                        }
                    </div>
                </section>
            </section>
        }

        @if (IsShopSettingsOpen())
        {
            <div class="workspace-drawer-backdrop">
                <aside class="panel workspace-drawer @(isFirstTimeMode ? "workspace-drawer--onboarding" : string.Empty)" aria-label="Shop settings drawer">
                    <div class="panel__header">
                        <div>
                            <p class="eyebrow">Shop settings</p>
                            <h3>Change profile and brand defaults</h3>
                        </div>
                        <div class="workspace-actions">
                            <span class="chip">Shop level</span>
                            <a class="button button--ghost button--compact" href="@GetCloseShopSettingsUrl()">Close</a>
                        </div>
                    </div>

                    <p class="field-hint">These defaults apply across the shop. Programmes inherit them unless a customer delivery output introduces its own overrides later.</p>

                    <section class="shop-settings-callout">
                        <p class="eyebrow">@(shopDetailsReady ? "Shop details complete" : "Required now")</p>
                        <p class="field-hint">Complete shop name, owner email, town/city, and postcode before creating the first programme. Branding is optional and can be refined later.</p>
                    </section>

                    <EditForm Model="_shopForm" OnValidSubmit="HandleShopSaveAsync" FormName="update-shop" class="form-stack onboarding-form">
                        <DataAnnotationsValidator />
                        <ValidationSummary class="validation-summary" />

                        <section class="shop-settings-group">
                            <div class="shop-settings-group__header">
                                <h4>Shop details</h4>
                                <span class="chip chip--accent">Required</span>
                            </div>

                            <div class="form-grid">
                                <label class="field">
                                    <span>Shop name</span>
                                    <InputText @bind-Value="_shopForm.DisplayName" class="input" />
                                </label>

                                <label class="field">
                                    <span>Owner email</span>
                                    <InputText @bind-Value="_shopForm.ContactEmail" class="input" />
                                </label>

                                <label class="field">
                                    <span>Shop type</span>
                                    <InputSelect @bind-Value="_shopForm.ShopTypeKey" class="input">
                                        @foreach (var shopType in ShopTypes)
                                        {
                                            <option value="@shopType.ShopTypeKey">@shopType.ShopTypeLabel</option>
                                        }
                                    </InputSelect>
                                </label>

                                <label class="field">
                                    <span>Town or city</span>
                                    <InputText @bind-Value="_shopForm.TownOrCity" class="input" />
                                </label>

                                <label class="field">
                                    <span>Postcode</span>
                                    <InputText @bind-Value="_shopForm.Postcode" class="input" />
                                </label>
                            </div>
                        </section>

                        <section class="shop-settings-group">
                            <div class="shop-settings-group__header">
                                <h4>Branding</h4>
                                <span class="chip">Optional</span>
                            </div>

                            <div class="form-grid">
                                <label class="field">
                                    <span>Site primary colour</span>
                                    <InputText @bind-Value="_shopForm.PrimaryColor" class="input" />
                                </label>

                                <label class="field">
                                    <span>Site accent colour</span>
                                    <InputText @bind-Value="_shopForm.AccentColor" class="input" />
                                </label>

                                <div class="field field--full">
                                    <span>Replace logo</span>
                                    <label class="upload-control">
                                        <InputFile OnChange="HandleBrandLogoSelectedAsync" accept=".png" />
                                        <span>Upload a PNG logo. We will suggest colours from it, but you can still override them manually.</span>
                                    </label>
                                </div>
                            </div>
                        </section>

                        @if (!string.IsNullOrWhiteSpace(_shopMessage))
                        {
                            <p class="field-hint">@_shopMessage</p>
                        }

                        <section class="workspace-drawer__preview @brandPreviewTheme.ThemeClass" style="@brandPreviewTheme.CssVariables">
                            <div class="workspace-preview-card">
                                <div class="brand-lockup brand-lockup--merchant">
                                    <img src="@(_pendingLogoPreviewUri ?? _workspace.BrandProfile.LogoUrl)" alt="@_shopForm.DisplayName logo preview" />
                                </div>
                                <div>
                                    <p class="eyebrow">Shared brand preview</p>
                                    <p class="workspace-preview-copy">@_shopForm.DisplayName</p>
                                    <p class="field-hint">Example output: @(selectedProgrammeSummary?.RewardHeadline ?? "Create the first programme to preview customer delivery.")</p>
                                </div>
                            </div>
                        </section>

                        <div class="form-actions form-actions--onboarding form-actions--drawer">
                            <button class="button button--primary button--wide" type="submit" disabled="@_isSavingShop">Save Shop</button>
                            @if (isSignupDemoSeedEnabled)
                            {
                                <button class="button button--secondary button--wide" type="button" @onclick="ApplyShopDemoSeed">Use demo details</button>
                            }
                            <button class="button button--secondary button--wide" type="button" @onclick="ResetShopForm">Reset</button>
                        </div>
                    </EditForm>
                </aside>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public Guid MerchantId { get; set; }

    [SupplyParameterFromQuery(Name = "tab")]
    public string? Tab { get; set; }

    [SupplyParameterFromQuery(Name = "section")]
    public string? Section { get; set; }

    [SupplyParameterFromQuery(Name = "programmeSection")]
    public string? ProgrammeSection { get; set; }

    [SupplyParameterFromQuery(Name = "programme")]
    public Guid? ProgrammeId { get; set; }

    [SupplyParameterFromQuery(Name = "settings")]
    public string? Settings { get; set; }

    [SupplyParameterFromQuery(Name = "launch")]
    public string? Launch { get; set; }

    private MerchantWorkspaceSnapshot? _workspace;
    private string _joinQrSvg = string.Empty;
    private string _scanCode = string.Empty;
    private string? _scanMessage;
    private string? _operateMessage;
    private string? _shopMessage;
    private string? _programmeMessage;
    private bool _isSavingShop;
    private bool _isSavingProgramme;
    private bool _isSetupRoadmapCollapsed;
    private bool _isSetupRoadmapDismissed;
    private bool _isSetupCompletionNoticeDismissed;
    private bool _isFinishingFirstProgrammeSetup;
    private bool _didInitializeRoadmapState;
    private bool _animateProgrammeSelection;
    private string _programmeGroupSort = "end-date";
    private string _selectedTemplateCardTypeKey = "all";
    private Guid? _lastObservedMerchantId;
    private Guid? _lastSelectedProgrammeId;
    private readonly ShopForm _shopForm = new();
    private readonly ProgrammeConfigurationForm _programmeForm = new();
    private readonly HashSet<string> _collapsedProgrammeGroups = new(StringComparer.OrdinalIgnoreCase)
    {
        "Expired"
    };
    private byte[]? _pendingLogoUploadBytes;
    private string? _pendingLogoPreviewUri;
    private string _pendingLogoFileName = "logo.png";
    private MerchantLogoMetadata _pendingLogoMetadata = new(160, 160);

    private WalletPassCapability WalletCapability => WalletPasses.GetCapability();
    private WalletPassPushCapability WalletPushCapability => WalletPushes.GetCapability();
    private IReadOnlyList<ShopTypeOption> ShopTypes => PlatformState.GetShopTypes();
    private IReadOnlyList<CardTypeOption> CardTypes => PlatformState.GetCardTypes();
    private IReadOnlyList<ProgrammeTemplateOption> ProgrammeTemplates => PlatformState.GetProgrammeTemplates(
        _workspace?.Merchant.ShopTypeKey,
        _selectedTemplateCardTypeKey == "all" ? null : _selectedTemplateCardTypeKey);
    private IReadOnlyList<ProgrammeTemplateOption> FilteredProgrammeTemplates => ProgrammeTemplates;
    private string CurrentShopTypeLabel => _workspace is null
        ? "Shop"
        : GetShopTypeLabel(_workspace.Merchant.ShopTypeKey);
    private ProgrammeSummarySnapshot? SelectedProgrammeSummary
    {
        get
        {
            var selectedProgrammeId = _workspace?.SelectedProgramme?.ProgrammeId;
            return selectedProgrammeId is null
                ? null
                : _workspace!.Programmes.FirstOrDefault(x => x.ProgrammeId == selectedProgrammeId.Value);
        }
    }
    private bool IsFirstTimeMode =>
        _workspace is not null
        && !_workspace.SetupChecklist.HasAnyProgramme;
    private bool IsFinishingFirstProgrammeSetup => _isFinishingFirstProgrammeSetup && _workspace?.Programmes.Count == 1;
    private bool ShowSetupCompletionNotice =>
        !_isSetupCompletionNoticeDismissed
        && _workspace is not null
        && !IsFirstTimeMode
        && _workspace.Programmes.Count == 1
        && _workspace.SetupChecklist.JoinReady
        && !IsFinishingFirstProgrammeSetup;
    private bool SelectedProgrammeIsActive =>
        _workspace?.SelectedProgramme is { } selectedProgramme && IsProgrammeActiveOn(selectedProgramme.StartsOn, selectedProgramme.EndsOn);
    private bool IsSignupDemoSeedEnabled =>
        Services.GetService<IConfiguration>()?.GetValue<bool>("Features:SignupDemoSeedEnabled") ?? false;


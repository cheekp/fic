    private async Task HandleBrandLogoSelectedAsync(InputFileChangeEventArgs args)
    {
        var file = args.File;
        if (file is null)
        {
            return;
        }

        if (!string.Equals(file.ContentType, "image/png", StringComparison.OrdinalIgnoreCase))
        {
            _pendingLogoUploadBytes = null;
            _pendingLogoPreviewUri = null;
            _pendingLogoMetadata = _workspace is null
                ? new MerchantLogoMetadata(160, 160)
                : new MerchantLogoMetadata(_workspace.BrandProfile.LogoWidth, _workspace.BrandProfile.LogoHeight);
            _shopMessage = "Please upload a PNG logo for the shop profile.";
            return;
        }

        await using var stream = file.OpenReadStream(2 * 1024 * 1024);
        using var buffer = new MemoryStream();
        await stream.CopyToAsync(buffer);

        _pendingLogoUploadBytes = buffer.ToArray();
        _pendingLogoMetadata = MerchantBrandAssetInspector.ReadLogoMetadata(_pendingLogoUploadBytes);
        _pendingLogoFileName = file.Name;
        _pendingLogoPreviewUri = $"data:{file.ContentType};base64,{Convert.ToBase64String(_pendingLogoUploadBytes)}";
        await SuggestPaletteFromLogoAsync(_pendingLogoPreviewUri);
        _shopMessage = $"{file.Name} loaded. Suggested site colours have been updated from the logo.";
    }


    private async Task HandleAwardVisitAsync()
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return;
        }

        var scannedCode = _scanCode.Trim();
        var updated = PlatformState.AwardVisit(MerchantId, selectedProgramme.ProgrammeId, scannedCode, Navigation.BaseUri);
        if (updated is null)
        {
            _scanMessage = "That pass code does not belong to this programme, or the programme is outside its active dates.";
            _scanCode = string.Empty;
            LoadWorkspace(refreshForms: false);
            return;
        }

        var updatedCard = updated.SelectedProgrammeCards.First(x => x.CardCode == scannedCode);
        var refresh = await TryRequestWalletRefreshAsync(updatedCard);
        _scanMessage = $"Visit stamped. The customer pass now shows {updatedCard.ProgressDisplayText}. {refresh.Summary}";

        _scanCode = string.Empty;
        LoadWorkspace(refreshForms: false);
    }

    private async Task HandleRedeemAsync(Guid cardId)
    {
        var selectedProgramme = _workspace?.SelectedProgramme;
        if (selectedProgramme is null)
        {
            return;
        }

        var currentCard = _workspace?.SelectedProgrammeCards.FirstOrDefault(card => card.CardId == cardId);
        if (currentCard is null || !currentCard.CanRedeem)
        {
            _scanMessage = "That customer pass is not ready to redeem yet.";
            return;
        }

        var updated = PlatformState.RedeemReward(MerchantId, selectedProgramme.ProgrammeId, cardId, Navigation.BaseUri);
        if (updated is null)
        {
            _scanMessage = "The reward could not be marked as redeemed.";
            LoadWorkspace(refreshForms: false);
            return;
        }

        var updatedCard = updated.SelectedProgrammeCards.FirstOrDefault(card => card.CardId == cardId);
        var refresh = updatedCard is null
            ? new WalletPassUpdateDispatchResult(0, 0, 0, true, "Wallet refresh was not requested because the updated pass could not be reloaded.")
            : await TryRequestWalletRefreshAsync(updatedCard);

        _scanMessage = $"Reward redeemed and the customer pass has reset for the next cycle. {refresh.Summary}";
        LoadWorkspace(refreshForms: false);
    }

    private async Task<WalletPassUpdateDispatchResult> TryRequestWalletRefreshAsync(WalletCardSnapshot card)
    {
        if (!WalletCapability.SupportsAppleWalletPass)
        {
            return new WalletPassUpdateDispatchResult(
                0,
                0,
                0,
                true,
                "Wallet refresh was not requested because this environment is still using preview mode.");
        }

        var pushTokens = PlatformState.GetWalletPushTokens(card.CardId);
        var refresh = await WalletPushes.NotifyPassUpdatedAsync(card, pushTokens);

        if (refresh.HasInvalidatedPushTokens)
        {
            PlatformState.RemoveWalletPushTokens(card.CardId, refresh.InvalidatedPushTokens!);
        }

        return refresh;
    }


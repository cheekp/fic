    private bool IsWorkspaceSection(string section) =>
        string.Equals(GetActiveSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsProgrammeSection(string section) =>
        IsWorkspaceSection("programmes") && string.Equals(GetActiveProgrammeSection(), section, StringComparison.OrdinalIgnoreCase);

    private bool IsShopSettingsOpen() =>
        NormalizeRequestedSettings() is not null;

    private bool IsSetupStepActive(SetupStepView step) =>
        (string.Equals(step.Section, "edit", StringComparison.OrdinalIgnoreCase)
            ? IsShopSettingsOpen()
            : string.Equals(GetActiveSection(), step.Section, StringComparison.OrdinalIgnoreCase))
        && (step.Section != "programmes"
            || string.Equals(GetActiveProgrammeSection(), step.ProgrammeSection ?? "operate", StringComparison.OrdinalIgnoreCase));

    private string GetActiveSection() =>
        IsFirstTimeMode && !IsShopSettingsOpen()
            ? "programmes"
            : NormalizeWorkspaceSection(Tab, Section);

    private string GetActiveProgrammeSection() =>
        IsFirstTimeMode
            ? _workspace?.SetupChecklist.HasAnyProgramme == true
                ? NormalizeFirstTimeProgrammeSection(NormalizeProgrammeSection(Tab, Section, ProgrammeSection))
                : "create"
            : NormalizeProgrammeSection(Tab, Section, ProgrammeSection);

    private string? NormalizeRequestedSettings() =>
        string.Equals(Settings, "shop", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Section, "edit", StringComparison.OrdinalIgnoreCase)
        || string.Equals(Tab, "brand", StringComparison.OrdinalIgnoreCase)
            ? "shop"
            : null;

    private static string NormalizeFirstTimeProgrammeSection(string programmeSection) =>
        programmeSection.ToLowerInvariant() switch
        {
            "create" => "create",
            "configure" => "configure",
            "operate" => "operate",
            _ => "operate"
        };

    private void EnforceFirstTimeRouteGuard()
    {
        if (_workspace is null || !IsFirstTimeMode)
        {
            return;
        }

        var requestedProgrammeSection = NormalizeProgrammeSection(Tab, Section, ProgrammeSection);
        var settings = NormalizeRequestedSettings();
        var guardedSettings = !_workspace.SetupChecklist.ShopDetailsComplete ? "shop" : settings;
        var guardedProgrammeSection = _workspace.SetupChecklist.HasAnyProgramme
            ? NormalizeFirstTimeProgrammeSection(requestedProgrammeSection)
            : "create";
        var guardedUrl = GetWorkspaceUrl(
            "programmes",
            guardedProgrammeSection,
            _workspace.SelectedProgramme?.ProgrammeId,
            guardedSettings,
            launch: null);

        if (!string.Equals(guardedUrl, Navigation.Uri, StringComparison.Ordinal))
        {
            Navigation.NavigateTo(guardedUrl, replace: true);
        }
    }

    private string GetWorkspaceSectionUrl(string section) =>
        GetWorkspaceUrl(
            section,
            section == "programmes" ? GetActiveProgrammeSection() : null,
            _workspace?.SelectedProgramme?.ProgrammeId,
            settings: null,
            launch: null);

    private string GetShopSettingsUrl() =>
        GetWorkspaceUrl(

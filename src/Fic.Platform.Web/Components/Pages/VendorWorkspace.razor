    private IReadOnlyList<ProgrammeGroupView> BuildProgrammeGroups()
    {
        if (_workspace is null)
        {
            return [];
        }

        static IReadOnlyList<ProgrammeSummarySnapshot> FilterByStatus(IEnumerable<ProgrammeSummarySnapshot> programmes, string status) =>
            programmes.Where(programme =>
                    string.Equals(
                        BuildProgrammeWindowBadge(programme.StartsOn, programme.EndsOn),
                        status,
                        StringComparison.OrdinalIgnoreCase))
                .ToArray();

        var active = SortProgrammesForRail(FilterByStatus(_workspace.Programmes, "Active"));
        var scheduled = SortProgrammesForRail(FilterByStatus(_workspace.Programmes, "Scheduled"));
        var expired = SortProgrammesForRail(FilterByStatus(_workspace.Programmes, "Expired"));

        return new[]
        {
            new ProgrammeGroupView("Active", active, IsProgrammeGroupCollapsed("Active")),
            new ProgrammeGroupView("Scheduled", scheduled, IsProgrammeGroupCollapsed("Scheduled")),
            new ProgrammeGroupView("Expired", expired, IsProgrammeGroupCollapsed("Expired"))
        }
        .Where(group => group.Programmes.Count > 0)
        .ToArray();
    }

    private IReadOnlyList<ProgrammeSummarySnapshot> SortProgrammesForRail(IReadOnlyList<ProgrammeSummarySnapshot> programmes) =>
        _programmeGroupSort switch
        {
            "name" => programmes
                .OrderBy(programme => programme.RewardHeadline, StringComparer.OrdinalIgnoreCase)
                .ThenBy(programme => programme.EndsOn)
                .ToArray(),
            "start-date" => programmes
                .OrderBy(programme => programme.StartsOn)
                .ThenBy(programme => programme.EndsOn)
                .ThenBy(programme => programme.RewardHeadline, StringComparer.OrdinalIgnoreCase)
                .ToArray(),
            _ => programmes
                .OrderBy(programme => programme.EndsOn)
                .ThenBy(programme => programme.StartsOn)
                .ThenBy(programme => programme.RewardHeadline, StringComparer.OrdinalIgnoreCase)
                .ToArray()
        };

    private static IReadOnlyList<CustomerCardGroupView> BuildCustomerCardGroups(IReadOnlyList<WalletCardSnapshot> cards)
    {
        if (cards.Count == 0)
        {
            return [];
        }

        static IReadOnlyList<WalletCardSnapshot> FilterByStatus(IEnumerable<WalletCardSnapshot> source, CustomerCardStatus status) =>
            source.Where(card => card.CustomerCardStatus == status).ToArray();

        return new[]
        {
            new CustomerCardGroupView("Reward ready", FilterByStatus(cards, CustomerCardStatus.RewardReady)),
            new CustomerCardGroupView("Active", FilterByStatus(cards, CustomerCardStatus.Active)),
            new CustomerCardGroupView("Scheduled", FilterByStatus(cards, CustomerCardStatus.Scheduled)),
            new CustomerCardGroupView("Expired", FilterByStatus(cards, CustomerCardStatus.Expired)),
            new CustomerCardGroupView("Redeemed", FilterByStatus(cards, CustomerCardStatus.Redeemed))
        }
        .Where(group => group.Cards.Count > 0)
        .ToArray();
    }


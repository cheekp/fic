@page "/account/forgot-password"
@using System.ComponentModel.DataAnnotations

<PageTitle>Forgot Password</PageTitle>

<section class="panel company-support account-panel">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star account support</p>
            <h2>Reset your password</h2>
            <p class="lede">
                Use this support surface when a merchant needs account recovery. Password reset delivery is still a
                follow-on step in this internal MVP, but the route now sits in the right support lane.
            </p>
        </div>
    </div>

    <EditForm Model="_form" OnValidSubmit="HandleSubmit" FormName="forgot-password" class="form-stack">
        <DataAnnotationsValidator />
        <ValidationSummary class="validation-summary" />

        <label class="field">
            <span>Email</span>
            <InputText @bind-Value="_form.Email" class="input" />
        </label>

        @if (!string.IsNullOrWhiteSpace(_message))
        {
            <p class="field-hint">@_message</p>
        }

        <div class="form-actions">
            <button class="button button--primary" type="submit">Send Reset Link</button>
            <a class="button button--ghost" href="/account/login">Back to Log In</a>
        </div>
    </EditForm>

    <div class="company-support__footer">
        <p>If recovery turns into an onboarding or billing question, North Star support can pick it up from here.</p>
        <div class="company-support__links">
            <a class="inline-link" href="/support/account">Account support</a>
            <a class="inline-link" href="/support/billing">Billing support</a>
        </div>
    </div>
</section>

@code {
    private readonly ForgotPasswordFormModel _form = new();
    private string? _message;

    private void HandleSubmit() =>
        _message = $"Password reset delivery is not wired yet. North Star support would pick up the recovery request for {_form.Email}.";

    private sealed class ForgotPasswordFormModel
    {
        [Required, EmailAddress]
        public string Email { get; set; } = "owner@joscoffee.test";
    }
}

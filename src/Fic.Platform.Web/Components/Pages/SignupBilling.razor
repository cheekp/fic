@page "/portal/signup/billing/{MerchantId:guid}"
@inject DemoPlatformState PlatformState
@inject NavigationManager Navigation

<PageTitle>Billing Setup</PageTitle>

@if (_workspace is null)
{
    <section class="empty-state">
        <h2>Shop setup not found.</h2>
        <p>The shop may not exist in the current demo instance.</p>
        <a class="button button--primary" href="/portal/signup">Back to shop signup</a>
    </section>
}
else
{
    <section class="panel signup-panel">
        <div class="panel__header">
            <div>
                <p class="eyebrow">Step 2 of 3</p>
                <h2>Confirm billing</h2>
                <p class="lede">Final account step before the workspace opens for @_workspace.Merchant.DisplayName. Set the owner password here, then create the first programme inside the shop area.</p>
            </div>
        </div>

        <form method="post" action="/account/session/complete-signup" class="form-stack">
            <input type="hidden" name="merchantId" value="@MerchantId" />
            <input type="hidden" name="returnUrl" value="@($"/portal/merchant/{MerchantId}?tab=programmes&section=programmes&programmeSection=create")" />
            <div class="form-grid">
                <label class="field">
                    <span>Plan</span>
                    <select name="plan" class="input">
                        <option value="founding">Founding coffee shop</option>
                        <option value="growth">Growth coffee shop</option>
                    </select>
                </label>

                <label class="field">
                    <span>Billing email</span>
                    <input class="input" type="email" name="billingEmail" value="@_billingEmail" />
                </label>

                <label class="field">
                    <span>Cardholder name</span>
                    <input class="input" type="text" name="cardholderName" value="@_cardholderName" />
                </label>

                <label class="field">
                    <span>Card number</span>
                    <input class="input" type="text" name="cardNumber" value="4242 4242 4242 4242" />
                </label>

                <label class="field">
                    <span>Owner password</span>
                    <input class="input" type="password" name="password" autocomplete="new-password" required minlength="8" />
                </label>

                <label class="field">
                    <span>Confirm password</span>
                    <input class="input" type="password" name="confirmPassword" autocomplete="new-password" required minlength="8" />
                </label>
            </div>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <p class="field-hint">@_message</p>
            }

            <p class="field-hint">Shop: @_workspace.Merchant.DisplayName, @_workspace.Merchant.TownOrCity, @_workspace.Merchant.Postcode</p>

            <div class="form-actions">
                <button class="button button--primary" type="submit">Open Workspace</button>
                <a class="button button--ghost" href="/portal/signup">Back to shop signup</a>
            </div>
        </form>
    </section>
}

@code {
    [Parameter]
    public Guid MerchantId { get; set; }

    [SupplyParameterFromQuery]
    public string? Error { get; set; }

    private MerchantWorkspaceSnapshot? _workspace;
    private string _billingEmail = string.Empty;
    private string _cardholderName = string.Empty;
    private string? _message;

    protected override void OnParametersSet()
    {
        _workspace = PlatformState.GetMerchantWorkspace(MerchantId, Navigation.BaseUri);
        if (_workspace is not null)
        {
            _billingEmail = _workspace.Merchant.ContactEmail;
            _cardholderName = _workspace.Merchant.DisplayName;
        }

        _message = Error switch
        {
            "password-mismatch" => "The password fields must match before the workspace can open.",
            "invalid-password" => "Choose a password with at least 8 characters.",
            "merchant-not-found" => "The shop setup could not be found. Start again from signup.",
            _ => null
        };
    }
}

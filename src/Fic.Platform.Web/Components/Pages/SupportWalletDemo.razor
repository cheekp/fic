@page "/support/wallet-demo"
@inject IAppleWalletPassService WalletPasses
@inject IWalletPassUpdateNotifier WalletPushes

<PageTitle>Wallet Demo Support</PageTitle>

@{
    var issuanceCapability = WalletPasses.GetCapability();
    var refreshCapability = WalletPushes.GetCapability();
}

<section class="panel company-support">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star Wallet support</p>
            <h2>Apple Wallet demo readiness</h2>
            <p class="lede">
                Check whether this environment can both issue a real signed Apple Wallet pass and request a refresh after merchant actions.
            </p>
        </div>
        <span class="chip @((issuanceCapability.SupportsAppleWalletPass && refreshCapability.IsReady) ? "chip--success" : string.Empty)">
            @((issuanceCapability.SupportsAppleWalletPass && refreshCapability.IsReady) ? "Founder demo ready" : "Demo setup needed")
        </span>
    </div>

    <div class="metrics-grid">
        <article class="metric-card">
            <span class="metric-card__label">Pass issuance</span>
            <strong class="metric-card__value">@(issuanceCapability.SupportsAppleWalletPass ? "Ready" : "Preview")</strong>
            <p class="metric-card__copy">@issuanceCapability.HelperText</p>
            @if (issuanceCapability.HasDiagnostics)
            {
                <ul class="support-list">
                    @foreach (var issue in issuanceCapability.DiagnosticItems!)
                    {
                        <li>@issue</li>
                    }
                </ul>
            }
        </article>

        <article class="metric-card">
            <span class="metric-card__label">Pass refresh</span>
            <strong class="metric-card__value">@(refreshCapability.IsReady ? "Ready" : "Setup")</strong>
            <p class="metric-card__copy">@refreshCapability.HelperText</p>
            @if (refreshCapability.HasDiagnostics)
            {
                <ul class="support-list">
                    @foreach (var issue in refreshCapability.DiagnosticItems!)
                    {
                        <li>@issue</li>
                    }
                </ul>
            }
        </article>
    </div>

    <div class="company-support__summary">
        <p>To complete the founder demo, make sure you have:</p>
        <ul>
            <li>a Wallet pass type identifier</li>
            <li>a team identifier</li>
            <li>a signing certificate exported as <code>.p12</code></li>
            <li>the Apple WWDR certificate</li>
            <li>local secrets configured for the web app</li>
            <li>Wallet refresh push enabled for this environment</li>
        </ul>
        <p>Run <code>./scripts/run-wallet-demo-lan.sh</code> once the environment is ready. After the customer adds the pass, stamp a visit from the merchant workspace and check that the refresh request is reported there.</p>
        <p>Merchant refresh status now reports one of: <strong>sent</strong>, <strong>skipped</strong>, <strong>retry needed</strong>, or <strong>unavailable</strong>.</p>
        <p>If refresh did not arrive on device:</p>
        <ul>
            <li>confirm the merchant message was not <strong>skipped</strong> or <strong>unavailable</strong></li>
            <li>if status is <strong>retry needed</strong>, repeat the stamp once and watch for APNs transient recovery</li>
            <li>if status reports invalid registrations, remove and re-add the pass on device to re-register push</li>
        </ul>
    </div>

    <div class="company-support__actions">
        <a class="button button--primary" href="/portal/signup">Open merchant setup</a>
        <a class="button button--ghost" href="/consultancy">Training &amp; Consultancy</a>
    </div>

    <CompanySocialRail Compact="true" />
</section>

@page "/"

<PageTitle>FIC Loyalty</PageTitle>

<section class="panel home-landing">
    <div class="home-landing__utility">
        <div class="home-landing__utility-links">
            <a href="/account/login">Log In</a>
            <a href="/account/forgot-password">Forgot password?</a>
        </div>
    </div>

    <div class="home-landing__media">
        <img src="/images/home-hero.jpeg" alt="Customers sitting in a bright independent coffee shop." />
    </div>

    <div class="home-landing__content">
        <p class="eyebrow">For independent coffee shops</p>
        <h2>Set up your loyalty programme in minutes.</h2>

        <blockquote class="home-landing__quote">
            “Customer loyalty is not driven by rewards alone. It emerges from the combined influence of value, recognition, experience, and connection.”
        </blockquote>

        <a class="button button--primary" href="/portal/signup">Sign Up Now</a>
    </div>
</section>

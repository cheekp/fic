@page "/"

<PageTitle>North Star | Apple Wallet loyalty for coffee shops</PageTitle>

<section class="panel company-home">
    <div class="company-home__header">
        <div class="company-home__brand">
            <p class="eyebrow">North Star loyalty platform</p>
            <p class="company-home__strap">Apple Wallet loyalty for independent coffee shops.</p>
        </div>

        <nav class="company-home__utility" aria-label="Company links">
            <a href="/account/login">Merchant log in</a>
        </nav>
    </div>

    <div class="company-home__media">
        <img src="/images/home-hero.jpeg" alt="Customers sitting in a bright independent coffee shop." />
    </div>

    <div class="company-home__content">
        <p class="eyebrow">Launch in minutes</p>
        <h1>Set up your Apple Wallet loyalty programme in minutes.</h1>
        <p class="lede">
            Create your shop, choose a plan, and launch your first customer-ready programme in one guided flow.
        </p>

        <div class="company-home__signals" aria-label="Product highlights">
            <span class="chip">Apple Wallet first</span>
            <span class="chip">Simple QR join</span>
            <span class="chip">No customer app</span>
        </div>

        <div class="company-home__actions">
            <a class="button button--primary button--cta button--wide" href="/portal/signup">Sign up now</a>
        </div>

        <CompanySocialRail />
    </div>
</section>

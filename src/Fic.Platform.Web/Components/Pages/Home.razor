@page "/"

<PageTitle>North Star Customer Solutions</PageTitle>

<section class="panel company-home">
    <div class="company-home__header">
        <div class="company-home__brand">
            <p class="eyebrow">North Star Customer Solutions</p>
            <p class="company-home__strap">Loyalty. Membership. Customer Strategy.</p>
        </div>

        <nav class="company-home__utility" aria-label="Company links">
            <a href="/consultancy">Training &amp; Consultancy</a>
            <a href="/account/login">Log In</a>
            <a href="/account/forgot-password">Forgot password?</a>
        </nav>
    </div>

    <div class="company-home__grid">
        <div class="company-home__content">
            <p class="eyebrow">For independent coffee shops</p>
            <h1>Designing loyalty that actually works.</h1>
            <p class="lede">
                FIC is the wallet-first loyalty product from North Star Customer Solutions. Start quickly,
                keep the customer experience simple, and let the deeper strategy sit behind the scenes.
            </p>

            <blockquote class="company-home__quote">
                “Customer loyalty is not driven by rewards alone. It emerges from the combined influence of value,
                recognition, experience, and connection.”
            </blockquote>

            <div class="company-home__actions">
                <a class="button button--primary" href="/portal/signup">Set Up Your Loyalty Programme</a>
                <a class="button button--ghost" href="/consultancy">Explore Consultancy</a>
            </div>

            <p class="company-home__note">
                Use FIC when you want a clean self-serve loyalty product. Use North Star when you want broader
                loyalty, membership, and customer strategy support.
            </p>
        </div>

        <div class="company-home__media">
            <img src="/images/home-hero.jpeg" alt="Customers sitting in a bright independent coffee shop." />
        </div>
    </div>
</section>

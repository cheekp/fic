@page "/"
@implements IDisposable
@inject DemoPlatformState PlatformState

<PageTitle>FIC Loyalty</PageTitle>

<section class="hero-panel">
    <div>
        <p class="eyebrow">FIC merchant onboarding</p>
        <h2>Create a merchant workspace, brand it, publish the join QR, and manage issued wallet cards.</h2>
        <p class="lede">This should feel like the vendor experience: set up the brand and loyalty card once, then run the programme from the workspace instead of bouncing through a demo console.</p>
    </div>
    <div class="hero-panel__actions">
        <a class="button button--primary" href="/portal/signup">Create Merchant Workspace</a>
        <span class="chip">Apple Wallet first</span>
        <span class="chip">No customer app required</span>
    </div>
</section>

<section class="metrics-grid">
    <article class="metric-card">
        <span class="metric-card__label">Workspace</span>
        <strong class="metric-card__value">Brand</strong>
        <p class="metric-card__copy">Set the business name, logo, and colours that define the merchant-facing experience.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Template</span>
        <strong class="metric-card__value">Card</strong>
        <p class="metric-card__copy">Configure the loyalty rule and customer-facing wallet card copy.</p>
    </article>
    <article class="metric-card">
        <span class="metric-card__label">Operations</span>
        <strong class="metric-card__value">Customers</strong>
        <p class="metric-card__copy">Issue passes, scan visits, and manage customer card state inside the same workspace.</p>
    </article>
</section>

@if (_latestMerchant is null)
{
    <section class="empty-state">
        <h4>No merchant workspace created yet.</h4>
        <p>Start by creating a merchant workspace. Once that exists, the merchant can manage brand, card template, and issued customer cards from one place.</p>
        <a class="button button--primary" href="/portal/signup">Create Your First Merchant Workspace</a>
    </section>
}
else
{
    <section class="panel latest-workspace">
        <div class="panel__header">
            <div>
                <p class="eyebrow">Continue where you left off</p>
                <h3>@_latestMerchant.DisplayName</h3>
            </div>
            <span class="chip chip--accent">@_latestMerchant.RewardHeadline</span>
        </div>
        <dl class="resume-card__metrics">
            <div>
                <dt>Active cards</dt>
                <dd>@_latestMerchant.ActiveCards</dd>
            </div>
            <div>
                <dt>Rewards unlocked</dt>
                <dd>@_latestMerchant.RewardsUnlocked</dd>
            </div>
            <div>
                <dt>Join code</dt>
                <dd>@_latestMerchant.JoinCode</dd>
            </div>
        </dl>
        <div class="resume-card__actions">
            <a class="button button--primary" href="/portal/merchant/@_latestMerchant.MerchantId?tab=brand">Open Merchant Workspace</a>
            <a class="button button--ghost" href="/portal/signup">Create Another Merchant</a>
        </div>
        <p class="field-hint">
            Local demo-only tools:
            <a class="inline-link" href="/dev/workspaces">browse all local workspaces</a>.
        </p>
    </section>
}

@code {
    private IReadOnlyList<MerchantSummarySnapshot> _merchants = [];
    private MerchantSummarySnapshot? _latestMerchant;

    protected override void OnInitialized()
    {
        LoadState();
        PlatformState.Changed += HandleStateChanged;
    }

    private void LoadState()
    {
        _merchants = PlatformState.GetMerchantSummaries();
        _latestMerchant = _merchants.FirstOrDefault();
    }

    private void HandleStateChanged() =>
        _ = InvokeAsync(() =>
        {
            LoadState();
            StateHasChanged();
        });

    public void Dispose()
    {
        PlatformState.Changed -= HandleStateChanged;
    }
}

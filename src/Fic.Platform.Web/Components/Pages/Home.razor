@page "/"

<PageTitle>FIC | Wallet loyalty for coffee shops</PageTitle>

<section class="panel company-home">
    <div class="company-home__header">
        <div class="company-home__brand">
            <p class="eyebrow">North Star Customer Solutions</p>
            <p class="company-home__strap">Strategy, support, and training behind FIC.</p>
        </div>

        <nav class="company-home__utility" aria-label="Company links">
            <a href="/account/login">Log In</a>
            <a href="/consultancy">Consultancy</a>
        </nav>
    </div>

    <div class="company-home__media">
        <img src="/images/home-hero.jpeg" alt="Customers sitting in a bright independent coffee shop." />
    </div>

    <div class="company-home__content">
        <p class="eyebrow">FIC for independent coffee shops</p>
        <h1>Set up your wallet loyalty programme in minutes.</h1>
        <p class="lede">
            Launch a simple Apple Wallet loyalty programme for your shop. No customer app, no clunky sign-up,
            and no need to explain the product at the counter.
        </p>

        <div class="company-home__signals" aria-label="Product highlights">
            <span class="chip">Apple Wallet first</span>
            <span class="chip">Simple QR join</span>
            <span class="chip">No customer app</span>
        </div>

        <div class="company-home__actions">
            <a class="button button--primary" href="/portal/signup">Set Up Your Shop</a>
            <a class="inline-link company-home__login-link" href="/account/login">Already have an account?</a>
        </div>

        <p class="company-home__note">
            Backed by North Star Customer Solutions for rollout support, training, and broader loyalty strategy.
        </p>

        <blockquote class="company-home__quote">
            “Customer loyalty is not driven by rewards alone. It emerges from the combined influence of value,
            recognition, experience, and connection.”
        </blockquote>
    </div>
</section>

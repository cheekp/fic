@page "/support/billing"

<PageTitle>Billing Support</PageTitle>

<section class="panel company-support">
    <div class="panel__header">
        <div>
            <p class="eyebrow">North Star billing support</p>
            <h2>Billing and commercial help</h2>
            <p class="lede">
                Use this support surface for plan, commercial onboarding, and invoice questions. Live billing is not
                wired yet, but the support path is here.
            </p>
        </div>
    </div>

    <div class="company-support__summary">
        <p>Typical reasons to use this area:</p>
        <ul>
            <li>clarify plan fit before launch</li>
            <li>check who the billing contact should be</li>
            <li>route pricing or rollout questions into the right support conversation</li>
        </ul>
    </div>

    <div class="company-support__actions">
        <a class="button button--primary" href="/portal/signup">Continue to setup</a>
        <a class="button button--ghost" href="/consultancy">Training &amp; Consultancy</a>
    </div>

    <CompanySocialRail Compact="true" />
</section>

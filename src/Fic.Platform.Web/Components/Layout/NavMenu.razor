@using Fic.Platform.Web.Components.Layout

<div class="nav-shell">
    <div class="nav-brand">
        @if (!string.IsNullOrWhiteSpace(ShellContext.LogoUrl))
        {
            <div class="nav-brand__mark">
                <img src="@ShellContext.LogoUrl" alt="@ShellContext.SidebarName logo" />
            </div>
        }
        <p class="nav-brand__kicker">@ShellContext.SidebarKicker</p>
        <a class="nav-brand__name" href="">@ShellContext.SidebarName</a>
        <p class="nav-brand__copy">@ShellContext.SidebarCopy</p>
    </div>

    <nav class="nav-links">
        <NavLink class="nav-links__item" href="" Match="NavLinkMatch.All">Start Here</NavLink>
        <NavLink class="nav-links__item" href="portal/signup">Create Your Card</NavLink>
    </nav>

    <div class="nav-panel">
        <p class="nav-panel__title">@ShellContext.PanelTitle</p>
        <ul class="nav-panel__list">
            @foreach (var point in ShellContext.PanelPoints)
            {
                <li>@point</li>
            }
        </ul>
    </div>
</div>

@code {
    [Parameter]
    public MainLayout.ShellContext ShellContext { get; set; } = MainLayout.ShellContext.Default;
}

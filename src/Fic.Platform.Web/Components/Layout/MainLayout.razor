            string.Empty,
            [],
            null,
            null,
            new AgentContext(
                "Support",
                "Get account help",
                "Use this discreet launcher if you need support with access, password recovery, or account ownership.",
                "Open account help",
                "Ask about access",
                "Contact North Star"));

        public static ShellContext AccountRecovery { get; } = new(

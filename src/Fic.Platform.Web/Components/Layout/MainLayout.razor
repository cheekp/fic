            "recovery",
            false,
            false,
            false,
            false,
            false,
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty,
            [],
            null,
            null,
            new AgentContext(
                "Support",
                "Get recovery help",
                "Use this discreet launcher if you need help recovering access or routing the merchant back into the right support path.",
                "Open recovery help",

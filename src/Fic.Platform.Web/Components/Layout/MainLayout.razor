            "consultancy",
            false,
            false,
            false,
            false,
            false,
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty,
            [],
            null,
            null,
            new AgentContext(
                "Consultancy",
                "Speak with North Star",

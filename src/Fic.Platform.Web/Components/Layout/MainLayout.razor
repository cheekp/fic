            string.Empty,
            string.Empty,
            [],
            null,
            null,
            new AgentContext(
                "Setup",
                "Get onboarding help",
                "Use this discreet launcher if you need help creating the shop account before moving into billing and workspace setup.",
                "Open setup help",
                "Ask about setup",
                "Talk to North Star"));

        public static ShellContext Billing { get; } = new(
            "Commercial onboarding",
            "Confirm billing",
            "This step simulates commercial onboarding before the merchant lands in the live workspace.",
            "billing",
            false,
            false,
            false,
            false,
            false,
            string.Empty,
            string.Empty,
            string.Empty,
            string.Empty,
            [],
            null,
            null,
            new AgentContext(
                "Billing",
                "Get billing help",
                "Use this discreet launcher for plan, pricing, or mock billing questions during onboarding.",
                "Open billing help",
                "Ask about billing",
                "Talk to North Star"));

        public static ShellContext Login { get; } = new(

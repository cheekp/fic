{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/join/[joinCode]",
      "regex": "^/join/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPjoinCode": "nxtPjoinCode"
      },
      "namedRegex": "^/join/(?<nxtPjoinCode>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/merchant/[merchantId]",
      "regex": "^/portal/merchant/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmerchantId": "nxtPmerchantId"
      },
      "namedRegex": "^/portal/merchant/(?<nxtPmerchantId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/signup/billing/[merchantId]",
      "regex": "^/portal/signup/billing/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmerchantId": "nxtPmerchantId"
      },
      "namedRegex": "^/portal/signup/billing/(?<nxtPmerchantId>[^/]+?)(?:/)?$"
    },
    {
      "page": "/portal/signup/plan/[merchantId]",
      "regex": "^/portal/signup/plan/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPmerchantId": "nxtPmerchantId"
      },
      "namedRegex": "^/portal/signup/plan/(?<nxtPmerchantId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/account",
      "regex": "^/account(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/account(?:/)?$"
    },
    {
      "page": "/billing",
      "regex": "^/billing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/billing(?:/)?$"
    },
    {
      "page": "/blogs",
      "regex": "^/blogs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/blogs(?:/)?$"
    },
    {
      "page": "/consultancy",
      "regex": "^/consultancy(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/consultancy(?:/)?$"
    },
    {
      "page": "/manifest.webmanifest",
      "regex": "^/manifest\\.webmanifest(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/manifest\\.webmanifest(?:/)?$"
    },
    {
      "page": "/offline",
      "regex": "^/offline(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/offline(?:/)?$"
    },
    {
      "page": "/portal/signup",
      "regex": "^/portal/signup(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/portal/signup(?:/)?$"
    },
    {
      "page": "/training",
      "regex": "^/training(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/training(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}